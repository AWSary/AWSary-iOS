{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://awsary.example/schemas/community/person.schema.json",
  "title": "AWSary Community Person",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "displayName",
    "headline",
    "summary",
    "location",
    "avatar",
    "programs",
    "topics",
    "links",
    "featuredContent",
    "sourceEvidence",
    "profileStatus",
    "ownershipStatus",
    "lastReviewedAt",
    "lastHarvestedAt"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^person_[a-z0-9]+(?:_[a-z0-9]+)*$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "displayName": { "type": "string", "minLength": 1, "maxLength": 200 },
    "headline": { "type": ["string", "null"], "maxLength": 300 },
    "summary": { "type": ["string", "null"], "maxLength": 10000 },
    "location": { "$ref": "#/$defs/location" },
    "avatar": { "$ref": "#/$defs/avatar" },
    "programs": {
      "type": "array",
      "items": { "$ref": "#/$defs/program" }
    },
    "topics": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 100 },
      "uniqueItems": true
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    },
    "featuredContent": {
      "type": "array",
      "items": { "$ref": "#/$defs/featuredContent" }
    },
    "sourceEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceEvidence" }
    },
    "profileStatus": {
      "enum": ["draft", "published", "hidden", "needs_review"]
    },
    "ownershipStatus": {
      "enum": ["unclaimed", "claimed", "pending_claim"]
    },
    "lastReviewedAt": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date-time" }
      ]
    },
    "lastHarvestedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "sourceType": {
      "enum": ["aws_builder_center", "aws_public_page", "manual", "owner_submitted"]
    },
    "verificationStatus": {
      "enum": [
        "aws_source_verified",
        "owner_verified",
        "admin_verified",
        "source_observed",
        "unverified",
        "expired"
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["city", "country", "region"],
      "properties": {
        "city": { "type": ["string", "null"], "maxLength": 200 },
        "country": { "type": ["string", "null"], "maxLength": 200 },
        "region": { "type": ["string", "null"], "maxLength": 200 }
      }
    },
    "avatar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "sourceUrl", "sourceType", "verified"],
      "properties": {
        "url": {
          "oneOf": [{ "type": "null" }, { "type": "string", "format": "uri" }]
        },
        "sourceUrl": {
          "oneOf": [{ "type": "null" }, { "type": "string", "format": "uri" }]
        },
        "sourceType": { "$ref": "#/$defs/sourceType" },
        "verified": { "type": "boolean" }
      }
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "category",
        "startYear",
        "endYear",
        "verificationStatus",
        "sourceUrl",
        "lastCheckedAt"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "category": { "type": ["string", "null"], "maxLength": 200 },
        "startYear": { "type": ["integer", "null"], "minimum": 2000, "maximum": 2100 },
        "endYear": { "type": ["integer", "null"], "minimum": 2000, "maximum": 2100 },
        "verificationStatus": { "$ref": "#/$defs/verificationStatus" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "lastCheckedAt": { "type": "string", "format": "date" }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label", "url", "handle", "verified", "sourceUrl"],
      "properties": {
        "type": {
          "enum": [
            "builder_center",
            "website",
            "linkedin",
            "x",
            "github",
            "youtube",
            "twitch",
            "blog",
            "newsletter",
            "mastodon",
            "other"
          ]
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 200 },
        "url": { "type": "string", "format": "uri" },
        "handle": { "type": ["string", "null"], "maxLength": 200 },
        "verified": { "type": "boolean" },
        "sourceUrl": { "type": "string", "format": "uri" }
      }
    },
    "featuredContent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url", "contentType", "sourceUrl"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "url": { "type": "string", "format": "uri" },
        "contentType": { "type": "string", "minLength": 1, "maxLength": 100 },
        "sourceUrl": { "type": "string", "format": "uri" }
      }
    },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "sourceUrl", "retrievedAt", "fields"],
      "properties": {
        "sourceType": { "$ref": "#/$defs/sourceType" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "retrievedAt": { "type": "string", "format": "date-time" },
        "fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*(?:\\.[A-Za-z][A-Za-z0-9]*)*$"
          }
        }
      }
    }
  }
}
