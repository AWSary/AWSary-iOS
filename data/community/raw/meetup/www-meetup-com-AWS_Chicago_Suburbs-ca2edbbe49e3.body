nts/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Group:18646699":{"__typename":"Group","id":"18646699","name":"AWS Chicago Western Suburbs","timezone":"America/Chicago","keyGroupPhoto":{"__ref":"PhotoInfo:530359244"},"urlname":"aws_chicago_western_suburbs","isPrivate":false,"organizer":{"__ref":"Member:417412934"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":1203,"leadership":1,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.79,"total":85}},"lat":41.78,"lon":-88.25,"joinMode":"OPEN","status":"PAID","city":"Naperville","state":"IL","country":"us","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":false,"needsPhoto":false,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws_chicago_western_suburbs/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"Thanks for joining! We are excited to meet you.","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:417412934"}}]},"description":"**AWS Chicago Western Suburbs** is a thriving community of AWS professionals, developers, architects, and technology enthusiasts in Naperville, Aurora, Schaumburg, and the greater western suburbs of Chicago. We host meetups, hands-on workshops, and networking events focused on AWS technologies covering cloud architecture, AI/ML, DevOps, serverless, data engineering, and security. \n \n Our mission is to foster learning, collaboration, and innovation for members at every skill level, from newcomers to seasoned cloud practitioners.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":15,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:313787557"}},{"__typename":"EventEdge","node":{"__ref":"Event:313256754"}},{"__typename":"EventEdge","node":{"__ref":"Event:312798459"}},{"__typename":"EventEdge","node":{"__ref":"Event:311205522"}}]},"activeTopics":[{"__ref":"Topic:15166"},{"__ref":"Topic:15167"},{"__ref":"Topic:661712"},{"__ref":"Topic:20479"},{"__ref":"Topic:24410"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[]},"foundedDate":"2015-06-03T14:40:20-05:00","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:47252302"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:1149