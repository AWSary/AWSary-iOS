hotoInfo:318727550"}},"Rsvp:2065727420":{"__typename":"Rsvp","id":"2065727420","member":{"__ref":"Member:414701759"}},"PhotoInfo:269395490":{"__typename":"PhotoInfo","id":"269395490","highResUrl":"https://secure.meetupstatic.com/photos/member/d/8/c/2/highres_269395490.jpeg"},"Member:233260705":{"__typename":"Member","id":"233260705","name":"Ademola Adedeji","memberPhoto":{"__ref":"PhotoInfo:269395490"}},"Rsvp:2065727478":{"__typename":"Rsvp","id":"2065727478","member":{"__ref":"Member:233260705"}},"PhotoInfo:324569557":{"__typename":"PhotoInfo","id":"324569557","highResUrl":"https://secure.meetupstatic.com/photos/member/7/3/7/5/highres_324569557.jpeg"},"Member:296363832":{"__typename":"Member","id":"296363832","name":"Bhavika Mantri","memberPhoto":{"__ref":"PhotoInfo:324569557"}},"Rsvp:2065727655":{"__typename":"Rsvp","id":"2065727655","member":{"__ref":"Member:296363832"}},"Event:313787557":{"__typename":"Event","id":"313787557","title":"AWS Community on Tour is coming to Chicago!","eventUrl":"https://www.meetup.com/aws_chicago_western_suburbs/events/313787557/","description":"**AWS Community on Tour is coming to Chicago!**\n\nThe AWS Developer Advocate team is hitting the road this spring and stopping in Chicago as part of the North America AWS Community Tour.\nJoin the Chicago AWS User Group for a special evening with AWS Developer Advocates and builders from across the local community.\nThis stop will feature a **hands-on workshop on agentic AI development**, along with plenty of time to connect with other developers and talk about what you're building on AWS.\nWe’ll also be celebrating **20 years of AWS** and spotlighting members of the developer community who help make groups like this possible.\nSeveral AWS Developer Advocates will be joining the tour, including **Aaron Hunter, Brooke Jamieson, Jonathan Vogel**, and others from the DevRel team.\n\nExpect:\n\n* A hands-on workshop\n* Conversations with AWS Developer Advocates\n* Networking with builders in your city\n* Food, beverages, and AWS community swag\n\nIf you're building with AWS—or just getting started—we’d love to see you there.","isSaved":false,"group":{"__ref":"Group:18646699"},"creatorMember":{"__ref":"Member:417412934"},"eventHosts":[{"__typename":"EventHost","memberId":"417412934"}],"feeSettings":null,"venue":{"__ref":"Venue:24851566"},"dateTime":"2026-04-29T18:00:00-05:00","createdTime":"2026-03-15T19:20:04-04:00","endTime":"2026-04-29T20:00:00-05:00","going":{"__typename":"GoingRsvpConnection","totalCount":113},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:530359244"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":113,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065667025"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065727121"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065727420"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065727478"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065727655"}}]},"maxTickets":120,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":true},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:24725840":{"__typename":"Venue","id":"24725840","name":"Amazon Chicago","address":"227 W. Monroe St.","city":"Chicago","state":"IL","country":"us"},"Rsvp:2062351074":{"__typename":"Rsvp","id":"2062351074","member":{"__ref":"Member:417412934"}},"Rsvp:2062495330":{"__typename":"Rsvp","id":"2062495330","member":{"__ref":"Member:296363832"}},"PhotoInfo:319350281":{"__typename":"PhotoInfo","id":"319350281","highResUrl":"https://secure.meetupstatic.com/photos/member/7/6/4/9/highres_319350281.jpeg"},"Member:405832619":{"__typename":"Member","id":"405832619","name":"Prishitha ","memberPhoto":{"__ref":"PhotoInfo:319350281"}},"Rsvp:2062637427":{"__typename":"Rsvp","id":"2062637427","member":{"__ref":"Member:405832619"}},"PhotoInfo:325599577":{"__typename":"PhotoInfo","id":"325599577","highResUrl":"https://secure.meetupstatic.com/photos/member/9/a/9/9/highres_325599577.jpeg"},"Member:249675487":{"__typename":"Member","id":"249675487","name":"Dhawal Gajwe","memberPhoto":{"__ref":"PhotoInfo:325599577"}},"Rsvp:2062642054":{"__typename":"Rsvp","id":"2062642054","member":{"__ref":"Member:249675487"}},"Member:474573922":{"__typename":"Member","id":"474573922","name":"Andrea","memberPhoto":null},"Rsvp:2062690276":{"__typename":"Rsvp","id":"2062690276","member":{"__ref":"Member:474573922"}},"Event:313256754":{"__typename":"Event","id":"313256754","title":"Observability as the Foundation for AWS Well-Architected Cloud Infrastructure","eventUrl":"https://www.meetup.com/aws_chicago_western_suburbs/events/313256754/","description":"Managing AWS at scale means balancing performance, cost, and business objectives—but are you making decisions based on assumptions or evidence? Join Bob Dussault from Sycomp to discover why observability isn't just monitoring; it's the architectural foundation that enables excellence across all six pillars of the AWS Well-Architected Framework. Learn how Sycomp's Intelligent Cloud+, Intelligent Observability+, and Managed FinOps services help organizations build observable, cost-efficient infrastructure that delivers measurable business value","isSaved":false,"group":{"__ref":"Group:18646699"},"creatorMember":{"__ref":"Member:417412934"},"eventHosts":[{"__typename":"EventHost","memberId":"417412934"}],"feeSettings":null,"venue":{"__ref":"Venue:24725840"},"dateTime":"2026-02-26T18:00:00-06:00","createdTime":"2026-02-07T17:03:42-05:00","endTime":"2026-02-26T20:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":37},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:530359244"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":37,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062351074