o:307731880":{"__typename":"PhotoInfo","id":"307731880","highResUrl":"https://secure.meetupstatic.com/photos/member/c/a/a/8/highres_307731880.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:11678257":{"__typename":"Member","id":"11678257","name":"William B. Conway III","memberPhoto":{"__ref":"PhotoInfo:307731880"}},"Rsvp:2059612897":{"__typename":"Rsvp","id":"2059612897","member":{"__ref":"Member:11678257"}},"PhotoInfo:192653992":{"__typename":"PhotoInfo","id":"192653992","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/d/2/e/8/highres_192653992.jpeg"},"PhotoInfo:320762906":{"__typename":"PhotoInfo","id":"320762906","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/b/5/a/highres_320762906.jpeg"},"PhotoInfo:53407392":{"__typename":"PhotoInfo","id":"53407392","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/1/c/e/0/highres_53407392.jpeg"},"PhotoInfo:252980428":{"__typename":"PhotoInfo","id":"252980428","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/4/f/c/c/highres_252980428.jpeg"},"Event:312798459":{"__typename":"Event","id":"312798459","title":"Your re:Invent Recap — Join Us Online","eventUrl":"https://www.meetup.com/aws_chicago_western_suburbs/events/312798459/","description":"Didn’t make it to re:Invent, or felt a bit lost with all the announcements? You’re not alone and we’ve got you covered. Join us for a relaxed online session where we’ll walk through the most interesting highlights and explain what really matters.\n\nThe session will be hosted by AWS Developer Advocate **Darko Mesaroš**, who’ll spend two hours sharing key moments, insights, and real-world takeaways. It’s a great chance to catch up and learn without the overwhelm.\n\nWe’ll send the Zoom link ahead of the event. Hope to see you there!","isSaved":false,"group":{"__ref":"Group:18646699"},"creatorMember":{"__ref":"Member:417412934"},"eventHosts":[{"__typename":"EventHost","memberId":"417412934"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-01-15T12:00:00-06:00","createdTime":"2026-01-09T00:41:35-05:00","endTime":"2026-01-15T14:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":8},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532161031"},"displayPhoto":{"__ref":"PhotoInfo:532161031"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":8,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2059545222"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2059545994"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2059545997"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2059568635"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2059612897"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":{"__typename":"SocialProofInsights","isTrendingEvent":false,"totalInterestedUsers":47,"interestedUsersSample":[{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:324698921"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:255913428"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:307731880"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:192653992"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:320762906"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:53407392"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:252980428"}}]}},"Rsvp:2050266336":{"__typename":"Rsvp","id":"2050266336","member":{"__ref":"Member:417412934"}},"PhotoInfo:317289295":{"__typename":"PhotoInfo","id":"317289295","highResUrl":"https://secure.meetupstatic.com/photos/member/2/4/4/f/highres_317289295.jpeg"},"Member:400361859":{"__typename":"Member","id":"400361859","name":"Divyaraj Rana","memberPhoto":{"__ref":"PhotoInfo:317289295"}},"Rsvp:2050268268":{"__typename":"Rsvp","id":"2050268268","member":{"__ref":"Member:400361859"}},"Member:473884454":{"__typename":"Member","id":"473884454","name":"trisharane1206","memberPhoto":null},"Rsvp:2050270463":{"__typename":"Rsvp","id":"2050270463","member":{"__ref":"Member:473884454"}},"PhotoInfo:323573565":{"__typename":"PhotoInfo","id":"323573565","highResUrl":"https://secure.meetupstatic.com/photos/member/d/1/3/d/highres_323573565.jpeg"},"Member:474799920":{"__typename":"Member","id":"474799920","name":"alfred.armendariz89","memberPhoto":{"__ref":"PhotoInfo:323573565"}},"Rsvp:2050278005":{"__typename":"Rsvp","id":"2050278005","member":{"__ref":"Member:474799920"}},"Rsvp:2050305269":{"__typename":"Rsvp","id":"2050305269","member":{"__ref":"Member:414701759"}},"Event:311205522":{"__typename":"Event","id":"311205522","title":"AWS Developer Advocates Road Tour: Serverless Adventures with Darko \u0026 Aaron","eventUrl":"https://www.meetup.com/aws_chicago_western_suburbs/events/311205522/","description":"Join us for an exclusive stop on the AWS Developer Advocates Northeast \u0026 Midwest Road Tour!\n\nAWS Principal Developer Advocates **Darko Mesaros** and **Aaron Hunter** are bringing interactive workshops directly to the Chicago Western Suburbs developer community.\n\n**We're excited to announce the reactivation of the AWS Chicago Western Suburbs User Group!** Please join us in welcoming our new User Group Leader, **Vivek**, who is working hard to bring this community back together. This Developer Advocate visit marks an exciting new chapter for our group!\n\n**Featured Sessions:**\n\n**\"Trust your events: How I've built a Link shortener with serverless\"** - *Darko Mesaros*\nJoin Darko on an adventure building a link shortener using serverless and event-driven architectures. Learn about eventual consistency, Lambda functions, and get a bit Rusty!\n**\"Make your dev environment work for you!\"** - *Darko Mesaros*\nDiscover tricks every developer should know to build the most efficient dev environment. Automate builds, augment your coding experience, and aspire to leave work early!\n\n**Workshop with Aaron Hunter** - *Details coming soon!*\n\n**When:** October 11th\n\n**Where:** Amazon ORD 10 227 W Monroe St #1400, Chicago,IL 60606\n2nd Floor Conference Center via Elevator,\n**The Franklin** **A**\n\n**Instructions :** 1\\. Need to Enter at 115 Franklin St Entrance\n2\\. Should Bring Original Photo ID\n\n**What:** Interactive workshops, hands-on learning, and real-world AWS insights .This is going to be an incredible learning opportunity and a fantastic way to kick off our group's relaunch! Food, drinks, and AWS credits included!\n\n**THANK YOU** *Amazon Web Services* for sponsoring pizza! Learn more at [https://aws.amazon.com/](https://aws.amazon.com/)\n\n**Want to sponsor the pizza and/or bar tab for a future meetup?**\nPlease contact me if you would like to sponsor this meetup's pizza and/or bar : m.vivekanandha@gmail.com","isSaved":false,"group":{"__ref":"Group:18646699"},"creatorMember":{"__ref":"Member:417412934"},"eventHosts":[{"__typename":"EventHost","memberId":"417412934"}],"feeSettings":null,"venue":{"__ref":"Venue:24725840"},"dateTime":"2025-10-11T11:30:00-05:00","createdTime":"2025-09-24T14:35:30-04:00","endTime":"2025-10-11T13:00:00-05:00","going":{"__typename":"GoingRsvpConnection","totalCount":113},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:530359244"},"displayPhoto":{"__ref":"PhotoInfo:530359244"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":113,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2050266336"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2050268268"}},{"__typename":"RsvpEd