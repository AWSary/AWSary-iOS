:"GroupQuestion","id":"9678892","question":"Join our WhatsApp group: https://chat.whatsapp.com/GSXrp9gWvZH9zBxsiQo75Y","sort":3},"GroupQuestion:9680184":{"__typename":"GroupQuestion","id":"9680184","question":"Mail ID","sort":4},"GroupQuestion:9715718":{"__typename":"GroupQuestion","id":"9715718","question":"Sign Up in our Website To Redeem AWS Swags :https://www.meetup.com/aws-user-group-madurai/events/314849116/  ","sort":5},"Member:286084828":{"__typename":"Member","id":"286084828","name":"Vivek Raja","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:318364415"}},"Member:294938484":{"__typename":"Member","id":"294938484","name":"Poobalan P","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:322026489"}},"Member:394619430":{"__typename":"Member","id":"394619430","name":"S LOGESH","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:324978785"}},"Group:36938462":{"__typename":"Group","id":"36938462","name":"AWS User Group Madurai","timezone":"Asia/Kolkata","keyGroupPhoto":{"__ref":"PhotoInfo:511249480"},"urlname":"aws-user-group-madurai","isPrivate":false,"organizer":{"__ref":"Member:387062186"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":2795,"leadership":4,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.5,"total":227}},"lat":9.92,"lon":78.12,"joinMode":"OPEN","status":"PAID","city":"Madurai","state":"","country":"in","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":true,"needsPhoto":false,"questions":[{"__ref":"GroupQuestion:9581189"},{"__ref":"GroupQuestion:9581190"},{"__ref":"GroupQuestion:9678892"},{"__ref":"GroupQuestion:9680184"},{"__ref":"GroupQuestion:9715718"}],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-madurai/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"Vanakkam and welcome to the AWS User Group Madurai! We are thrilled to have you join our community of AWS enthusiasts and professionals.\u003cbr /\u003e\u003cbr /\u003eOur user group is dedicated to sharing knowledge, best practices, and experiences related to AWS services and technologies. As a member of our community, you will have the opportunity to participate in a variety of events, including meetups, workshops, hackathons, and more.\u003cbr /\u003e\u003cbr /\u003eWe believe that the strength of our community lies in our members' diverse backgrounds and expertise. Whether you're an experienced AWS professional or just getting started, we welcome your contributions and insights.\u003cbr /\u003e\u003cbr /\u003e\u003cbr /\u003eSign up in our Website - https://www.awsugmdu.in/ and start your journey in AI and Cloud with us \u003cbr /\u003eParticipate in hands-on sessions, workshops, and real-world learning experiences while earning UG Madurai Points for every step you take\u003cbr /\u003e\u003cbr /\u003eWhether you attend, participate, or contribute, your efforts get rewarded. Redeem your points for AWS swags, AWS credits, and more through our store\u003cbr /\u003e\u003cbr /\u003eJoin our Certification Circle to learn alongside experienced and certified members through guided learning, practical sessions, and hands-on experience.\u003cbr /\u003e\u003cbr /\u003e👥 Meet the Team\u003cbr /\u003eConnect with our Organizers and Co-Organizers, who are here to guide, support, and help you throughout your learning journey with the community\u003cbr /\u003eAws User Group Madurai - https://www.linkedin.com/in/awsugmdu/\u003cbr /\u003e\u003cbr /\u003eVivek Raja- https://linkedin.com/in/meetvivekraja\u003cbr /\u003eLogesh-https://www.linkedin.com/in/logeshs182/\u003cbr /\u003ePoobalan -https://www.linkedin.com/in/poobalan-p/\u003cbr /\u003e\u003cbr /\u003eThank you for joining the AWS User Group Madurai, and we look forward to getting to know you!\u003cbr /\u003e\u003cbr /\u003eBest regards,\u003cbr /\u003eVivek Raja P S\u003cbr /\u003eAWS AI HERO\u003cbr /\u003eAWS User Group Madurai Leader","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387062186"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:286084828"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:294938484"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:394619430"}}]},"description":"he AWS User Group Madurai is a community of technology enthusiasts, professionals, and students who are interested in learning and sharing knowledge about Amazon Web Services (AWS) and cloud computing. The purpose of the group is to create a platform for individuals to connect, network, and collaborate with like-minded individuals who are passionate about AWS.\nThe group is open to anyone who is interested in AWS, cloud computing, or related technologies, regardless of their level of experience or expertise. Students, professionals, entrepreneurs, and hobbyists can all benefit from joining the community, as they can learn from experienced professionals, share their own knowledge, and collaborate on projects and initiatives.\nAt the events organized by AWS User Group Madurai, members can learn about the latest trends, techniques, and best practices in AWS and cloud computing. These events can take the form of workshops, webinars, hackathons, meetups, or conferences, and are designed to provide valuable insights and hands-on experience for attendees. Members can also network with other members of the community, share their own experiences, and discuss ideas for future projects or initiatives.\nOverall, the AWS User Group Madurai provides an excellent opportunity for individuals to learn, grow, and connect with other professionals who share a common interest in AWS and cloud computing. By joining the community, members can expand their knowledge, build their professional network, and stay up-to-date with the latest trends and best practices in the field.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":1,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:315340105"}}]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":67,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:315141671"}},{"__typename":"EventEdge","node":{"__ref":"Event:315069072"}},{"__typename":"EventEdge","node":{"__ref":"Event:314947600"}},{"__typename":"EventEdge","node":{"__ref":"Event:314849116"}}]},"activeTopics":[{"__ref":"Topic:8192"},{"__ref":"Topic:120095"},{"__ref":"Topic:9696"},{"__ref":"Topic:788002"},{"__ref":"Topic:15167"},{"__ref":"Topic:15824"},{"__ref":"Topic:488822"},{"__ref":"Topic:661712"},{"__ref":"Topic:966852"},{"__ref":"Topic:1509702"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[]},"foundedDate":"2023-03-12T01:56:39+05:30","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"https://twitter.com/awsugmdu","url":"https://twitter.com/awsugmdu","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"https://instagram.com/awsugmdu","url":"https://instagram.com/awsugmdu","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387062186"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:286084828"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387147608"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:223535677"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:295887988"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:345580397"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:104365872"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:356246454"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:285764427"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:324182993"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387189735"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387226262"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:335974504"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387169405"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:250010872"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:358226769"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:200506573"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:26906060":{"__typename":"Venue","id":"26906060","name":"Online event","address":"","city":"","state":"","country":""},"PhotoInfo:534826999":{"__typename":"PhotoInfo","id":"534826999","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/b/7/9/7/highres_534826999.jpeg"},"PhotoInfo:322026489":{"__typename":"PhotoInfo","id":"322026489","highResUrl":"https://secure.meetupstatic.com/photos/member/1/9/5/9/highres_322026489.jpeg"},"Rsvp:2074757576":{"__typename":"Rsvp","id":"2074757576","member":{"__ref":"Member:294938484"}},"PhotoInfo:318364415":{"__typename":"PhotoInfo","id":"318364415","highResUrl":"https://secure.meetupstatic.com/photos/member/1/1/3/f/highres_318364415.jpeg"},"Rsvp:2074757577":{"__typename":"Rsvp","id":"2074757577","member":{"__ref":"Member:286084828"}},"PhotoInfo:324978785":{"__typename":"PhotoInfo","id":"324978785","highResUrl":"https://secure.meetupstatic.com/photos/member/4/9/6/1/highres_324978785.jpeg"},"Rsvp:2074757578":{"__typename":"Rsvp","id":"2074757578","member":{"__ref":"Member:394619430"}},"Rsvp:2074757579":{"__typename":"Rsvp","id":"2074757579","member":{"__ref":"Member:387062186"}},"PhotoInfo:322347143":{"__typename":"PhotoInfo","id":"322347143","highResUrl":"https://secure.meetupstatic.com/photos/member/6/a/0/7/highres_322347143.jpeg"},"Member:467934825":{"__typename":"Member","id":"467934825","name":"Madhu T K","memberPhoto":{"__ref":"PhotoInfo:322347143"}},"Rsvp:2074758220":{"__typename":"Rsvp","id":"2074758220","member":{"__ref":"Member:467934825"}},"Event:315340105":{"__typename":"Event","id":"315340105","title":"Claude \u0026 OpenClaw on AWS","eventUrl":"https://www.meetup.com/aws-user-group-madurai/events/315340105/","description":"# 🚀 Builders Skill Sprint: OpenClaw Month\n\n## Claude \u0026 OpenClaw on AWS\n\nJoin AWS User Group Madurai for a special **Builders Skill Sprint** dedicated to **OpenClaw Month**, where we'll explore how to build production-grade AI agents using **Claude, OpenClaw, and AWS**.\nThis session is designed for builders who want to move beyond AI demos and learn how to create scalable, autonomous agent systems that can solve real-world problems.\n\n### What You'll Learn\n\n🔹 Introduction to OpenClaw and the Agentic AI ecosystem\n🔹 Leveraging Claude for reasoning, planning, and decision-making\n🔹 Building AI agents on AWS infrastructure\n🔹 Agent orchestration, tool calling, and workflow automation\n🔹 Deploying production-ready agent applications\n🔹 Best practices for security, monitoring, and scaling\n\n### Builders Skill Sprint Highlights\n\n✅ Hands-on learning experience\n✅ Live demos and architecture walkthroughs\n✅ Open-source AI agent development practices\n✅ Real-world use cases and implementation strategies\n✅ Community networking with AWS and AI builders\n\n### Who Should Attend?\n\n* Developers and Software Engineers\n* Cloud \u0026 DevOps Professionals\n* AI/ML Enthusiasts\n* Solution Architects\n* Students and Emerging Builders","isSaved":false,"group":{"__ref":"Group:36938462"},"creatorMember":{"__ref":"Member:387062186"},"eventHosts":[{"__typename":"EventHost","memberId":"294938484"},{"__typename":"EventHost","memberId":"286084828"},{"__typename":"EventHost","memberId":"387062186"},{"__typename":"EventHost","memberId":"394619430"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-06-28T10:00:00+05:30","createdTime":"2026-06-20T05:43:58-04:00","endTime":"2026-06-28T12:00:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":46},"isOnline":true,"eventType":"ONLINE","status":"ACTIVE","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534826999"},"displayPhoto":{"__ref":"PhotoInfo:534826999"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":46,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074757576"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074757577"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074757578"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074757579"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074758220"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:534613302":{"__typename":"PhotoInfo","id":"534613302","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/3/3/f/6/highres_534613302.jpeg"},"Rsvp:2073572892":{"__typename":"Rsvp","id":"2073572892","member":{"__ref":"Member:294938484"}},"Rsvp:2073572894":{"__typename":"Rsvp","id":"2073572894","member":{"__ref":"Member:286084828"}},"Rsvp:2073572895":{"__typename":"Rsvp","id":"2073572895","member":{"__ref":"Member:394619430"}},"PhotoInfo:325691381":{"__typename":"PhotoInfo","id":"325691381","highResUrl":"https://secure.meetupstatic.com/photos/member/2/c/7/5/highres_325691381.jpeg"},"Member:479137599":{"__typename":"Member","id":"479137599","name":"NAVEENSRI V","memberPhoto":{"__ref":"PhotoInfo:325691381"}},"Rsvp:2073591353":{"__typename":"Rsvp","id":"2073591353","member":{"__ref":"Member:479137599"}},"PhotoInfo:325418095":{"__typename":"PhotoInfo","id":"325418095","highResUrl":"https://secure.meetupstatic.com/photos/member/9/4/c/f/highres_325418095.jpeg"},"Member:342399886":{"__typename":"Member","id":"342399886","name":"Pritesh Kiri","memberPhoto":{"__ref":"PhotoInfo:325418095"}},"Rsvp:2073598015":{"__typename":"Rsvp","id":"2073598015","member":{"__ref":"Member:342399886"}},"Event:315141671":{"__typename":"Event","id":"315141671","title":"Strands Agents Workshop ","eventUrl":"https://www.meetup.com/aws-user-group-madurai/events/315141671/","description":"🚀 Strands Agents Workshop \u0026 Challenge Sprint 🚀\n\nHello Everyone!\nAWS CLOUD CHAMP CLUB AS PES is excited to conduct a workshop on Strands Agents, the latest AWS technology which enables developers to build intelligent AI agents\n\n📅 Date 11th June, 2026\n⏰ Time: 5:30 PM\n📍 Mode: Virtual (Online)\n\nWhether you're a student, developer, or a person who has some interest in artificial intelligence, you would definitely love to explore the exciting world of AWS Strands agents\n\nWhat you will learn:\n🔹 Build AI agents using the Strands SDK\n🔹 Integrate AWS services and AI models\n🔹 Explore memory, guardrails, observability, and MCP tools\n🔹 Complete 5 hands-on challenges and showcase your implementation skills\n\nWhy should you join the challenge?\nBuilding agentic AI applications is the future. Participating in this sprint will make you understand how to develop AI agents by integrating cloud services and AI models\n\n🏆 Finish all the 5 challenges, submit your solution via the user group website, earn community points and be recognized in AWS community!\n🌟 Join us and become one of the agentic AI leaders!","isSaved":false,"group":{"__ref":"Group:36938462"},"creatorMember":{"__ref":"Member:394619430"},"eventHosts":[{"__typename":"EventHost","memberId":"294938484"},{"__typename":"EventHost","memberId":"286084828"},{"__typename":"EventHost","memberId":"394619430"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-06-11T17:30:00+05:30","createdTime":"2026-06-07T00:10:29-04:00","endTime":"2026-06-11T20:30:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":37},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534613302"},"displayPhoto":{"__ref":"PhotoInfo:534613302"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":37,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073572892"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073572894"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073572895"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073591353"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073598015"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:534537171":{"__typename":"PhotoInfo","id":"534537171","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/d/f/5/3/highres_534537171.jpeg"},"Rsvp:2073098141":{"__typename":"Rsvp","id":"2073098141","member":{"__ref":"Member:294938484"}},"Rsvp:2073098142":{"__typename":"Rsvp","id":"2073098142","member":{"__ref":"Member:286084828"}},"Rsvp:2073098143":{"__typename":"Rsvp","id":"2073098143","member":{"__ref":"Member:394619430"}},"Member:479711520":{"__typename":"Member","id":"479711520","name":"Sivanivetha S","memberPhoto":null},"Rsvp:2073107771":{"__typename":"Rsvp","id":"2073107771","member":{"__ref":"Member:479711520"}},"Member:480059193":{"__typename":"Member","id":"480059193","name":"dd388301","memberPhoto":null},"Rsvp:2073107782":{"__typename":"Rsvp","id":"2073107782","member":{"__ref":"Member:480059193"}},"Event:315069072":{"__typename":"Event","id":"315069072","title":"From Zero to AI Agent Builder","eventUrl":"https://www.meetup.com/aws-user-group-madurai/events/315069072/","description":"From Zero to AI Agent Builder\nA hands-on learning session designed to help students understand how modern AI Agents are built using AWS technologies, memory systems, tool calling, streaming responses, and knowledge retrieval.\nThis session is based on the complete AWS Builders Skill Sprint journey, where participants will explore the evolution of AI agents from simple local assistants to intelligent knowledge-powered systems.\nUnlike traditional AI workshops that focus only on concepts, this session emphasizes practical learning, real-world architecture understanding, and live demonstrations of AI agent capabilities.\n\nEVENT HIGHLIGHTS\n• Build Your First AI Agent using Ollama\n• Learn Tool Calling with Amazon Bedrock and Nova Pro\n• Understand Persistent Memory using Mem0 and FAISS\n• Explore Streaming AI Responses\n• Introduction to MCP (Model Context Protocol)\n• Build a Knowledge-Powered AI Assistant\n• Real-World AI Agent Architecture Walkthrough\n• AWS Builders Skill Sprint Experience Sharing\n\nEVENT DETAILS\nDate: 03 June 2026\nTime: 08:00 PM to 09:30 PM\nMode: Online Session (Google Meet)\nSPEAKERS\nThamaraikannan G\nHarini G\n\nTECHNOLOGIES COVERED\n• Amazon Bedrock\n• Amazon Nova Pro\n• Mem0\n• FAISS Vector Store\n• Streaming Responses\n• MCP (Model Context Protocol)\n• Strands SDK\n• Ollama\n• AI Agents\n• Knowledge Retrieval Systems\n\nWHY ATTEND?\n• Learn AI Agent Development from Scratch\n• Understand Real-World AI Architectures\n• Explore AWS-Powered Generative AI\n• Learn Memory, Tools, and Streaming Concepts\n• Get Hands-On Exposure to AI Agent Workflows\n• Discover How Modern AI Assistants Are Built\n• Learn from a Complete End-to-End Project Journey\n\nWHO CAN ATTEND?\n• Beginners interested in AI\n• AWS and Cloud Enthusiasts\n• Students exploring Generative AI\n• Developers interested in AI Agents\n• Anyone curious about building intelligent applications\nDon't just use AI. Learn how to build intelligent AI Agents from the ground up.","isSaved":false,"group":{"__ref":"Group:36938462"},"creatorMember":{"__ref":"Member:394619430"},"eventHosts":[{"__typename":"EventHost","memberId":"294938484"},{"__typename":"EventHost","memberId":"286084828"},{"__typename":"EventHost","memberId":"394619430"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-06-03T20:10:00+05:30","createdTime":"2026-06-02T09:13:32-04:00","endTime":"2026-06-03T22:10:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":41},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534537171"},"displayPhoto":{"__ref":"PhotoInfo:534537171"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":41,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073098141"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073098142"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073098143"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073107771"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073107782"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Rsvp:2072380759":{"__typename":"Rsvp","id":"2072380759","member":{"__ref":"Member:294938484"}},"Rsvp:2072380761":{"__typename":"Rsvp","id":"2072380761","member":{"__ref":"Member:286084828"}},"Rsvp:2072380762":{"__typename":"Rsvp","id":"2072380762","member":{"__ref":"Member:394619430"}},"Member:477742180":{"__typename":"Member","id":"477742180","name":"Mugunthan S","memberPhoto":null},"Rsvp:2072380865":{"__typename":"Rsvp","id":"2072380865","member":{"__ref":"Member:477742180"}},"Member:479146951":{"__typename":"Member","id":"479146951","name":"SRI GANTH K ","memberPhoto":null},"Rsvp:2072380963":{"__typename":"Rsvp","id":"2072380963","member":{"__ref":"Member:479146951"}},"Event:314947600":{"__typename":"Event","id":"314947600","title":"Build You Own Agents","eventUrl":"https://www.meetup.com/aws-user-group-madurai/events/314947600/","description":"We are excited to invite you all to an interactive session on Building AI Agents using AWS Bedrock, Nova \u0026 Strands SDK as part of the Builders Skill Sprint Challenge\n\nIn this session, we’ll discuss:\n✨ What are AI Agents?\n✨ Ollama \u0026 Local AI Models\n✨ Amazon Bedrock \u0026 Nova Pro\n✨ Memory + Tool Calling\n✨ MCP (Model Context Protocol)\n✨ How to participate in the challenge and build your own AI Agent project\n\n📅 Date: 25/05/2026\n⏰ Time: 8:00 PM – 9:00 PM\n\n🎤 Speakers:\n•⁠ ⁠THAMARAIKANNAN G – College Champ Captain\n•⁠ ⁠HARINI G – College Champ Vice Captain\n\nThis session will help you understand modern AI Agent development and guide you to start building projects using AWS technologies 🚀\nDon’t miss it! See you all at the session 🔥","isSaved":false,"group":{"__ref":"Group:36938462"},"creatorMember":{"__ref":"Member:394619430"},"eventHosts":[{"__typename":"EventHost","memberId":"294938484"},{"__typename":"EventHost","memberId":"286084828"},{"__typename":"EventHost","memberId":"394619430"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-05-25T20:15:00+05:30","createdTime":"2026-05-25T09:44:38-04:00","endTime":"2026-05-25T22:15:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":31},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:511249480"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":31,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072380759"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072380761"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072380762"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072380865"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072380963"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:534361458":{"__typename":"PhotoInfo","id":"534361458","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/5/b/2/highres_534361458.jpeg"},"Rsvp:2071830341":{"__typename":"Rsvp","id":"2071830341","member":{"__ref":"Member:387062186"}},"Rsvp:2071830342":{"__typename":"Rsvp","id":"2071830342","member":{"__ref":"Member:294938484"}},"Rsvp:2071830344":{"__typename":"Rsvp","id":"2071830344","member":{"__ref":"Member:394619430"}},"Rsvp:2071830345":{"__typename":"Rsvp","id":"2071830345","member":{"__ref":"Member:286084828"}},"PhotoInfo:319003830":{"__typename":"PhotoInfo","id":"319003830","highResUrl":"https://secure.meetupstatic.com/photos/member/a/b/3/6/highres_319003830.jpeg"},"Member:183094352":{"__typename":"Member","id":"183094352","name":"Sai Prasad Kandavalli ","memberPhoto":{"__ref":"PhotoInfo:319003830"}},"Rsvp:2071831253":{"__typename":"Rsvp","id":"2071831253","member":{"__ref":"Member:183094352"}},"Event:314849116":{"__typename":"Event","id":"314849116","title":"Builders Skill Sprint – DevOps Month 2026","eventUrl":"https://www.meetup.com/aws-user-group-madurai/events/314849116/","description":"🚀 AWS User Group Madurai \\| Builders Skill Sprint – May Edition: DevOps Month 🛠️\n\nThis May, we are diving deep into the intersection of cloud operations, intelligent automation, and agentic workflows. Learn how to leverage the AWS DevOps Agent from foundational incident response to advanced private enterprise integrations! 💥\n\n📍 Checkpoint 1: The Learning Sprint\n\n1️⃣ AI-Powered Incident Response with AWS DevOps Agent\nSpeaker: Omshree Butani\nLeverage AWS DevOps Agent to detect anomalies, automate root-cause analysis, and streamline workflows for high availability.\n\n2️⃣ Building Private MCP Servers on AWS: Integrating Custom Capabilities with AWS DevOps Agent\nSpeaker: Srinivasan chinnaswamy\nSecurely connect AWS DevOps Agent to private internal networks using custom MCP servers, JSON-RPC 2.0 and secure architectures.\n\n📅 Date: 24th May 2026, Sunday\n🕙 Time: 10:00 AM IST Onwards\n🔗 Register Here: https://www.meetup.com/aws-user-group-madurai/events/314849116/\n\nOur Website -[https://www.awsugmdu.in/](https://www.awsugmdu.in/)\nJoin Now, get Points and Redeem AWS Swags\n\n💡 What You’ll Learn:\n✅ Transitioning from manual debugging to AI-agent-assisted workflows with AWS DevOps Agent.\n✅ Registering private MCP servers with AWS DevOps Agent using Lambda and VPC Endpoints.\n✅ Practical debugging strategies for agent connectivity, SigV4, and IAM errors.\n\n👥 Who Should Attend?\nDevOps engineers, cloud architects, developers, security enthusiasts, and students looking to master advanced agentic architectures on AWS!\n\n🎯 How to Sprint with Us:\n🧭 Learn from experts\n🛠️ Build the post-session challenge\n✍️ Create \u0026 share insights\n🏅 Earn exclusive swag \u0026 climb the leaderboard!","isSaved":false,"group":{"__ref":"Group:36938462"},"creatorMember":{"__ref":"Member:387062186"},"eventHosts":[{"__typename":"EventHost","memberId":"294938484"},{"__typename":"EventHost","memberId":"286084828"},{"__typename":"EventHost","memberId":"387062186"},{"__typename":"EventHost","memberId":"394619430"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-05-24T10:00:00+05:30","createdTime":"2026-05-18T14:04:36-04:00","endTime":"2026-05-24T12:00:00+05:30","going":{"__typename":"GoingRsvpConnection",