ine events","footer.localGuides":"Local guides","footer.makeFriendsLp":"Make friends","footer.sitemap":"Sitemap","footer.meetupText":"Meetup","footer.about":"About","footer.blog":"Blog","footer.meetupPro":"Meetup Pro","footer.careers":"Careers","footer.apps":"Apps","footer.podcast":"Podcast","footer.followUs":"Follow us","footer.getTheApp":"Get the app","mobileDownloadButtons.downloadFromGooglePlay":"Download app from Google Play","mobileDownloadButtons.downloadFromAppStore":"Download app from App Store","mobileDownloadButtons.downloadOnStore":"Download on","footer.meetupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Terms of service","footer.privacyPolicy":"Privacy policy","footer.cookiePolicy":"Cookie policy","footer.licenseAttribution":"License attribution","footer.madeWithLoveBy":"Made with {love} by"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:317430576":{"__typename":"PhotoInfo","id":"317430576","highResUrl":"https://secure.meetupstatic.com/photos/member/7/7/7/0/highres_317430576.jpeg"},"Member:388281225":{"__typename":"Member","id":"388281225","name":"Anton Antanovich","email":"","memberPhoto":{"__ref":"PhotoInfo:317430576"},"isSuperOrganizer":false},"PhotoInfo:519460254":{"__typename":"PhotoInfo","id":"519460254","highResUrl":"https://secure.meetupstatic.com/photos/event/9/d/3/e/highres_519460254.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Member:247174718":{"__typename":"Member","id":"247174718","name":"Grzegorz Kalwig","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:319235891"}},"Group:36964244":{"__typename":"Group","id":"36964244","name":"AWS User Group 3City","timezone":"Europe/Warsaw","keyGroupPhoto":{"__ref":"PhotoInfo:519460254"},"urlname":"aws-user-group-3city","isPrivate":false,"organizer":{"__ref":"Member:388281225"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":859,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.68,"total":92}},"lat":54.36,"lon":18.64,"joinMode":"OPEN","status":"PAID","city":"Gdansk","state":"","country":"pl","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":false,"needsPhoto":false,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-3city/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"Nice to have you! \n\nHere you can find all our platforms https://linktr.ee/AWS3city\nIf you have any ideas for collaboration, want to be a speaker or a sponsor just send us a mail to info@aws3.city\n\nBest regard,\nAnton","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:388281225"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:247174718"}}]},"description":"**Welcome to AWS User Group 3city! (Gdansk, Sopot, Gdynia)**\nHello there! Dive into our community where we share and learn about Amazon Web Services, cloud computing, AI, and DevOps. Whether you're a pro or just getting started, we'd love to have you!\n\nWe mainly communicate in English to ensure everyone feels included.\n\n**Let's Collaborate:**\n\n* **Speakers**: Got insights? Come share with us!\n* **Partners**: Have a venue or can help with catering? Let's team up. We're open to hosting events together.\n\n**Stay connected:**\n\n* WeAreCommunity: [Link](https://wearecommunity.io/communities/aws3city)\n* Telegram: [Link](https://t.me/AWS_UG_3City)\n* LinkedIn: [Link](https://www.linkedin.com/groups/9385575/)","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":25,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:313540850"}},{"__typename":"EventEdge","node":{"__ref":"Event:312350780"}},{"__typename":"EventEdge","node":{"__ref":"Event:310517266"}},{"__typename":"EventEdge","node":{"__ref":"Event:308388587"}}]},"activeTopics":[{"__ref":"Topic:188"},{"__ref":"Topic:15167"},{"__ref":"Topic:19297"},{"__ref":"Topic:51156"},{"__ref":"Topic:87614"},{"__ref":"Topic:110474"},{"__ref":"Topic:117019"},{"__ref":"Topic:661712"},{"__ref":"Topic:1508781"},{"__ref":"Topic:1518546"},{"__ref":"Topic:126177"},{"__ref":"Topic:1519673"},{"__ref":"Topic:753702"},{"__ref":"Topic:46810"},{"__ref":"Topic:124668"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7038582"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7038584"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7039485"}}]},"foundedDate":"2023-03-26T10:34:50+02:00","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"https://www.linkedin.com/groups/9385575/","url":"https://www.linkedin.com/groups/9385575/","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"https://wearecommunity.io/communities/aws3city","url":"https://wearecommunity.io/communities/aws3city","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:388281225"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:388286177"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:298087723"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:207653993"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:386649807"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:305713428"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:204804881"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:358527128"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:277555107"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:185992711"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:377710687"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:261859388"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:348097465"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:198861931"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:357092796"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:257067281"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:377835098"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:25138978":{"__typename":"Venue","id":"25138978","name":"Pomorski Park Naukowo-Technologiczny","address":"aleja Zwycięstwa 96/98","city":"Gdynia","state":"","country":"pl"},"PhotoInfo:532927877":{"__typename":"PhotoInfo","id":"532927877","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/1/e/c/5/highres_532927877.jpeg"},"Rsvp:2064065760":{"__typename":"Rsvp","id":"2064065760","member":{"__ref":"Member:388281225"}},"PhotoInfo:319235891":{"__typename":"PhotoInfo","id":"319235891","highResUrl":"https://secure.meetupstatic.com/photos/member/8/c/3/3/highres_319235891.jpeg"},"Rsvp:2064065763":{"__typename":"Rsvp","id":"2064065763","member":{"__ref":"Member:247174718"}},"PhotoInfo:311410451":{"__typename":"PhotoInfo","id":"311410451","highResUrl":"https://secure.meetupstatic.com/photos/member/2/8/d/3/highres_311410451.jpeg"},"Member:365580316":{"__typename":"Member","id":"365580316","name":"Micheal Onyemelonu","memberPhoto":{"__ref":"PhotoInfo:311410451"}},"Rsvp:2064068917":{"__typename":"Rsvp","id":"2064068917","member":{"__ref":"Member:365580316"}},"PhotoInfo:274268305":{"__typename":"PhotoInfo","id":"274268305","highResUrl":"https://secure.meetupstatic.com/photos/member/2/0/7/1/highres_274268305.jpeg"},"Member:247096405":{"__typename":"Member","id":"247096405","name":"Oleksandr Barbul","memberPhoto":{"__ref":"PhotoInfo:274268305"}},"Rsvp:2064069246":{"__typename":"Rsvp","id":"2064069246","member":{"__ref":"Member:247096405"}},"Member:455678169":{"__typename":"Member","id":"455678169","name":"Mr. V","memberPhoto":null},"Rsvp:2064069916":{"__typename":"Rsvp","id":"2064069916","member":{"__ref":"Member:455678169"}},"Event:313540850":{"__typename":"Event","id":"313540850","title":"AWS Community GameDay Europe","eventUrl":"https://www.meetup.com/aws-user-group-3city/events/313540850/","description":"Join us for **AWS Community GameDay Europe** — a **unique, large-scale, synchronized pan-European AWS challenge**! This hybrid community event brings together \\~50 AWS User Groups across Europe to solve **real-world cloud challenges** in a fun, hands-on, team-based competition.\n\n👉 More info on the official site: **[https://www.awsgameday.eu/](https://www.awsgameday.eu/?utm_source=chatgpt.com)**\n\n📍 Location: Pomorski Park Naukowo-Technologiczny **Building IV Room F0.02**\naleja Zwycięstwa 96/98, Gdynia\n\n## 🧠 What is AWS GameDay?\n\nAWS GameDay is an **interactive, gamified learning experience** where small teams (2–4 people):\n\n* Compete head-to-head against teams across Europe\n* Work through real cloud scenarios on AWS\n* Solve challenges without step-by-step instructions\n* Use real AWS services to architect, debug, optimize, and deploy solutions\n\nThis isn’t a workshop — it’s **hands-on, unpredictable, fun, and competitive**!\n\n## 🎯 Why Attend?\n\n✔️ **Develop real AWS skills** in a safe, gamified environment\n✔️ **Collaborate with peers** from Gdynia \u0026 across Europe\n✔️ Compete for **prizes** 💸 — **local and global winners will be recognized**\n✔️ Have fun with snacks, networking, and a shared experience with the AWS community\n*Prizes will be awarded to top scoring teams at the **European closing ceremony**.*\n\n## 🧩 Format\n\n* ⏱ **Duration:** \\~2 hours of gameplay\n* 👥 **Teams:** 2–4 players (form your own or join one on site)\n* 💻 **Bring:** Laptop (internet provided)\n* 🌍 AWS **accounts provided on site** — no personal AWS account required\n\n## 📅 Agenda (approx.)\n\n* **17:30–18:00** – Arrival \u0026 team formation\n* **18:00–18:20** – Intro \u0026 live stream kickoff\n* **18:20–20:30** – GameDay challenges\n* **20:30–20:45** – European closing ceremony + prizes\n\n## 🎉 Who Should Join?\n\nEveryone with basic AWS knowledge!\nWhether you’re a developer, architect, devops engineer, or cloud curious — GameDay is a **fun way to test your skills and learn**.","isSaved":false,"group":{"__ref":"Group:36964244"},"creatorMember":{"__ref":"Member:388281225"},"eventHosts":[{"__typename":"EventHost","memberId":"247174718"},{"__typename":"EventHost","memberId":"388281225"}],"feeSettings":null,"venue":{"__ref":"Venue:25138978"},"dateTime":"2026-03-17T17:30:00+01:00","createdTime":"2026-02-26T10:33:49-05:00","endTime":"2026-03-17T20:30:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":17},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532927877"},"displayPhoto":{"__ref":"PhotoInfo:532927877"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":17,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064065760"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064065763"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064068917"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064069246"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064069916"}}]},"maxTickets":20,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:26268421":{"__typename":"Venue","id":"26268421","name":"O4 Coworking","address":"Aleja Grunwaldzka 472B","city":"Gdańsk","state":"","country":"pl"},"PhotoInfo:531689381":{"__typename":"PhotoInfo","id":"531689381","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/7/2/c/5/highres_531689381.jpeg"},"Rsvp:2056993162":{"__typename":"Rsvp","id":"2056993162","member":{"__ref":"Member:247174718"}},"Rsvp:2056993164":{"__typename":"Rsvp","id":"2056993164","member":{"__ref":"Member:388281225"}},"PhotoInfo:324504482":{"__typename":"PhotoInfo","id":"324504482","highResUrl":"https://secure.meetupstatic.com/photos/member/5/f/a/2/highres_324504482.jpeg"},"Member:473454653":{"__typename":"Member","id":"473454653","name":"Aytan Asadova","memberPhoto":{"__ref":"PhotoInfo:324504482"}},"Rsvp:2057013889":{"__typename":"Rsvp","id":"2057013889","member":{"__ref":"Member:473454653"}},"PhotoInfo:324504484":{"__typename":"PhotoInfo","id":"324504484","highResUrl":"https://secure.meetupstatic.com/photos/member/5/f/a/4/highres_324504484.jpeg"},"Member:475898300":{"__typename":"Member","id":"475898300","name":"Sabina Abbasova","memberPhoto":{"__ref":"PhotoInfo:324504484"}},"Rsvp:2057014547":{"__typename":"Rsvp","id":"2057014547","member":{"__ref":"Member:475898300"}},"Member:473931893":{"__typename":"Member","id":"473931893","name":"Uladzislau Yatsun","memberPhoto":null},"Rsvp:2057014686":{"__typename":"Rsvp","id":"2057014686","member":{"__ref":"Member:473931893"}},"Event:312350780":{"__typename":"Event","id":"312350780","title":"AWS UserGroup 3City Meetup #13","eventUrl":"https://www.meetup.com/aws-user-group-3city/events/312350780/","description":"Join our next AWS User Group 3city meetup! 🚀\nWe’re bringing you the hottest highlights straight from **AWS re:Invent 2025** in Las Vegas.\nDiscover the latest AWS announcements and innovations — explained from a practical engineering perspective by experts working with cloud every day.\nThis edition is fully **offline** — meet us in Gdańsk for great tech insights, pizza 🍕, beer 🍺 and networking with the local AWS community!\n\n**📍 Event details**\n☁️ **Date \u0026 time:** 16 December 2025, 17:00\n☁️ **Format:** Technical panel + pizza \u0026 networking\n☁️ **Venue:** O4 COWORKING, al. Grunwaldzka 472B, Gdańsk\n☁️ **Cost:** Free to attend — **register below** 👇\n\n**➖➖➖ AGENDA ➖➖➖**\n\n👉 **“AWS re:Invent 2025 re:Cap”**\n**Panel discussion** with:\n• **Anton Antanovich** – Lead Systems Engineer @ EPAM\n• **Grzegorz Kalwig** – System Architect @ Univio\nA fast-paced overview of the most important and impactful news from AWS re:Invent — what you can take advantage of right now, and what trends are shaping the future of AWS.\n\n📌 **Note:**\nThis event is **in-person only** — no livestream.\n\nJoin us to learn, connect and stay ahead in the cloud! ☁️💙","isSaved":false,"group":{"__ref":"Group:36964244"},"creatorMember":{"__ref":"Member:247174718"},"eventHosts":[{"__typename":"EventHost","memberId":"247174718"},{"__typename":"EventHost","memberId":"388281225"}],"feeSettings":null,"venue":{"__ref":"Venue:26268421"},"dateTime":"2025-12-16T17:00:00+01:00","createdTime":"2025-12-08T05:58:22-05:00","endTime":"2025-12-16T20:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":44},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:531689381"},"displayPhoto":{"__ref":"PhotoInfo:531689381"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":44,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2056993162"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2056993164"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2057013889"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2057014547"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2057014686"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:529628117":{"__typename":"PhotoInfo","id":"529628117","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/1/f/b/5/highres_529628117.jpeg"},"Rsvp:2046169874":{"__typename":"Rsvp","id":"2046169874","member":{"__ref":"Member:388281225"}},"Rsvp:2046169875":{"__typename":"Rsvp","id":"2046169875","member":{"__ref":"Member:247174718"}},"PhotoInfo:243900014":{"__typename":"PhotoInfo","id":"243900014","highResUrl":"https://secure.meetupstatic.com/photos/member/e/highres_243900014.jpeg"},"Member:182976487":{"__typename":"Member","id":"182976487","name":"Łukasz Gajdak","memberPhoto":{"__ref":"PhotoInfo:243900014"}},"Rsvp:2046170968":{"__typename":"Rsvp","id":"2046170968","member":{"__ref":"Member:182976487"}},"Member:449358712":{"__typename":"Member","id":"449358712","name":"Erwin","memberPhoto":null},"Rsvp:2046171116":{"__typename":"Rsvp","id":"2046171116","member":{"__ref":"Member:449358712"}},"Member:406475577":{"__typename":"Member","id":"406475577","name":"Alexander Rychkov","memberPhoto":null},"Rsvp:2046171558":{"__typename":"Rsvp","id":"2046171558","member":{"__ref":"Member:406475577"}},"Event:310517266":{"__typename":"Event","id":"310517266","title":"AWS Community Day Baltic 2025","eventUrl":"https://www.meetup.com/aws-user-group-3city/events/310517266/","description":"First ever **AWS Community Day Baltic** – registration is now open!\n\nMore info [https://awsbaltic.eu](https://awsbaltic.eu)\n\nGet ready for a full day of cloud knowledge, real-world use cases, and networking with AWS enthusiasts, builders \u0026 pros.\n📍 When \u0026 where: 10 September 2025 \\| Gdynia\\, Poland 🇵🇱\n🎟 Entry is free, but spots are limited.\nPlease register only if you're committed to coming, so we can make room for everyone. 🙏\n\n🔗 Register here: https://awsbaltic.eventbrite.co.uk/?aff=meetup – secure your seat and join a truly community-driven experience!\n\n**Below is a list of our amazing speakers:**\n\n* **[Viktor Vedmich](https://www.linkedin.com/in/vedmich/)** \\- Senior Developer Advocate at AWS\\, Munich\\, Germany\n* **[Vadym Kazulkin](https://www.linkedin.com/in/vadymkazulkin/) -** AWS Hero, Head of Development at ip.labs in Bonn, Germany\n* **[Suzana Melo](https://sessionize.com/suzana-melo)** \\- Software Developer\\, Women in Tech advocate\\, AWS Community Builder\\, Malmo\\, Sweden\n* **[Socrates Ruiz](https://www.linkedin.com/in/socrates-ruiz-s/)** \\- AWS Community Builder\\, Principal Cloud Architect at Data Insights\\, Munich\\, Germany\n* **[Noe Sedeno](https://www.linkedin.com/in/noe-s-5b956478/)** \\- DevOps Enthusiastic\\, Munich\\, Germany\n* **[Irine Kokilashvili](https://www.linkedin.com/in/irine-kokilashvili/)** \\- Platform Engineer at Space International\\, Tbilisi\\, Georgia\n* **[Kirill Solovei](https://www.linkedin.com/in/hatedabamboo/)**[ ](https://www.linkedin.com/in/hatedabamboo/)\\- AWS Community Builder\\, Senior Systems Engineer\\, Gdansk\\, Poland\n* **[Szymon Sołtys](https://www.linkedin.com/in/szymonsoltys/)**[ ](https://www.linkedin.com/in/szymonsoltys/)\\- AWS Community Builder\\, Senior DevOps Engineer\\, Transition Technologies\\, Wrocław\\, Poland\n* **[Asia Chojnacka](https://www.linkedin.com/in/joanna-chojnacka-333a03217/)** \\- AWS Community Builder\\, Senior Software Engineer \u0026 Cloud Community Leader at Capgemini\\, Wrocław\\, Poland\n* **[Jakub Gaj](https://www.linkedin.com/in/jakubgaj/) -** AWS Community Builder, Senior Cloud Architect, Copenhagen, Denmark\n* **[Przemysław Chmielecki, PhD](https://www.linkedin.com/in/pchmielecki87/)** **-** Multi cloud Architect at EPAM, Warsaw, Poland\n* **[Przemysław Mikulski](https://www.linkedin.com/in/przemyslaw-mikulski/) -** Co-Founder, Data and Cloud Architect, Kodlot ApS, Copenhagen, Denmark\n* **[Martin Hauskrecht](https://sessionize.com/martin-hauskrecht)** \\- Head of Engineering at Labyrinth Labs\\, Bratislava\\, Slovakia\n* **[Stefano Amorelli](https://sessionize.com/stefano-amorelli)** \\- Staff Software Engineer\\,AI\\, Tallinn\\, Estonia","isSaved":false,"group":{"__ref":"Group:36964244"},"creatorMember":{"__ref":"Member:388281225"},"eventHosts":[{"__typename":"EventHost","memberId":"247174718"},{"__typename":"EventHost","memberId":"388281225"}],"feeSettings":null,"venue":{"__ref":"Venue:25138978"},"dateTime":"2025-09-10T09:00:00+02:00","createdTime":"2025-08-14T06:53:55-04:00","endTime":"2025-09-10T18:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":16},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:529628117"},"displayPhoto":{"__ref":"PhotoInfo:529628117"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":16,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2046169874"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2046169875"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2046170968"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2046171116"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2046171558"}}]},"maxTickets":200,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:528480456":{"__typename":"PhotoInfo","id":"528480456","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/1/c/8/highres_528480456.jpeg"},"Rsvp:2038008281":{"__typename":"Rsvp","id":"2038008281","member":{"__ref":"Member:247174718"}},"Rsvp:2038008282":{"__typename":"Rsvp","id":"2038008282","member":{"__ref":"Member:388281225"}},"PhotoInfo:309914818":{"__typename":"PhotoInfo","id":"309914818","highResUrl":"https://secure.meetupstatic.com/photos/member/3/9/e/2/highres_309914818.jpeg"},"Member:358246655":{"__typename":"Member","id":"358246655","name":"Aleksandra Szmurło","memberPhoto":{"__ref":"PhotoInfo:309914818"}},"Rsvp:2038009728":{"__typename":"Rsvp","id":"2038009728","member":{"__ref":"Member:358246655"}},"Rsvp:2038009748":{"__typename":"Rsvp","id":"2038009748","member":{"__ref":"Member:247096405"}},"PhotoInfo:278201231":{"__typename":"PhotoInfo","id":"278201231","highResUrl":"https://secure.meetupstatic.com/photos/member/a/1/0/f/highres_278201231.jpeg"},"Member:257067281":{"__typename":"Member","id":"257067281","name":"Faten Rostom","memberPhoto":{"__ref":"PhotoInfo:278201231"}},"Rsvp:2038009821":{"__typename":"Rsvp","id":"2038009821","member":{"__ref":"Member:257067281"}},"Event:308388587":{"__typename":"Event","id":"308388587","title":"AWS UserGroup 3City Meetup #12","eventUrl":"https://www.meetup.com/aws-user-group-3city/events/308388587/","description":"Join us on June 24, 2025, for the next AWS User Group 3city meetup — this time with two deep-dive sessions into scaling EKS and game development on AWS!\n\nAs always, you can expect hands-on knowledge, real-life examples, good conversations, pizza 🍕, and networking with fellow cloud enthusiasts. 🚀\n\n**Agenda**\n\n**👉 \"EKS without Karpenter or Cluster Autoscaler\"**\n**by Bartosz Piasecki, AWS DevOps Technical Leader @ SoftServe**\nDiscover how to scale Amazon EKS nodes without relying on external solutions like Karpenter or Cluster Autoscaler.\nBartosz will showcase a production-proven approach that leverages warm pools in Auto Scaling Groups — ideal for environments with specific EC2 instance requirements.\nLearn the benefits, limitations, and practical tips for using this method in your own EKS setups.\n\n**👉 \"Game Development and Hosting on AWS\"**\n**by Grzegorz Ochmański, AWS for Games Senior Solutions Architect @ AWS**\nAWS isn't just for business apps — it’s also powering many of your favorite game titles!\nGrzegorz will give us a behind-the-scenes look at how game development, deployment, and scalable game server hosting is done on AWS.\nWhether you’re a game developer or just curious how the cloud meets the gaming world — this session is for you.\n\n**Event Details**\n\n**WHEN:** June 24, 2025, from 5:00 PM\n**WHERE:** O4 Coworking, al. Grunwaldzka 47B, Gdańsk\n**WHAT:** 2 technical talks + pizza \u0026 drinks + networking\n**COST:** Free of charge\n\nAs always — great talks, good vibes.\nRegister now and join us! 🚀","isSaved":false,"group":{"__ref":"Group:36964244"},"creatorMember":{"__ref":"Member:247174718"},"eventHosts":[{"__typename":"EventHost","memberId":"247174718"},{"__typename":"EventHost","memberId":"388281225"}],"feeSettings":null,"venue":{"__ref":"Venue:26268421"},"dateTime":"2025-06-24T17:00:00+02:00","createdTime":"2025-06-09T02:58:24-04:00","endTime":"2025-06-24T20:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":39},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:528480456"},"displayPhoto":{"__ref":"PhotoInfo:528480456"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":39,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2038008281"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2038008282"}},{"__typename":"Rsv