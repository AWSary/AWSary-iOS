"GroupMemberEdge","node":{"__ref":"Member:62686982"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:184464305"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:41102332"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:209473091"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:47857842"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:188242812"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:196920496"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:174890432"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:194800896"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:101007112"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:14086410"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:25715073":{"__typename":"Venue","id":"25715073","name":"Endava","address":"str. Palat nr. 3B, clădirea E5 - parter (Complex Palas)","city":"Iasi","state":"","country":"ro"},"Rsvp:2073204790":{"__typename":"Rsvp","id":"2073204790","member":{"__ref":"Member:222577274"}},"PhotoInfo:325112319":{"__typename":"PhotoInfo","id":"325112319","highResUrl":"https://secure.meetupstatic.com/photos/member/7/e/3/f/highres_325112319.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:14510953":{"__typename":"Member","id":"14510953","name":"Dragos Madarasan","memberPhoto":{"__ref":"PhotoInfo:325112319"}},"Rsvp:2073204791":{"__typename":"Rsvp","id":"2073204791","member":{"__ref":"Member:14510953"}},"PhotoInfo:258314761":{"__typename":"PhotoInfo","id":"258314761","highResUrl":"https://secure.meetupstatic.com/photos/member/3/9/a/9/highres_258314761.jpeg"},"Member:208929487":{"__typename":"Member","id":"208929487","name":"Sabin Nemtisor","memberPhoto":{"__ref":"PhotoInfo:258314761"}},"Rsvp:2073206649":{"__typename":"Rsvp","id":"2073206649","member":{"__ref":"Member:208929487"}},"PhotoInfo:287885549":{"__typename":"PhotoInfo","id":"287885549","highResUrl":"https://secure.meetupstatic.com/photos/member/1/5/a/d/highres_287885549.jpeg"},"Member:239029248":{"__typename":"Member","id":"239029248","name":"Raluca","memberPhoto":{"__ref":"PhotoInfo:287885549"}},"Rsvp:2073207191":{"__typename":"Rsvp","id":"2073207191","member":{"__ref":"Member:239029248"}},"Member:475426951":{"__typename":"Member","id":"475426951","name":"dobos.albert123","memberPhoto":null},"Rsvp:2073209613":{"__typename":"Rsvp","id":"2073209613","member":{"__ref":"Member:475426951"}},"Event:315086654":{"__typename":"Event","id":"315086654","title":"Building with Kiro and Kiro CLI: A Spec-Driven Approach to Agentic AI","eventUrl":"https://www.meetup.com/aws-ro/events/315086654/","description":"Hey there, before your go on your vacation, join us on July 1th for a hands-on workshop with Kiro, delivered from a **Solution Architect Lead** working at **AWS (Dragos Madarasan).**\nThis hands-on workshop teaches you to leverage natural language prompts, structured specifications and intelligent automation using Kiro and Strands Agents SDK. Master five core capabilities:\n\n* Vibe Coding\n* Steering\n* Model Context Protocol\n* Spec-Driven Development\n* Agent Hooks\n\nWalk away with practical AI-assisted development skills you can immediately apply to your projects.\n**Workshop Agenda:**\n\n* Introduction to AIDLC - Overview of AI-Driven Development methodology and Kiro capabilities\n* Live Demo - Hands-on demonstration of Kiro\n* Practical Exercise - Build a prototype using Kiro with guided practice\n* Q\u0026A / Networking - Open discussion and Networking\n\n📍 Location: Endava, UBC1, strada Palat 3E, 5th floor\n🕒 Time: 18:00\nWhat to bring:\nA laptop!\nP.S. There will be pizza!","isSaved":false,"group":{"__ref":"Group:20208629"},"creatorMember":{"__ref":"Member:222577274"},"eventHosts":[{"__typename":"EventHost","memberId":"14510953"},{"__typename":"EventHost","memberId":"222577274"}],"feeSettings":null,"venue":{"__ref":"Venue:25715073"},"dateTime":"2026-07-01T18:00:00+03:00","createdTime":"2026-06-03T10:24:17-04:00","endTime":"2026-07-01T20:00:00+03:00","going":{"__typename":"GoingRsvpConnection","totalCount":16},"isOnline":false,"eventType":"PHYSICAL","status":"ACTIVE","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:510303598"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":16,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073204790"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073204791"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073206649"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073207191"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2073209613"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:26618627":{"__typename":"Venue","id":"26618627","name":"Congress Hall","address":"Strada Palas Nr. 7A","city":"Iași","state":"IS","country":"ro"},"PhotoInfo:533051597":{"__typename":"PhotoInfo","id":"533051597","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/2/d/4/d/highres_533051597.jpeg"},"Rsvp:2064760799":{"__typename":"Rsvp","id":"2064760799","member":{"__ref":"Member:14510953"}},"Rsvp:2064760800":{"__typename":"Rsvp","id":"2064760800","member":{"__ref":"Member:222577274"}},"Member:412754473":{"__typename":"Member","id":"412754473","name":"Vitalie Lisnic","memberPhoto":null},"Rsvp:2064784774":{"__typename":"Rsvp","id":"2064784774","member":{"__ref":"Member:412754473"}},"PhotoInfo:314065120":{"__typename":"PhotoInfo","id":"314065120","highResUrl":"https://secure.meetupstatic.com/photos/member/6/2/2/0/highres_314065120.jpeg"},"Member:276064684":{"__typename":"Member","id":"276064684","name":"Ovidiu Moraru","memberPhoto":{"__ref":"PhotoInfo:314065120"}},"Rsvp:2064785023":{"__typename":"Rsvp","id":"2064785023","member":{"__ref":"Member:276064684"}},"PhotoInfo:283646514":{"__typename":"PhotoInfo","id":"283646514","highResUrl":"https://secure.meetupstatic.com/photos/member/6/7/9/2/highres_283646514.jpeg"},"Member:270893598":{"__typename":"Member","id":"270893598","name":"George Babii","memberPhoto":{"__ref":"PhotoInfo:283646514"}},"Rsvp:2064787596":{"__typename":"Rsvp","id":"2064787596","member":{"__ref":"Member:270893598"}},"Event:313656301":{"__typename":"Event","id":"313656301","title":"AWS Europe GameDay - Iași","eventUrl":"https://www.meetup.com/aws-ro/events/313656301/","description":"AWS Community GameDay Europe takes place on March 17th, 2026, simultaneously across 50+ European cities. Same challenges. Same clock. One pan-European leaderboard. It's organized not by AWS corporate, but by the AWS User Groups that run meetups in your city, which means it has a completely different energy than a polished conference session.\n\n## **Before you walk in, a few things worth knowing**\n\n* **You don't need an AWS account.** A sandboxed environment is provided on the day. You show up, you get credentials, you start building.\n* **You DO need a laptop.** Charged. With your preferred browser and ideally the AWS CLI installed. That's the full tech checklist.\n\nFor preparation, the most useful investment of your time is not reading documentation. It's getting comfortable navigating the AWS console under pressure. Spin up a few services you haven't used before. Break something intentionally and fix it. The muscle memory matters more than theoretical knowledge.\nIf you want to be purposeful about it, brush up on these areas that tend to show up across GameDay scenarios:\n\n* **IAM and permissions** : misconfigured roles are a classic challenge vector\n* **CloudWatch and logging** : knowing where to look when something is wrong is half the battle\n* **Lambda, API Gateway, and serverless basics** useful for cloud-native challenge tracks\n* **Amazon Bedrock and basic LLM integration** : relevant to AI challenge scenarios\n* **VPC networking fundamentals** , security groups, NACLs, routing\n\nYou don't need to master all of these. Even one area of depth on your team covers ground.\n\n## **🦄 During: The Event Itself**\n\nDoors open at 18:30, teams form by 18:45, the stream starts at 19:00 and the game starts at 19:30 RO time sharp, simultaneously, across every city in Europe.\nThere's a live stream connecting all locations. A leaderboard. And a shared atmosphere of controlled chaos that's hard to describe until you've been in it.\nThe challenges drop you into a live AWS environment that's broken in interesting ways. Maybe a service is misconfigured. Maybe there's a security gap you need to find and close. Maybe an architecture is failing under load and your team needs to diagnose and fix it.\nPoints are awarded as you solve each challenge. Teams work through as many as they can before time runs out.\n**A few dynamics to know !**\n\n* **Divide the work early :** The teams that do well tend to split into parallel tracks quickly, one person investigates the environment, another reads the challenge documentation, another starts making changes. Sitting together and taking turns doesn't scale.\n* **Read the challenge text carefully :** The instructions often contain hints. Rushing straight to the console and clicking around randomly costs time.\n* **Ask for help without guilt :** There are organizers and AWS community members in the room whose job on the night is to unblock you, not to judge you. Use them.\n* **Don't spiral on one challenge :** If you've been stuck for 20 minutes, note what you've tried and move on. More points exist elsewhere.\n\nThe leaderboard is visible throughout the event. It's competitive but not cutthroat -- the room tends to have a collaborative energy despite the competition. People help each other between challenges. That's the community part.\n\\#\\# 🏆**After: What You Take Home**\nThe formal event ends after roughly two hours. There's a closing ceremony, results are announced, and the live stream wraps up across all cities.\nWhat stays with you is harder to quantify. Sure, you'll have touched AWS services you'd never have explored on your own. You'll have debugged under real pressure, which builds a kind of confidence no tutorial can give you.\nBut honestly? That's not the part people remember most.\nFor me it's the moment your teammate shouts \"I found it!\" and the whole table erupts. It's high-fiving a stranger you met 90 minutes ago. It's the feeling of solving something together that none of you could have cracked alone. You'll walk out with new connections that started under pressure and those tend to stick. Some of the strongest friendships in this community were born at a GameDay.\nPrizes: Designed for teams of 4\n1st place global winners will get: 1000$ AWS Credits, 4 Exam Vouchers, unique AWS Community hoodie (limited edition only in EMEA), 4 GameDay Trophies and customized medals/stickers\n2nd and 3rd teams as global winners, will get a unique AWS Community Hoodie and customized medals. AWS credits for each team member: 2nd place 100$ and 3rd - 50$.\n**Prizes**\n\n* 1st place global winners will get: 1000$ AWS Credits, 4 Exam Vouchers, unique AWS Community hoodie (limited edition only in EMEA), 4 GameDay Trophies and customized medals/stickers\n* 2nd and 3rd teams as global winners, will get a unique AWS Community Hoodie and customized medals. AWS credits for each team member: 2nd place 100$ and 3rd - 50$.\n* 1st place local winners will get: free tickets to AWS Community Day Romania for 23-24th of April ([aws-community.ro](http://aws-community.ro/))","isSaved":false,"group":{"__ref":"Group:20208629"},"creatorMember":{"__ref":"Member:222577274"},"eventHosts":[{"__typename":"EventHost","memberId":"14510953"},{"__typename":"EventHost","memberId":"222577274"}],"feeSettings":null,"venue":{"__ref":"Venue:26618627"},"dateTime":"2026-03-17T19:00:00+02:00","createdTime":"2026-03-05T17:19:15-05:00","endTime":"2026-03-17T21:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":16},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:533051597"},"displayPhoto":{"__ref":"PhotoInfo:533051597"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":16,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064760799"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064760800"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064784774"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064785023"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064787596"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:28198327":{"__typename":"Venue","id":"28198327","name":"Silk District","address":"Calea Chișinăului 22C","city":"Iasi","state":"","country":"ro"},"PhotoInfo:532676163":{"__typename":"PhotoInfo","id":"532676163","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/d/b/6/3/highres_532676163.jpeg"},"Rsvp:2062051019":{"__typename":"Rsvp","id":"2062051019","member":{"__ref":"Member:14510953"}},"Rsvp:2062051020":{"__typename":"Rsvp","id":"2062051020","member":{"__ref":"Member:222577274"}},"Member:404683120":{"__typename":"Member","id":"404683120","name":"Vladimir Cebotaroș ","memberPhoto":null},"Rsvp:2062052189":{"__typename":"Rsvp","id":"2062052189","member":{"__ref":"Member:404683120"}},"PhotoInfo:264901050":{"__typename":"PhotoInfo","id":"264901050","highResUrl":"https://secure.meetupstatic.com/photos/member/4/1/a/highres_264901050.jpeg"},"Member:215738533":{"__typename":"Member","id":"215738533","name":"Dan Jitarasu","memberPhoto":{"__ref":"PhotoInfo:264901050"}},"Rsvp:2062052382":{"__typename":"Rsvp","id":"2062052382","member":{"__ref":"Member:215738533"}},"Rsvp:2062052495":{"__typename":"Rsvp","id":"2062052495","member":{"__ref":"Member:208929487"}},"Event:313205649":{"__typename":"Event","id":"313205649","title":"Iasi AWS re:Invent 2025 – Key Takeaways \u0026 Local Recap","eventUrl":"https://www.meetup.com/aws-ro/events/313205649/","description":"Join us for a deep dive into the latest innovations from AWS re:Invent 2025. This session is designed to help local cloud architects, developers, and engineers navigate the new service landscape and integrate emerging technologies into their 2026 roadmaps.\n**Event Details:**\n\n* **Date:** February 24, 2026\n* **Time:** 18:30\n* **Location:** Levi9 Office, Silk District\n\n**Why Attend?**\n\n* **Technical Deep Dives:** We will move beyond the headlines to explore technical implementation.\n* **Strategic Insights:** Learn how the new 2025 updates affect efficiency, cost, and scalability.\n* **Peer Networking:** Connect with Iasi’s top tech talent over food and drinks.\n\n**P.S. As always, there will be pizza!**","isSaved":false,"group":{"__ref":"Group:20208629"},"creatorMember":{"__ref":"Member:222577274"},"eventHosts":[{"__typename":"EventHost","memberId":"14510953"},{"__typename":"EventHost","memberId":"222577274"}],"feeSettings":null,"venue":{"__ref":"Venue:28198327"},"dateTime":"2026-02-24T18:30:00+02:00","createdTime":"2026-02-04T11:14:53-05:00","endTime":"2026-02-24T20:30:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":96},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532676163"},"displayPhoto":{"__ref":"PhotoInfo:532676163"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":96,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062051019"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062051020"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062052189"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062052382"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062052495"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:529841715":{"__typename":"PhotoInfo","id":"529841715","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/a/2/f/3/highres_529841715.jpeg"},"Rsvp:2047338301":{"__typename":"Rsvp","id":"2047338301","member":{"__ref":"Member:222577274"}},"Rsvp:2047339234":{"__typename":"Rsvp","id":"2047339234","member":{"__ref":"Member:270893598"}},"PhotoInfo:272163470":{"__typename":"PhotoInfo","id":"272163470","highResUrl":"https://secure.meetupstatic.com/photos/member/d/8/e/highres_272163470.jpeg"},"Member:192521450":{"__typename":"Member","id":"192521450","name":"Vlad Panainte","memberPhoto":{"__ref":"PhotoInfo:272163470"}},"Rsvp:2047339944":{"__typename":"Rsvp","id":"2047339944","member":{"__ref":"Member:192521450"}},"PhotoInfo:287005855":{"__typename":"PhotoInfo","id":"287005855","highResUrl":"https://secure.meetupstatic.com/photos/member/6/4/f/f/highres_287005855.jpeg"},"Member:266684615":{"__typename":"Member","id":"266684615","name":"George Crăciun-Vasilache","memberPhoto":{"__ref":"PhotoInfo:287005855"}},"Rsvp:2047341731":{"__typename":"Rsvp","id":"2047341731","member":{"__ref":"Member:266684615"}},"Member:475420417":{"__typename":"Member","id":"475420417","name":"Carina Ioana Sirbu","memberPhoto":null},"Rsvp:2047341997":{"__typename":"Rsvp","id":"2047341997","member":{"__ref":"Member:475420417"}},"Event:310708771":{"__typename":"Event","id":"310708771","title":"Iasi, AWS GameDay: Security!","eventUrl":"https://www.meetup.com/aws-ro/events/310708771/","description":"## Details\n\n**What is an AWS GameDay?**\nJoin us for the AWS GameDay, a gamified simulation exercise in which you will learn AWS concepts and best practices under light competition. Your goals are to become more comfortable with AWS and have fun in a live, risk-free environment.\n\n**Format**\nThis event will be 100% hands-on and you will be working extensively in the AWS Console. It is not a workshop, there are no step-by-step instructions. Be prepared to decide your own path forward with ambiguous directions. You may get frustrated and that is alright! Support staff will be available to assist you. Please come with an open mind to try new things. Our event is team-based, so you should arrive well-rested to communicate effectively, divide and conquer, and support your teammates.\n\n**What is the upcoming AWS GameDay “Security” about?**\nCongratulations on your new position as Senior Security Consultant at Unicorn.Rentals! You are all new hires at our fast-growing [fictitious] startup, Unicorn.Rentals and will take on various business problems we’ve been facing related to our security posture. Your team will be engaging with the services like Amazon Inspector, IAM Access Analyzer, Secrets Manager, GuardDuty, Config, RDS, EC2 Image Builder, Lambda, Systems Manager Parameter Store, EventBridge, EC2, VPC.\n\n**Organisation details**\nTeam size: 3-4 Players - come with your team or we will create ad-hoc ones.\nBring: Your trusty laptop - we will provide an internet connection.\n\n**Target audience**\nThe game is designed for players with general knowledge of the AWS platform and services, as well as interest in security.\n\n**Agenda:**\n18:00 - 18:30 Introduction to GameDay\n18:30 - 20:30 Game run-time (snacks \u0026 beer at will)\n20:30 - Game Ceremony\n\n**You will compete with local teams from Timisoara and with remote teams from the Cluj-Napoca, Timisoara, Bucharest and Chisinau User Groups.**","isSaved":false,"group":{"__ref":"Group:20208629"},"creatorMember":{"__ref":"Member:222577274"},"eventHosts":[{"__typename":"EventHost","memberId":"222577274"}],"feeSettings":null,"venue":{"__ref":"Venue:26618627"},"dateTime":"2025-09-25T18:00:00+03:00","createdTime":"2025-08-26T03:52:17-04:00","endTime":"2025-09-25T21:00:00+03:00","going":{"__typename":"GoingRsvpConnection","totalCount":24},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:529841715"},"displayPhoto":{"__ref":"PhotoInfo:529841715"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":24,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2047338301"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2047339234"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2047339944"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2047341731"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2047341997"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:528579818":{"__typename":"PhotoInfo","id":"528579818","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/9/b/8/a/highres_528579818.jpeg"},"Rsvp:2038883219":{"__typename":"Rsvp","id":"2038883219","member":{"__ref":"Member:222577274"}},"Member:421078621":{"__typename":"Member","id":"421078621","name":"Mihaela","memberPhoto":null},"Rsvp:2038891187":{"__typename":"Rsvp","id":"2038891187","member":{"__ref":"Member:421078621"}},"Rsvp:2038899408":{"__typename":"Rsvp","id":"2038899408","member":{"__ref":"Member:412754473"}},"Member:473750084":{"__typename":"Member","id":"473750084","name":"Catalin Calugaru","memberPhoto":null},"Rsvp:2038904981":{"__typename":"Rsvp","id":"2038904981","member":{"__ref":"Member:473750084"}},"PhotoInfo:278407783":{"__typename":"PhotoInfo","id":"278407783","highResUrl":"https://secure.meetupstatic.com/photos/member/1/e/6/7/highres_278407783.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:257620673":{"__typename":"Member","id":"257620673","name":"Lavinia Hritcu","memberPhoto":{"__ref":"PhotoInfo:278407783"}},"Rsvp:2038942477":{"__typename":"Rsvp","id":"2038942477","member":{"__ref":"Member:257620673"}},"PhotoInfo:305592784":{"__typename":"PhotoInfo","id":"305592784","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/3/1/f/0/highres_305592784.jpeg"},"PhotoInfo:92747072":{"__typename":"PhotoInfo","id":"92747072","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/b/7/e/0/highres_92747072.jpeg"},"PhotoInfo:314146257":{"__typename":"PhotoInfo","id":"314146257","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/b/4/b/1/highres_314146257.jpeg"},"PhotoInfo:247914162":{"__typename":"PhotoInfo","id":"247914162","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/d/3/9/2/highres_247914162.jpeg"},"PhotoInfo:258538072":{"__typename":"PhotoInfo","id":"258538072","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/e/2/d/8/highres_258538072.jpeg"},"Event:308528893":{"__typename":"Event","id":"308528893","title":"Iasi Amazon Bedrock Fundamentals: Hands-On Workshop for Generative AI Developmen","eventUrl":"https://www.meetup.com/aws-ro/events/308528893/","description":"Hey there, before your go on your vacation, join us on June 19th 2025 for a for a hands-on workshop with AWS Bedrock, delivered from a **Solution Architect Lead working at AWS** (Dragos Madarasan).\n\nIn this workshop you will **get hands-on experience in leveraging foundation models** (FMs) through [Amazon Bedrock](https://aws.amazon.com/bedrock/) . Amazon Bedrock is a fully managed service that provides access to FMs from third-party providers and Amazon; available via an API. With Bedrock, you can choose from a variety of models to find the one that’s best suited for your use case.\n\nThrough **hands on labs**, you will **go through some of the most common Generative AI** usage patterns we are seeing with our customers. You will explore techniques for generating text and images, and learn how to improve productivity by using foundation models to help in **composing emails, summarizing text, answering questions, building chatbots, creating images, and generating code**.\n\nYou will gain **hands-on experience** using Bedrock APIs, SDKs, and open-source software, such as LangChain and FAISS, to implement these usage patterns. You'll learn how to leverage Amazon Bedrock's serverless architecture and powerful features to build production-ready generative AI applications that scale with your needs.\n\nThere will be temporary **AWS accounts provided for the hands on labs**. The purpose of these temporary accounts is to ensure that all resources and permissions are set up correctly and to avoid any charges in your personal or business accounts.\n\n📍 Location: Palas Mall, Congress Hall, Sala Vivaldi\n🕒 Time: 18:00\n\n**What to bring:**\n\n* A laptop!\n\n**P.S. There will be pizza!**","isSaved":false,"group":{"__ref":"Group:20208629"},"creatorMember":{"__ref":"Member:222577274"},"eventHosts":[{"__typename":"EventHost","memberId":"222577274"}],"feeSettings":null,"venue":{"__ref":"Venue:26618627"},"dateTime":"2025-06-19T18:00:00+03:00","createdTime":"2025-06-16T12:17:01-04:00","endTime":"2025-06-19T20:00:00+03:00","going":{"__typename":"GoingRsvpConnection","totalCount":8},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:528579818"},"displayPhoto":{"__ref":"PhotoInfo:528579818"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":8,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2038883219"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2038891187"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2038899408"}