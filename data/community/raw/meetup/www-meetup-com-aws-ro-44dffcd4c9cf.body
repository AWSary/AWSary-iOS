73"},"isSuperOrganizer":false},"PhotoInfo:510303598":{"__typename":"PhotoInfo","id":"510303598","highResUrl":"https://secure.meetupstatic.com/photos/event/e/0/e/highres_510303598.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"Member:194800896":{"__typename":"Member","id":"194800896","name":"Victor H.","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:314146257"}},"Group:20208629":{"__typename":"Group","id":"20208629","name":"IASI AWS User Group","timezone":"Europe/Bucharest","keyGroupPhoto":{"__ref":"PhotoInfo:510303598"},"urlname":"aws-ro","isPrivate":false,"organizer":{"__ref":"Member:222577274"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":742,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.8,"total":40}},"lat":47.17,"lon":27.57,"joinMode":"OPEN","status":"PAID","city":"Iasi","state":"","country":"ro","proNetwork":null,"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":null,"needsPhoto":null,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-ro/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:194800896"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:222577274"}}]},"description":"\u003cp\u003eThis is a group for users of Amazon Web Services. We'll cover Use Cases, Best Practices, Success Stories, Tips \u0026amp; Tricks, Cloud Computing, DevOps.\u003c/p\u003e\n\u003cp\u003eWe encourage discussions and networking and we will have fun while we learn new things.\u003c/p\u003e","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"Gro