le":"Past events","eventCard.attendeeCount.plural":"{count} attendees","shareButton.eventShareTitle":"Share this event","shareButton.label":"Share event","shareButton.eventShareTitle_v2":"Share","redesign.components.avatar.ariaLabel":"Photo of the user {memberName}","eventCard.attendeeCount.singular":"{count} attendee","groupHome.linksTitle":"Group links","aside.messageButton":"Message","aside.organizersTitle":"Organizers","aside.andOthers":"and {count, plural, one {# other} other {# others}}","aside.seeAll":"See all","aside.membersTitle":"Members","groupHome.networkLinksTitle":"Find us also at","groupHome.socialXBtn":"X","groupHome.socialLinkedinBtn":"LinkedIn","groupHome.topicsTitle":"Related topics","footer.meetupOnFacebook":"Meetup on Facebook","footer.meetupOnTwitter":"Meetup on Twitter","footer.meetupOnYoutube":"Meetup on YouTube","footer.meetupOnInstagram":"Instagram","footer.meetupOnTiktok":"TikTok","footer.thePeoplePlatform":"The \u003cred\u003epeople\u003c/red\u003e platform","footer.createYourOwnMeetupGroup":"Create your own Meetup group","footer.startNewGroup":"Start a new group","footer.yourAccount":"Your account","footer.signUp":"Sign up","footer.logIn":"Log in","footer.help":"Help","footer.discover":"Discover","footer.groups":"Groups","footer.events":"Events","footer.topics":"Topics","footer.cities":"Cities","footer.onlineEvents":"Online events","footer.localGuides":"Local guides","footer.makeFriendsLp":"Make friends","footer.sitemap":"Sitemap","footer.meetupText":"Meetup","footer.about":"About","footer.blog":"Blog","footer.meetupPro":"Meetup Pro","footer.careers":"Careers","footer.apps":"Apps","footer.podcast":"Podcast","footer.followUs":"Follow us","footer.getTheApp":"Get the app","mobileDownloadButtons.downloadFromGooglePlay":"Download app from Google Play","mobileDownloadButtons.downloadFromAppStore":"Download app from App Store","mobileDownloadButtons.downloadOnStore":"Download on","footer.meetupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Terms of service","footer.privacyPolicy":"Privacy policy","footer.cookiePolicy":"Cookie policy","footer.licenseAttribution":"License attribution","footer.madeWithLoveBy":"Made with {love} by"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:260979537":{"__typename":"PhotoInfo","id":"260979537","highResUrl":"https://secure.meetupstatic.com/photos/member/9/a/7/1/highres_260979537.jpeg"},"Member:183017413":{"__typename":"Member","id":"183017413","name":"Victor Adsuar","email":"","memberPhoto":{"__ref":"PhotoInfo:260979537"},"isSuperOrganizer":false},"PhotoInfo:484526535":{"__typename":"PhotoInfo","id":"484526535","highResUrl":"https://secure.meetupstatic.com/photos/event/6/7/a/7/highres_484526535.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Member:247574918":{"__typename":"Member","id":"247574918","name":"Vicente Aguilar","isSuperOrganizer":false},"Group:23036296":{"__typename":"Group","id":"23036296","name":"AWS User Group Alicante","timezone":"Europe/Madrid","keyGroupPhoto":{"__ref":"PhotoInfo:484526535"},"urlname":"aws-user-group-alicante","isPrivate":false,"organizer":{"__ref":"Member:183017413"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":502,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.95,"total":63}},"lat":38.35,"lon":-0.49,"joinMode":"OPEN","status":"PAID","city":"Alicante","state":"","country":"es","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":2},"needsQuestions":false,"needsPhoto":true,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-alicante/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"¡Muchas gracias por unirte a este MeetUp! \nTe aseguramos que será realmente interesante y no te arrepentirás.","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:183017413"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:247574918"}}]},"description":"El Meetup de AWS User Group Alicante tiene como objetivo transmitir el conocimiento sobre los servicios de Amazon Web Services en la zona de Levante. Colaboramos directamente con AWS y otros grupos de AWS repartidos por el mundo para difundir las herramientas y servicios que podemos emplear en la nube. \nCreemos que el cloud es una herramienta disruptiva en el mundo de la tecnología y que es capaz de cambiar las reglas del juego donde los pequeños podemos emplear las últimas tecnologías con una relación calidad/precio sin precedentes en la historia.\nNuestro principal enfoque es mostrar cómo podemos hacer más por menos empleando el cloud. Transmitimos los pilares de buenas prácticas a la hora de definir nuevas arquitecturas y siempre desde la honestidad de traer a los mejores de cada campo para que nos muestren en Alicante qué se hace en el resto de mundo. Contamos con el apoyo inestimable del equipo de evangelistas de AWS y con profesionales de empresas que día a día trabajan con las tecnologías que presentan.\nEste grupo está patrocinado por la empresa Cloud Levante, partner de AWS y colaborador en la misión evangelista del cloud.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":14,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:311066161"}},{"__typename":"EventEdge","node":{"__ref":"Event:303189524"}},{"__typename":"EventEdge","node":{"__ref":"Event:302172072"}},{"__typename":"EventEdge","node":{"__ref":"Event:299149945"}}]},"activeTopics":[{"__ref":"Topic:8192"},{"__ref":"Topic:788002"},{"__ref":"Topic:120095"},{"__ref":"Topic:43601"},{"__ref":"Topic:9696"},{"__ref":"Topic:101553"},{"__ref":"Topic:30609"},{"__ref":"Topic:1056672"},{"__ref":"Topic:32528"},{"__ref":"Topic:18865"},{"__ref":"Topic:17381"},{"__ref":"Topic:19303"},{"__ref":"Topic:17390"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch6963576"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch6963573"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch6963575"}}]},"foundedDate":"2017-03-28T05:21:28+02:00","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"@Cloud_Levante","url":"http://twitter.com/Cloud_Levante/","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"https://www.linkedin.com/company/cloud-levante","url":"https://www.linkedin.com/company/cloud-levante","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"https://twitter.com/AWSGroupAlic","url":"https://twitter.com/AWSGroupAlic","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:183017413"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:143552192"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:198952294"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:204619190"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:8802483"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:217173729"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:209302484"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:195179127"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:223455567"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:206218403"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:207291883"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:186777110"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:192380679"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:138316222"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:224734172"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:217923635"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:224274080"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Member:361565683":{"__typename":"Member","id":"361565683"},"Venue:28067803":{"__typename":"Venue","id":"28067803","name":"Ulab","address":"Ulab. Plaza de San Cristóbal, 14 (Alicante)","city":"Alicante","state":"","country":"es"},"PhotoInfo:530225352":{"__typename":"PhotoInfo","id":"530225352","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/1/4/e/8/highres_530225352.jpeg"},"PhotoInfo:319917039":{"__typename":"PhotoInfo","id":"319917039","highResUrl":"https://secure.meetupstatic.com/photos/member/d/e/c/f/highres_319917039.jpeg"},"Member:389085919":{"__typename":"Member","id":"389085919","name":"Neusa Antónia Romão Caxicane","memberPhoto":{"__ref":"PhotoInfo:319917039"}},"Rsvp:2049445097":{"__typename":"Rsvp","id":"2049445097","member":{"__ref":"Member:389085919"}},"PhotoInfo:317373430":{"__typename":"PhotoInfo","id":"317373430","highResUrl":"https://secure.meetupstatic.com/photos/member/8/2/9/6/highres_317373430.jpeg"},"Member:405816781":{"__typename":"Member","id":"405816781","name":"Emilio De La Peña Chacón","memberPhoto":{"__ref":"PhotoInfo:317373430"}},"Rsvp:2049446001":{"__typename":"Rsvp","id":"2049446001","member":{"__ref":"Member:405816781"}},"PhotoInfo:312980561":{"__typename":"PhotoInfo","id":"312980561","highResUrl":"https://secure.meetupstatic.com/photos/member/5/0/5/1/highres_312980561.jpeg"},"Member:373984494":{"__typename":"Member","id":"373984494","name":"Noah Winkler","memberPhoto":{"__ref":"PhotoInfo:312980561"}},"Rsvp:2049465565":{"__typename":"Rsvp","id":"2049465565","member":{"__ref":"Member:373984494"}},"PhotoInfo:321808755":{"__typename":"PhotoInfo","id":"321808755","highResUrl":"https://secure.meetupstatic.com/photos/member/7/0/5/3/highres_321808755.jpeg"},"Member:401595404":{"__typename":"Member","id":"401595404","name":"Oleksandr Torlo","memberPhoto":{"__ref":"PhotoInfo:321808755"}},"Rsvp:2049466093":{"__typename":"Rsvp","id":"2049466093","member":{"__ref":"Member:401595404"}},"PhotoInfo:323972745":{"__typename":"PhotoInfo","id":"323972745","highResUrl":"https://secure.meetupstatic.com/photos/member/7/f/e/9/highres_323972745.jpeg"},"Member:475931392":{"__typename":"Member","id":"475931392","name":"Quique","memberPhoto":{"__ref":"PhotoInfo:323972745"}},"Rsvp:2049506810":{"__typename":"Rsvp","id":"2049506810","member":{"__ref":"Member:475931392"}},"Event:311066161":{"__typename":"Event","id":"311066161","title":"[Tech Talks]  Building Deterministic Agentic AI Tooling in Rust","eventUrl":"https://www.meetup.com/aws-user-group-alicante/events/311066161/","description":"# **[Tech Talks] Building Deterministic Agentic AI Tooling in Rust – An Introduction to PMAT and Ruchy**\n\nHello community!\n\nWe’re back with an unmissable technical session designed to learn, share and enjoy.\n\n📅 Date: Thursday, October 16\n🕕 Time: 18:00\n📍 Venue: ULab, Alicante\n\nThis time, **Noah Gift**, founder of Pragmatic A.I. Labs and AWS Machine Learning Hero, will deliver the talk *“Building Deterministic Agentic AI Tooling in Rust – An Introduction to PMAT and Ruchy.”*\n\n👉 Join us for this session and discover how to build agentic AI tools in Rust with a deterministic approach.","isSaved":false,"group":{"__ref":"Group:23036296"},"creatorMember":{"__ref":"Member:361565683"},"eventHosts":[],"feeSettings":null,"venue":{"__ref":"Venue:28067803"},"dateTime":"2025-10-16T18:00:00+02:00","createdTime":"2025-09-16T05:29:46-04:00","endTime":"2025-10-16T20:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":25},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:530225352"},"displayPhoto":{"__ref":"PhotoInfo:530225352"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":25,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2049445097"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2049446001"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2049465565"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2049466093"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2049506810"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27862677":{"__typename":"Venue","id":"27862677","name":"Laboral Ciudad de la Cultura","address":"Calle Luis Moya Blanco 261, Gijón, Asturias (España)","city":"Gijón","state":"","country":"es"},"PhotoInfo:523275151":{"__typename":"PhotoInfo","id":"523275151","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/3/b/2/f/highres_523275151.jpeg"},"PhotoInfo:309670688":{"__typename":"PhotoInfo","id":"309670688","highResUrl":"https://secure.meetupstatic.com/photos/member/2/9/c/0/highres_309670688.jpeg"},"Member:220738408":{"__typename":"Member","id":"220738408","name":"Alejandro J. López","memberPhoto":{"__ref":"PhotoInfo:309670688"}},"Rsvp:2010841181":{"__typename":"Rsvp","id":"2010841181","member":{"__ref":"Member:220738408"}},"Event:303189524":{"__typename":"Event","id":"303189524","title":"AWS Community Day Spain 2024 - Gijón","eventUrl":"https://www.meetup.com/aws-user-group-alicante/events/303189524/","description":"¡Hola a tod@s!\n\nNos encanta anunciar un evento especial para toda la comunidad: el **AWS Community Day Spain.**\n\nPor supuesto, todos los miembros de AWS Alicante Group están invitados a participar. (Aunque este año el evento se celebrará en Gijón, así que si tienes pensado hacer un viajecito al norte ¡ya sabes!)\n\nEl AWS Community Day Spain es una **conferencia técnica gratuita** sobre AWS que está planificada, organizada e impartida por integrantes de la **Comunidad de Amazon Web Services en España**.\n\nLas entradas a este evento son limitadas. Puedes encontrar toda la información y la forma de **reservar tu entrada** en: [https://2024.awscommunity.es/](https://2024.awscommunity.es/)\n\nEl principal objetivo es reunir a entusiastas de la nube pública de Amazon en un evento anual donde intercambiar ideas y asistir a charlas técnicas de alto nivel.\n\nCreemos que una conferencia técnica pensada desde la comunidad de usuarios y usuarias es la mejor forma de conocer otros puntos de vista y de ver nuevas soluciones a los problemas que se nos plantean a diario.\n\nEste evento esta organizado por miembros activos de la comunidad de AWS España entre los que se encuentran User Group Leaders y AWS Community Builders.","isSaved":false,"group":{"__ref":"Group:23036296"},"creatorMember":{"__ref":"Member:361565683"},"eventHosts":[],"feeSettings":null,"venue":{"__ref":"Venue:27862677"},"dateTime":"2024-10-19T09:00:00+02:00","createdTime":"2024-09-02T05:05:06-04:00","endTime":"2024-10-19T19:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":1},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:523275151"},"displayPhoto":{"__ref":"PhotoInfo:523275151"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":1,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2010841181"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27847569":{"__typename":"Venue","id":"27847569","name":"Alohers Coffee Surf","address":"Carrer Sicília, 4, 03540 Alacant, Alicante","city":"Alicante","state":"","country":"es"},"PhotoInfo:522260126":{"__typename":"PhotoInfo","id":"522260126","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/4/e/9/e/highres_522260126.jpeg"},"Rsvp:2003033598":{"__typename":"Rsvp","id":"2003033598","member":{"__ref":"Member:183017413"}},"PhotoInfo:305553802":{"__typename":"PhotoInfo","id":"305553802","highResUrl":"https://secure.meetupstatic.com/photos/member/8/4/0/a/highres_305553802.jpeg"},"Member:154545412":{"__typename":"Member","id":"154545412","name":"sumente sumente","memberPhoto":{"__ref":"PhotoInfo:305553802"}},"Rsvp:2003035857":{"__typename":"Rsvp","id":"2003035857","member":{"__ref":"Member:154545412"}},"PhotoInfo:318660198":{"__typename":"PhotoInfo","id":"318660198","highResUrl":"https://secure.meetupstatic.com/photos/member/c/6/highres_318660198.jpeg"},"Member:252292242":{"__typename":"Member","id":"252292242","name":"Gunnar Grosch","memberPhoto":{"__ref":"PhotoInfo:318660198"}},"Rsvp:2003470879":{"__typename":"Rsvp","id":"2003470879","member":{"__ref":"Member:252292242"}},"Rsvp:2003541215":{"__typename":"Rsvp","id":"2003541215","member":{"__ref":"Member:389085919"}},"PhotoInfo:320159044":{"__typename":"PhotoInfo","id":"320159044","highResUrl":"https://secure.meetupstatic.com/photos/member/e/6/a/4/highres_320159044.jpeg"},"Member:424378573":{"__typename":"Member","id":"424378573","name":" Fran","memberPhoto":{"__ref":"PhotoInfo:320159044"}},"Rsvp:2003613388":{"__typename":"Rsvp","id":"2003613388","member":{"__ref":"Member:424378573"}},"Event:302172072":{"__typename":"Event","id":"302172072","title":"AWS Beers \u0026 Beach","eventUrl":"https://www.meetup.com/aws-user-group-alicante/events/302172072/","description":"Don't miss the exciting **AWS Beers \u0026 Beach** event!\n\n**Event Details**\n\n* **Date**: August 2, 2024\n* **Time**: 10:00 AM\n* **Venue**: [Alohers Coffee Surf, Carrer Sicília, 4, 03540 Alacant, Alicante](https://www.google.com/maps/place/Alohers+Coffee+Surf/@38.3629012,-0.4157612,17z/data=!4m6!3m5!1s0xd6239e19dc24685:0x65be31c2a90936c!8m2!3d38.3628462!4d-0.4113834!16s%2Fg%2F11g1g7j2v3?entry=ttu)\n\n**Description**\n\nJoin us in a relaxed and summery atmosphere at the beautiful [Alohers Coffee Surf](https://www.google.com/maps/place/Alohers+Coffee+Surf/@38.3629012,-0.4157612,17z/data=!4m6!3m5!1s0xd6239e19dc24685:0x65be31c2a90936c!8m2!3d38.3628462!4d-0.4113834!16s%2Fg%2F11g1g7j2v3?entry=ttu) café, where the Alicante AWS User Group is organizing a must-attend session for all technology enthusiasts.\n\n**Keynote Presentation**\n\n* **Title**: Visualize and Design Your Serverless Applications\n* **Speaker**: Gunnar Grosch, AWS Chaos Engineering Expert\n\n**About the Presentation**\n\nIn this session, Gunnar Grosch will guide us through the fascinating world of serverless applications. You will learn how to get started with **AWS Application Composer**, a low-code visual interface for designing and building serverless applications. This tool helps developers understand their application architecture, collaborate effectively, and manage application configuration.\n\nAdditionally, Gunnar will demonstrate how to prototype a serverless **generative AI** application, leveraging **Amazon Bedrock**, from concept to a full-featured application using **Application Composer** and **Amazon Q Developer** in his IDE.\n\n**And afterwards or during the talk...**\n\nWe’ll enjoy a refreshing drink together while soaking in the summer vibes of Alicante. It will be an excellent opportunity for networking, sharing ideas, and enjoying great conversation.\n\nYou can't miss it! Come to learn, get inspired, and relax at **AWS Beers \u0026 Beach**. We look forward to seeing you there!\n\n**¡IMPORTANT! Hawaiian Dress Code** 🏄‍♀️","isSaved":false,"group":{"__ref":"Group:23036296"},"creatorMember":{"__ref":"Member:361565683"},"eventHosts":[{"__typename":"EventHost","memberId":"183017413"}],"feeSettings":null,"venue":{"__ref":"Venue:27847569"},"dateTime":"2024-08-02T10:00:00+02:00","createdTime":"2024-07-11T03:25:37-04:00","endTime":"2024-08-02T12:00:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":11},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:522260126"},"displayPhoto":{"__ref":"PhotoInfo:522260126"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":11,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003033598"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003035857"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003470879"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003541215"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003613388"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27430817":{"__typename":"Venue","id":"27430817","name":"Parque Científico de Alicante","address":"","city":"Alicante","state":"VC","country":"es"},"PhotoInfo:519537274":{"__typename":"PhotoInfo","id":"519537274","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/d/f/b/a/highres_519537274.jpeg"},"Rsvp:1986856713":{"__typename":"Rsvp","id":"1986856713","member":{"__ref":"Member:183017413"}},"PhotoInfo:277279689":{"__typename":"PhotoInfo","id":"277279689","highResUrl":"https://secure.meetupstatic.com/photos/member/4/c/e/9/highres_277279689.jpeg"},"Member:2298175":{"__typename":"Member","id":"2298175","name":"Pau Garcia Quiles","memberPhoto":{"__ref":"PhotoInfo:277279689"}},"Rsvp:1986857483":{"__typename":"Rsvp","id":"1986857483","member":{"__ref":"Member:2298175"}},"PhotoInfo:315080255":{"__typename":"PhotoInfo","id":"315080255","highResUrl":"https://secure.meetupstatic.com/photos/member/4/f/1/f/highres_315080255.jpeg"},"Member:391150080":{"__typename":"Member","id":"391150080","name":"Anton Chernysh","memberPhoto":{"__ref":"PhotoInfo:315080255"}},"Rsvp:1986857693":{"__typename":"Rsvp","id":"1986857693","member":{"__ref":"Member:391150080"}},"Rsvp:1989519438":{"__typename":"Rsvp","id":"1989519438","member":{"__ref":"Member:389085919"}},"PhotoInfo:318766723":{"__typename":"PhotoInfo","id":"318766723","highResUrl":"https://secure.meetupstatic.com/photos/member/b/6/8/3/highres_318766723.jpeg"},"Member:415009211":{"__typename":"Member","id":"415009211","name":"Ruben","memberPhoto":{"__ref":"PhotoInfo:318766723"}},"Rsvp:1989785211":{"__typename":"Rsvp","id":"1989785211","member":{"__ref":"Member:415009211"}},"Event:299149945":{"__typename":"Event","id":"299149945","title":"Nueva Normativa Europea de Ciberseguridad NIS2: Cómo Preparar tu Empresa","eventUrl":"https://www.meetup.com/aws-user-group-alicante/events/299149945/","description":"NIS 2 es la legislación marco común de ciberseguridad de la UE, requiriendo que empresas identificadas por los Estados miembros cumplan los requisitos de seguridad y notificación a partir del 17 de octubre de 2024.\n\nLas empresas designadas como operadores esenciales deben implementar medidas de seguridad y reportar incidentes graves a las autoridades nacionales. Los proveedores clave de servicios digitales también deben cumplir con los requisitos de seguridad y notificación establecidos.\n\nPara determinar si tu empresa se ve afectada por la normativa y garantizar su cumplimiento, te invitamos a asistir al evento el **24 de abril** **a las 10:00h en el [Parque Científico de Alicante](https://maps.app.goo.gl/ksjjREAcYNi5kCv57)**. Nuestros expertos, [Victor Adsuar](https://www.linkedin.com/in/victoradsuar/) de [Cloud Levante](https://cloudlevante.com/) y [Pablo Sánchez Carmona](https://www.linkedin.com/in/sanchezcarmona/) de [AWS](https://aws.amazon.com/?nc2=h_lg), proporcionarán información detallada y soluciones prácticas para asegurar el cumplimiento normativo.\n\n**FECHA Y LUGAR**\n\n24 de abril a las 10:00h. La jornada se realizará de forma presencial en la Sala Polivalente del edificio Parque Científico de Alicante.\n\n**AGENDA**\n\n* **10:00** Café de Bienvenida\n* **10:15** Introducción a NIS 2: impacto en las organizaciones y cómo prepararse para su cumplimiento\n* **10:45** Soluciones de seguridad en torno a NIS2\nSecurity@Edge y Zero Trust Networking con AWS Verified Access (AVA)\nSecurity Information and Event Management (SIEM)\n* **12:15** Coloquio y conclusiones\n* **12:30** Lunch y Vino Alicante\n\n[Por favor, para asegurar tu plaza, haz clic aquí y confirma tu asistencia a través del formulario.](https://forms.office.com/Pages/ResponsePage.aspx?id=vaEjbrXv7UCif_CN4wPe8nfhqhVYzCNCt4A3TfzZna5UOFBFUzg2M004TjdGT0czTE81TTlHQlFBUS4u)","isSaved":false,"group":{"__ref":"Group:23036296"},"creatorMember":{"__ref":"Member:361565683"},"eventHosts":[{"__typename":"EventHost","memberId":"183017413"}],"feeSettings":null,"venue":{"__ref":"Venue:27430817"},"dateTime":"2024-04-24T10:00:00+02:00","createdTime":"2024-02-12T03:31:31-05:00","endTime":"2024-04-24T12:30:00+02:00","going":{"__typename":"GoingRsvpConnection","totalCount":21},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:519537274"},"displayPhoto":{"__ref":"PhotoInfo:519537274"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":21,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:1986856713"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:1986857483"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:1986857693"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:1989519438"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:1989785211"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:8192":{"__typename":"Topic","id":"8192","name":"Open Source","urlkey":"open-source"},"Topic:788002":{"__typename":"Topic","id":"788002","name":"Web Technology","urlkey":"web-technology"},"Topic:120095":{"__typename":"Topic","id":"120095","name":"Software Development","urlkey":"software-development"},"Topic:43601":{"__typename":"Topic","id":"43601","name":"Professional Development","urlkey":"professional-development"},"Topic:9696":{"__typename":"Topic","id":"9696","name":"New Technology","urlkey":"new-technology"},"Topic:101553":{"__typename":"Topic","id":"101553","name":"Mobile Technology","urlkey":"mobile-technology"},"Topic:30609":{"__typename":"Topic","id":"30609","name":"Startup Businesses","urlkey":"startup-businesses"},"Topic:1056672":{"__typename":"Topic","id":"1056672","name":"Big Data","urlkey":"big-data"},"Topic:32528":{"__typename":"Topic","id":"32528","name":"Computer Programming","urlkey":"computer-programming"},"Topic:18865":{"__typename":"Topic","id":"18865","name":"Technology","urlkey":"technology"},"Topic:17381":{"__typename":"Topic","id":"17381","name":"Professional Networking","urlkey":"professional-networking"},"Topic:19303":{"__typename":"Topic","id":"19303","name":"Entrepreneur Networking","urlkey":"entrepreneur-networking"},