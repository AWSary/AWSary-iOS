Organizer":true},"PhotoInfo:527476878":{"__typename":"PhotoInfo","id":"527476878","highResUrl":"https://secure.meetupstatic.com/photos/event/4/1/e/e/highres_527476878.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"Member:321449605":{"__typename":"Member","id":"321449605","name":"Hari priya","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:304006272"}},"Member:275416631":{"__typename":"Member","id":"275416631","name":"Srushith R","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:322701605"}},"Member:401820331":{"__typename":"Member","id":"401820331","name":"Srushti T","isSuperOrganizer":false},"Member:454806895":{"__typename":"Member","id":"454806895","name":"rasika","isSuperOrganizer":false},"Member:296264333":{"__typename":"Member","id":"296264333","name":"Dharmendra Singh Negi","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:310371116"}},"Group:34534969":{"__typename":"Group","id":"34534969","name":"AWS User Group Tirupati","timezone":"Asia/Kolkata","keyGroupPhoto":{"__ref":"PhotoInfo:527476878"},"urlname":"aws-user-group-tirupati","isPrivate":false,"organizer":{"__ref":"Member:183467672"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":1848,"leadership":6,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.69,"total":62}},"lat":13.63,"lon":79.41,"joinMode":"OPEN","status":"PAID","city":"Tirupati","state":"","country":"in","proNetwork":null,"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":null,"needsPhoto":null,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-tirupati/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"Hey there! \n\nWelcome to AWS UG Tirupati. \n\nLet's connect in the meetups, learn and share knowledge on AWS and empower each other. \n\nLooking forward to your active participation!","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:183467672"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321449605"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:275416631"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:401820331"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:454806895"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:296264333"}}]},"description":"\u003cp\u003eThis group is for anyone and everyone interested in AWS. \u003c/p\u003e \n\u003cp\u003eAll skill levels are welcome. \u003c/p\u003e \n\u003cp\u003eIf you are beginner, you can start learn AWS by attending the meetups. \u003cbr\u003eIf you are an intermediate level user, you can connect to people and start sharing your knowledge \u003cbr\u003eIf you are an expert, share your knowledge and become a leader in the community.\u003c/p\u003e","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":29,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:314845150"}},{"__typename":"EventEdge","node":{"__ref":"Event:313834973"}},{"__typename":"EventEdge","node":{"__ref":"Event:313553806"}},{"__typename":"EventEdge","node":{"__ref":"Event:313218186"}}]},"activeTopics":[{"__ref":"Topic:20479"},{"__ref":"Topic:15167"},{"__ref":"Topic:120095"},{"__ref":"Topic:8192"},{"__ref":"Topic:788002"},{"__ref":"Topic:1056672"},{"__ref":"Topic:31197"},{"__ref":"Topic:24410"},{"__ref":"Topic:33089"},{"__ref":"Topic:44297"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[]},"foundedDate":"2020-11-26T23:27:42+05:30","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:304640192"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:222820667"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:183467672"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:283792468"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321449084"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321449605"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:117734232"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321450068"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321450905"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:298327497"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:223165302"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:226425906"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321454580"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:235745429"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:206950937"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:272730312"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:321449843"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:26906060":{"__typename":"Venue","id":"26906060","name":"Online event","address":"","city":"","state":"","country":""},"PhotoInfo:534297970":{"__typename":"PhotoInfo","id":"534297970","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/e/2/7/2/highres_534297970.jpeg"},"PhotoInfo:310371116":{"__typename":"PhotoInfo","id":"310371116","highResUrl":"https://secure.meetupstatic.com/photos/member/c/7/a/c/highres_310371116.jpeg"},"Rsvp:2071754365":{"__typename":"Rsvp","id":"2071754365","member":{"__ref":"Member:296264333"}},"PhotoInfo:322701605":{"__typename":"PhotoInfo","id":"322701605","highResUrl":"https://secure.meetupstatic.com/photos/member/5/4/6/5/highres_322701605.jpeg"},"Rsvp:2071754366":{"__typename":"Rsvp","id":"2071754366","member":{"__ref":"Member:275416631"}},"Member:479060031":{"__typename":"Member","id":"479060031","name":"Jahnavi Reddy P","memberPhoto":null},"Rsvp:2071756799":{"__typename":"Rsvp","id":"2071756799","member":{"__ref":"Member:479060031"}},"PhotoInfo:253020227":{"__typename":"PhotoInfo","id":"253020227","highResUrl":"https://secure.meetupstatic.com/photos/member/e/3/highres_253020227.jpeg"},"Member:198272601":{"__typename":"Member","id":"198272601","name":"G.M.","memberPhoto":{"__ref":"PhotoInfo:253020227"}},"Rsvp:2071758081":{"__typename":"Rsvp","id":"2071758081","member":{"__ref":"Member:198272601"}},"PhotoInfo:325071685":{"__typename":"PhotoInfo","id":"325071685","highResUrl":"https://secure.meetupstatic.com/photos/member/c/9/e/5/highres_325071685.jpeg"},"Member:416791503":{"__typename":"Member","id":"416791503","name":"Maharishee ambati","memberPhoto":{"__ref":"PhotoInfo:325071685"}},"Rsvp:2071769092":{"__typename":"Rsvp","id":"2071769092","member":{"__ref":"Member:416791503"}},"Event:314845150":{"__typename":"Event","id":"314845150","title":"Serverless Saturdays - 13th June","eventUrl":"https://www.meetup.com/aws-user-group-tirupati/events/314845150/","description":"Agenda:\n\n**Session 1:** From Log Hunting to AI-Powered Insights: Building Event-Driven Observability on AWS Serverless by [Sourabh Choubey](https://www.linkedin.com/in/sourabh-choubey/), Lead Application Developer at Schneider\n\n**Abstract:**\nMost teams know when something breaks. Very few know why — quickly.\nThis session walks through a production-grade, event-driven Root Cause Analysis pipeline built entirely on AWS serverless — no third-party APM tools, just CloudWatch, EventBridge, Step Functions, Lambda, and Bedrock working together.\n\nPart 1 — The Foundation: Structured error classification with EMF metrics, typed CloudWatch alarms, and a Composite Alarm that auto-triggers a Step Functions investigation — logs delivered in 90 seconds.\n\nPart 2 — The Brain: Amazon Bedrock plugged into the same pipeline. Two emails land simultaneously — raw logs in \\~10 seconds, AI-generated RCA with root cause, impact, and fix recommendations in \\~30 seconds.\nReal failure scenarios. Real production trade-offs. No guesswork.\n\n**Session 2:** AI Agents with Amazon Bedrock Agentcore by [Pratik Raj](https://www.linkedin.com/in/pratik-raj-20a752159/), Senior Developer at SLS Guru\n\n**Abstract:**\n\n* The talk explores the shift from chatbots to action-oriented, agentic AI\n* Agents are built on an architecture of LLMs, tools, and a Reasoning → Action loop\n* Enterprise adoption requires addressing security, establishing guardrails, and human oversight\n* Amazon Bedrock AgentCore offers secure, serverless environments for persistent agent execution\n* It also discusses Agentcore for web automation and the Strands open-source SDK","isSaved":false,"group":{"__ref":"Group:34534969"},"creatorMember":{"__ref":"Member:275416631"},"eventHosts":[{"__typename":"EventHost","memberId":"275416631"},{"__typename":"EventHost","memberId":"296264333"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-06-13T11:00:00+05:30","createdTime":"2026-05-18T09:54:52-04:00","endTime":"2026-06-13T13:00:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":63},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534297970"},"displayPhoto":{"__ref":"PhotoInfo:534297970"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":63,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071754365"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071754366"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071756799"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071758081"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071769092"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Rsvp:2065921140":{"__typename":"Rsvp","id":"2065921140","member":{"__ref":"Member:275416631"}},"Member:476928638":{"__typename":"Member","id":"476928638","name":"mohitha8412","memberPhoto":null},"Rsvp:2065986459":{"__typename":"Rsvp","id":"2065986459","member":{"__ref":"Member:476928638"}},"PhotoInfo:322719319":{"__typename":"PhotoInfo","id":"322719319","highResUrl":"https://secure.meetupstatic.com/photos/member/9/9/9/7/highres_322719319.jpeg"},"Member:223981248":{"__typename":"Member","id":"223981248","name":"Dev","memberPhoto":{"__ref":"PhotoInfo:322719319"}},"Rsvp:2066147923":{"__typename":"Rsvp","id":"2066147923","member":{"__ref":"Member:223981248"}},"PhotoInfo:323864486":{"__typename":"PhotoInfo","id":"323864486","highResUrl":"https://secure.meetupstatic.com/photos/member/a/d/c/6/highres_323864486.jpeg"},"Member:448622943":{"__typename":"Member","id":"448622943","name":"Sai Karthik ","memberPhoto":{"__ref":"PhotoInfo:323864486"}},"Rsvp:2066267850":{"__typename":"Rsvp","id":"2066267850","member":{"__ref":"Member:448622943"}},"Member:478250791":{"__typename":"Member","id":"478250791","name":"kpmohitha13","memberPhoto":null},"Rsvp:2066326599":{"__typename":"Rsvp","id":"2066326599","member":{"__ref":"Member:478250791"}},"Event:313834973":{"__typename":"Event","id":"313834973","title":"The Cloud Compass: Finding Your Path Through the AWS Ecosystem","eventUrl":"https://www.meetup.com/aws-user-group-tirupati/events/313834973/","description":"Open the AWS Management Console for the first time, and it is easy to feel lost. With over 200 services and a constant stream of new acronyms, most students feel overwhelmed before they even deploy their first instance. It’s tempting to look away, but the reality is that cloud proficiency is no longer \"optional\"; it is the fundamental infrastructure of modern tech.\n\nThis session is designed to strip away the complexity. We’ll talk about why the cloud is the \"need of the hour\" for any aspiring developer and how to filter out the noise to focus on what actually matters. We’ll wrap up with a practical, no-fluff roadmap to the **AWS Certified Cloud Practitioner** exam, giving you a clear entry point into the ecosystem without the information overload.\n\nThis session is in collaboration with the **AWS Cloud Club, SVCE, Tirupati**","isSaved":false,"group":{"__ref":"Group:34534969"},"creatorMember":{"__ref":"Member:275416631"},"eventHosts":[{"__typename":"EventHost","memberId":"275416631"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-03-24T12:00:00+05:30","createdTime":"2026-03-18T11:56:27-04:00","endTime":"2026-03-24T13:00:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":181},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:527476878"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":181,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065921140"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2065986459"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066147923"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066267850"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066326599"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27783660":{"__typename":"Venue","id":"27783660","name":"Mohan Babu University","address":"","city":"Tirupati","state":"","country":"in"},"PhotoInfo:532940847":{"__typename":"PhotoInfo","id":"532940847","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/5/1/6/f/highres_532940847.jpeg"},"Rsvp:2064219132":{"__typename":"Rsvp","id":"2064219132","member":{"__ref":"Member:275416631"}},"Member:475698645":{"__typename":"Member","id":"475698645","name":"Santosh","memberPhoto":null},"Rsvp:2064222016":{"__typename":"Rsvp","id":"2064222016","member":{"__ref":"Member:475698645"}},"Rsvp:2064237237":{"__typename":"Rsvp","id":"2064237237","member":{"__ref":"Member:416791503"}},"Member:420655115":{"__typename":"Member","id":"420655115","name":"Sankarram","memberPhoto":null},"Rsvp:2064239572":{"__typename":"Rsvp","id":"2064239572","member":{"__ref":"Member:420655115"}},"Member:416942010":{"__typename":"Member","id":"416942010","name":"Jaideep T","memberPhoto":null},"Rsvp:2064417928":{"__typename":"Rsvp","id":"2064417928","member":{"__ref":"Member:416942010"}},"Event:313553806":{"__typename":"Event","id":"313553806","title":"Your New Pair Programmer: A Hands-on Kiro Deep Dive","eventUrl":"https://www.meetup.com/aws-user-group-tirupati/events/313553806/","description":"Ever wish you had a senior engineer sitting next to you, helping you navigate complex code and fix bugs in real-time? Welcome to the era of Agentic IDEs.\n\nJoin us on **Saturday, March 7th, at 9:30 AM** for a hands-on workshop featuring **Kiro**, an AI-powered \"agentic\" IDE designed to do more than just autocomplete your - it helps you build entire features.\n\n**What we’ll cover:**\n\n* **Vibe Coding vs. Spec-Driven Development:** Learn how to start with a creative \"vibe\" and then refine it into rigorous technical specifications.\n* **The Architect’s Workflow:** Watch Kiro generate design documents, architecture diagrams, and property-based tests before a single line of application code is written.\n* **Guiding the Agent:** Use \"Steering Docs\" (like Python PEP guides and accessibility standards) to ensure your AI agent follows best practices, not just the easiest path.\n* **The Implementation Loop:** Execute an automated task list, manage \"Agent Hooks,\" and see how to iterate using inline chat and checkpoints.\n\nBy the end of this morning, you won't just have a working app; you’ll have a new mental framework for how to build software in the age of AI agents.\n\n**Prerequisites:**\n1\\. Bring your laptop\\.\n2\\. Sign up for an **AWS Builder ID** (it’s free).\n3\\. Install the **Kiro IDE** before you arrive.\n\n**Bring your laptop and let’s build something together!**","isSaved":false,"group":{"__ref":"Group:34534969"},"creatorMember":{"__ref":"Member:275416631"},"eventHosts":[{"__typename":"EventHost","memberId":"275416631"}],"feeSettings":null,"venue":{"__ref":"Venue:27783660"},"dateTime":"2026-03-07T09:30:00+05:30","createdTime":"2026-02-27T01:57:38-05:00","endTime":"2026-03-07T12:30:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":82},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532940847"},"displayPhoto":{"__ref":"PhotoInfo:532940847"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":82,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064219132"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064222016"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064237237"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064239572"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2064417928"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:532595012":{"__typename":"PhotoInfo","id":"532595012","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/8/8/c/4/highres_532595012.jpeg"},"Rsvp:2062126645":{"__typename":"Rsvp","id":"2062126645","member":{"__ref":"Member:296264333"}},"Rsvp:2062127994":{"__typename":"Rsvp","id":"2062127994","member":{"__ref":"Member:198272601"}},"Rsvp:2062128596":{"__typename":"Rsvp","id":"2062128596","member":{"__ref":"Member:275416631"}},"Member:475806322":{"__typename":"Member","id":"475806322","name":"d.bhargavi","memberPhoto":null},"Rsvp:2062129899":{"__typename":"Rsvp","id":"2062129899","member":{"__ref":"Member:475806322"}},"Member:478057842":{"__typename":"Member","id":"478057842","name":"Hamsini","memberPhoto":null},"Rsvp:2062130231":{"__typename":"Rsvp","id":"2062130231","member":{"__ref":"Member:478057842"}},"Event:313218186":{"__typename":"Event","id":"313218186","title":"Serverless Saturdays - 28th Feb","eventUrl":"https://www.meetup.com/aws-user-group-tirupati/events/313218186/","description":"AWS UG Tirupathi present \"Serverless Saturdays\", a monthly free online meetup series by expert speakers on the latest and best in cloud and AWS!\n\nDate: 28th Feb 2026 (Saturday)\nTime: 11 AM - 1 PM IST\n\n**Agenda:**\n**Session 1:** Stateful Serverless at Last: Checkpoint + Replay Workflows with AWS Lambda **by** [Jaya Ganesh Krishna Moorthy](https://www.linkedin.com/in/jaya-ganesh-k/), Application Developer at Genesys Cloud Services.\n\n**Abstract:**\nAWS Lambda Durable Functions add durable execution to Lambda, so you can write multi-step workflows as normal Python code while Lambda checkpoints progress and replays safely to recover from failures.\n\nIn this session, we’ll build a small but realistic workflow using durable steps and waits (callbacks or approvals, retries, and timeouts) and cover production essentials such as idempotency, safe handling of side effects, and debugging via execution history and structured logs. We’ll also compare Durable Functions with AWS Step Functions, including when workflows as code is the better choice, when a state machine fits better, and the tradeoffs in visibility, integrations, and operations.\n\nYou’ll leave with a practical decision checklist and patterns you can apply immediately.\n\n**Session 2:** Building a Personal AI Assistant with Molt Bot (Clawdbot) and Amazon Nova by **[Amin Ali](https://www.linkedin.com/in/amin-ali/),** Software Engineer at Target Australia\n\n**Abstract:** This session demonstrates how to build a personal AI assistant using Molt Bot (Clawdbot) integrated with Amazon Nova. Attendees will learn how conversational AI can be designed, customized, and deployed to handle real-world tasks such as automation, information retrieval, and user interaction.\nThe talk covers the core components of Molt Bot for creating intelligent conversation flows and shows how Amazon Nova enables scalability, security, and performance in production environments. Through practical examples and architecture walkthroughs, participants will gain insights into building AI assistants without requiring deep machine learning expertise.\nBy the end of the session, attendees will understand the end-to-end process of creating, hosting, and scaling a personal AI assistant that can be adapted for productivity, customer support, or internal automation use cases.","isSaved":false,"group":{"__ref":"Group:34534969"},"creatorMember":{"__ref":"Member:296264333"},"eventHosts":[{"__typename":"EventHost","memberId":"296264333"},{"__typename":"EventHost","memberId":"275416631"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-02-28T11:00:00+05:30","createdTime":"2026-02-05T04:10:28-05:00","endTime":"2026-02-28T13:00:00+05:30","going":{"__typename":"GoingRsvpConnection","totalCount":55},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532595012"},"displayPhoto":{"__ref":"PhotoInfo:532595012"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":55,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062126645"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062127994"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062128596"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062129899"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062130231"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:20479":{"__typename":"Topic","id":"20479","name":"Virtualization","urlkey":"virtualization"},"Topic:15167":{"__typename":"Topic","id":"15167","name":"Cloud Computing","urlkey":"cloud-computing"},"Topic:120095":{"__typename":"Topic","id":"120095","name":"Software Development","urlkey":"software-development"},"Topic:8192":{"__typename":"Topic","id":"8192","name":"Open Source","urlkey":"open-source"},"Topic:788002":{"__typename":"Topic","id":"788002","name":"Web Technology","urlkey":"web-technology"},"Topic:1056672":{"__typename":"Topic","id":"1056672","name":"Big Data","urlkey":"big-data"},"Topic:31197":{"__typename":"Topic","id":"31197","name":"PaaS (Platform as a Service)","urlkey":"paas-platform-as-a-service-"},"Topic:24410":{"__typename":"Topic","id":"24410","name":"High Scalability Computing","urlkey":"high-scalability-computing"},"Topic:33089":{"__typename":"Topic","id":"33089","name":"SaaS (Software as a Service)","urlkey":"saas-software-as-a-service-"},"Topic:44297":{"__typename":"Topic","id":"44297","name":"IaaS (Infrastructure as a Service)","urlkey":"iaas-infrastructure-as-a-service-"},"TopicCategory:546":{"__typename":"TopicCategory","id":"546","name":"Technology","urlkey":"technology"},"PhotoInfo:305672194":{"__typename":"PhotoInfo","id"