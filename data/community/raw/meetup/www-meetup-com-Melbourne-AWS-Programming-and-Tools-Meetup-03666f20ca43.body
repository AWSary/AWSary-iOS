name":"GroupMemberEdge","node":{"__ref":"Member:19578421"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:220123321"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:195980065"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:207620140"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:4072633"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:244737954"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:176247452"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:14179481"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:211158148"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:147606112"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:204875471"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:25647432":{"__typename":"Venue","id":"25647432","name":"Shine Solutions","address":"Level 30, 600 Bourke Street","city":"Melbourne","state":"","country":"au"},"PhotoInfo:534790981":{"__typename":"PhotoInfo","id":"534790981","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/2/a/e/5/highres_534790981.jpeg"},"PhotoInfo:325792442":{"__typename":"PhotoInfo","id":"325792442","highResUrl":"https://secure.meetupstatic.com/photos/member/c/c/d/a/highres_325792442.jpeg"},"Rsvp:2074521762":{"__typename":"Rsvp","id":"2074521762","member":{"__ref":"Member:413240193"}},"PhotoInfo:287387768":{"__typename":"PhotoInfo","id":"287387768","highResUrl":"https://secure.meetupstatic.com/photos/member/b/a/9/8/highres_287387768.jpeg"},"Member:220385186":{"__typename":"Member","id":"220385186","name":"Juntao Zeng","memberPhoto":{"__ref":"PhotoInfo:287387768"}},"Rsvp:2074556417":{"__typename":"Rsvp","id":"2074556417","member":{"__ref":"Member:220385186"}},"PhotoInfo:281644529":{"__typename":"PhotoInfo","id":"281644529","highResUrl":"https://secure.meetupstatic.com/photos/member/1/1/b/1/highres_281644529.jpeg"},"Member:265817893":{"__typename":"Member","id":"265817893","name":"Stefan Derian Hartono","memberPhoto":{"__ref":"PhotoInfo:281644529"}},"Rsvp:2074556505":{"__typename":"Rsvp","id":"2074556505","member":{"__ref":"Member:265817893"}},"Member:481790647":{"__typename":"Member","id":"481790647","name":"Lakshay Arora","memberPhoto":null},"Rsvp:2074556608":{"__typename":"Rsvp","id":"2074556608","member":{"__ref":"Member:481790647"}},"PhotoInfo:325338277":{"__typename":"PhotoInfo","id":"325338277","highResUrl":"https://secure.meetupstatic.com/photos/member/4/7/6/5/highres_325338277.jpeg"},"Member:479447246":{"__typename":"Member","id":"479447246","name":"kirtikasharma5104","memberPhoto":{"__ref":"PhotoInfo:325338277"}},"Rsvp:2074556676":{"__typename":"Rsvp","id":"2074556676","member":{"__ref":"Member:479447246"}},"Event:315298544":{"__typename":"Event","id":"315298544","title":"Intro to RAG with Amazon AgentCore","eventUrl":"https://www.meetup.com/melbourne-aws-programming-and-tools-meetup/events/315298544/","description":"In this hands-on workshop, you'll go from raw embeddings to a fully deployed, production-ready RAG agent on AWS — no prior RAG or AgentCore experience needed.\nWe'll build a real document Q\u0026A system, stage by stage:\n\n* **Basic RAG from scratch** — embed documents yourself with Amazon Titan Text Embeddings V2, store them in a local FAISS index, retrieve with cosine similarity, and generate answers with Claude.\n* **Bedrock Knowledge Bases** — swap the DIY pipeline for a fully managed service that handles chunking, embedding, and indexing (OpenSearch Serverless) from an S3 data source, with hybrid search and metadata filtering. Compare the results against your hand-built version.\n* **AgentCore Agent** — wrap your RAG into a Strands agent, containerize it, push to ECR, and deploy to AgentCore Runtime with session isolation, auto-scaling, and streaming.\n* **Production hardening** — add AgentCore Memory for conversation continuity, instrument with OpenTelemetry for traces in CloudWatch, run a RAG evaluation suite, and expose your knowledge base as a Gateway MCP tool.\n\nBy the end you'll have a deployed, invokable RAG agent on AgentCore Runtime — with memory, full observability, and a real feel for the tradeoffs at every layer, from local FAISS to managed production.\nWhat to bring:\n\n* Laptop with Python 3.11+ (managed via uv) and AWS CLI v2 installed\n* An AWS account\n\nSkill level: Intermediate — some Python and basic AWS familiarity helpful. No prior RAG or agent development experience required.","isSaved":false,"group":{"__ref":"Group:26952502"},"creatorMember":{"__ref":"Member:413240193"},"eventHosts":[{"__typename":"EventHost","memberId":"413240193"}],"feeSettings":null,"venue":{"__ref":"Venue:25647432"},"dateTime":"2026-07-08T18:00:00+10:00","createdTime":"2026-06-17T10:37:10-04:00","endTime":"2026-07-08T20:00:00+10:00","going":{"__typename":"GoingRsvpConnection","totalCount":60},"isOnline":false,"eventType":"PHYSICAL","status":"ACTIVE","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534790981"},"displayPhoto":{"__ref":"PhotoInfo:534790981"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":60,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074521762"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074556417"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074556505"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074556608"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074556676"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Rsvp:2072202367":{"__typename":"Rsvp","id":"2072202367","member":{"__ref":"Member:5467684"}},"PhotoInfo:325368204":{"__typename":"PhotoInfo","id":"325368204","highResUrl":"https://secure.meetupstatic.com/photos/member/b/c/4/c/highres_325368204.jpeg"},"Member:473534188":{"__typename":"Member","id":"473534188","name":"liuzexijeff","memberPhoto":{"__ref":"PhotoInfo:325368204"}},"Rsvp:2072203056":{"__typename":"Rsvp","id":"2072203056","member":{"__ref":"Member:473534188"}},"PhotoInfo:323555208":{"__typename":"PhotoInfo","id":"323555208","highResUrl":"https://secure.meetupstatic.com/photos/member/8/9/8/8/highres_323555208.jpeg"},"Member:474700673":{"__typename":"Member","id":"474700673","name":"ChunHeng","memberPhoto":{"__ref":"PhotoInfo:323555208"}},"Rsvp:2072203060":{"__typename":"Rsvp","id":"2072203060","member":{"__ref":"Member:474700673"}},"PhotoInfo:325345255":{"__typename":"PhotoInfo","id":"325345255","highResUrl":"https://secure.meetupstatic.com/photos/member/6/2/a/7/highres_325345255.jpeg"},"Member:344490482":{"__typename":"Member","id":"344490482","name":"cynthia","memberPhoto":{"__ref":"PhotoInfo:325345255"}},"Rsvp:2072203063":{"__typename":"Rsvp","id":"2072203063","member":{"__ref":"Member:344490482"}},"PhotoInfo:323439410":{"__typename":"PhotoInfo","id":"323439410","highResUrl":"https://secure.meetupstatic.com/photos/member/9/9/f/2/highres_323439410.jpeg"},"Member:470087405":{"__typename":"Member","id":"470087405","name":"shiva Tirupathi Kumar","memberPhoto":{"__ref":"PhotoInfo:323439410"}},"Rsvp:2072203076":{"__typename":"Rsvp","id":"2072203076","member":{"__ref":"Member:470087405"}},"Event:314919288":{"__typename":"Event","id":"314919288","title":"Build Production-Ready AI Agents on AWS with Amazon Bedrock AgentCore","eventUrl":"https://www.meetup.com/melbourne-aws-programming-and-tools-meetup/events/314919288/","description":"In this hands-on workshop, you'll go from zero to a fully deployed multi-agent system on AWS — no prior AgentCore experience needed.\n\nWe'll build a real multi-agent research assistant, step by step:\n\n\\- Deploy your first AI agent using the Strands framework and BedrockAgentCoreApp — running in the cloud in minutes\n\\- Orchestrate multiple agents with the A2A \\(Agent\\-to\\-Agent\\) protocol\\, a cloud\\-agnostic standard that lets agents discover and call each other\nsecurely via IAM\n\\- Connect external tools — wire in PubMed via MCP Gateway\\, deploy a citation manager as a Lambda function\\, and expose your own MCP server\n\nBy the end you'll have a working orchestrator agent that routes queries to a search specialist, calls real APIs, and manages citations — all\nrunning on AgentCore Runtime with proper IAM permissions and CloudWatch observability.\n\nWhat to bring:\n\\- Laptop with Python 3\\.11\\+ and AWS CLI installed\n\\- An AWS account \\(free tier works for most of the workshop\\)\nSkill level: Intermediate — some Python and basic AWS familiarity helpful. No prior agent development experience required.","isSaved":false,"group":{"__ref":"Group:26952502"},"creatorMember":{"__ref":"Member:5467684"},"eventHosts":[{"__typename":"EventHost","memberId":"5467684"}],"feeSettings":null,"venue":{"__ref":"Venue:25647432"},"dateTime":"2026-06-10T18:00:00+10:00","createdTime":"2026-05-22T23:25:10-04:00","endTime":"2026-06-10T20:00:00+10:00","going":{"__typename":"GoingRsvpConnection","totalCount":139},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:484243789"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":139,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072202367"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072203056"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072203060"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072203063"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072203076"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Member:321898699":{"__typename":"Member","id":"321898699","name":"Michael Walmsley","memberPhoto":{"__ref":"PhotoInfo:314607979"}},"Venue:28090476":{"__typename":"Venue","id":"28090476","name":"Mantel Group","address":"Level 2/452 Flinders St, 452 Flinders Street","city":"Melbourne","state":"","country":"AU"},"PhotoInfo:314607979":{"__typename":"PhotoInfo","id":"314607979","highResUrl":"https://secure.meetupstatic.com/photos/member/6/d/4/b/highres_314607979.jpeg"},"Rsvp:2067423074":{"__typename":"Rsvp","id":"2067423074","member":{"__ref":"Member:321898699"}},"Rsvp:2067423078":{"__typename":"Rsvp","id":"2067423078","member":{"__ref":"Member:5467684"}},"PhotoInfo:325647664":{"__typename":"PhotoInfo","id":"325647664","highResUrl":"https://secure.meetupstatic.com/photos/member/6/c/1/0/highres_325647664.jpeg"},"Member:361553486":{"__typename":"Member","id":"361553486","name":"Christina","memberPhoto":{"__ref":"PhotoInfo:325647664"}},"Rsvp:2067434230":{"__typename":"Rsvp","id":"2067434230","member":{"__ref":"Member:361553486"}},"Rsvp:2067436579":{"__typename":"Rsvp","id":"2067436579","member":{"__ref":"Member:413240193"}},"PhotoInfo:325219275":{"__typename":"PhotoInfo","id":"325219275","highResUrl":"https://secure.meetupstatic.com/photos/member/4/b/4/b/highres_325219275.jpeg"},"Member:242902375":{"__typename":"Member","id":"242902375","name":"Prashorst (Eric) Meas","memberPhoto":{"__ref":"PhotoInfo:325219275"}},"Rsvp:2067442727":{"__typename":"Rsvp","id":"2067442727","member":{"__ref":"Member:242902375"}},"Event:314098156":{"__typename":"Event","id":"314098156","title":"End-to-End Observability on EKS: A Hands-On CNCF Workshop","eventUrl":"https://www.meetup.com/melbourne-aws-programming-and-tools-meetup/events/314098156/","description":"🚀 **Build Your Own CNCF Observability Stack: Hands-On Workshop**\n\nJoin us for a practical, end-to-end workshop where you’ll build a modern observability stack from the ground up using industry-standard CNCF tooling.\nIn this session, you will learn to set up metrics with Prometheus, visualize and analyze data with Grafana, instrument your application using OpenTelemetry, and implement distributed tracing with Jaeger. You’ll also apply best practices for collecting, managing, and interpreting telemetry data.\n\nThis is a fully hands-on session, so come ready to build, break, and learn. By the end, you’ll have a working observability stack and a clear understanding of how to instrument and monitor your own applications in real-world environments.\n\n🛠️ No prior observability experience required, but basic familiarity with containers or cloud-native concepts will help.\n\n**A laptop is required to participate.**","isSaved":false,"group":{"__ref":"Group:26952502"},"creatorMember":{"__ref":"Member:321898699"},"eventHosts":[{"__typename":"EventHost","memberId":"31642322"}],"feeSettings":null,"venue":{"__ref":"Venue:28090476"},"dateTime":"2026-05-07T18:30:00+10:00","createdTime":"2026-04-02T20:23:41-04:00","endTime":"2026-05-07T20:30:00+10:00","going":{"__typename":"GoingRsvpConnection","totalCount":81},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:484243789"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":81,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067423074"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067423078"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067434230"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067436579"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067442727"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:28099314":{"__typename":"Venue","id":"28099314","name":"AWS Offices","address":"555 Collins St, Melbourne (AWS Offices) (Level 12 Room 12.204)","city":"Melbourne","state":"","country":"au"},"Rsvp:2063463514":{"__typename":"Rsvp","id":"2063463514","member":{"__ref":"Member:5467684"}},"PhotoInfo:268141077":{"__typename":"PhotoInfo","id":"268141077","highResUrl":"https://secure.meetupstatic.com/photos/member/4/3/5/highres_268141077.jpeg"},"Member:230338586":{"__typename":"Member","id":"230338586","name":"debayan chakrobortty","memberPhoto":{"__ref":"PhotoInfo:268141077"}},"Rsvp:2063464341":{"__typename":"Rsvp","id":"2063464341","member":{"__ref":"Member:230338586"}},"Member:423900603":{"__typename":"Member","id":"423900603","name":"Joshua Mashman","memberPhoto":null},"Rsvp:2063464608":{"__typename":"Rsvp","id":"2063464608","member":{"__ref":"Member:423900603"}},"PhotoInfo:325625246":{"__typename":"PhotoInfo","id":"325625246","highResUrl":"https://secure.meetupstatic.com/photos/member/1/4/7/e/highres_325625246.jpeg"},"Member:210230553":{"__typename":"Member","id":"210230553","name":"Dishit D","memberPhoto":{"__ref":"PhotoInfo:325625246"}},"Rsvp:2063465180":{"__typename":"Rsvp","id":"2063465180","member":{"__ref":"Member:210230553"}},"PhotoInfo:323640069":{"__typename":"PhotoInfo","id":"323640069","highResUrl":"https://secure.meetupstatic.com/photos/member/4/5/highres_323640069.jpeg"},"Member:424923243":{"__typename":"Member","id":"424923243","name":"Sanjana Kailasanathan","memberPhoto":{"__ref":"PhotoInfo:323640069"}},"Rsvp:2063466133":{"__typename":"Rsvp","id":"2063466133","member":{"__ref":"Member:424923243"}},"Event:313442601":{"__typename":"Event","id":"313442601","title":"Pet Store Agent GameDay","eventUrl":"https://www.meetup.com/melbourne-aws-programming-and-tools-meetup/events/313442601/","description":"The Pet Store Agent Quest is an introductory AWS GameDay challenge focused on Agentic AI development using Amazon Bedrock AgentCore and the Strands framework. This Quest is designed to give attendees hands-on experience building and working with AI agents, utilizing prompt engineering and Amazon Q Developer Pro to assist in solving a series of challenges.\nParticipants will build AI agents for a new Virtual Pet Store, creating specialized agents for pet recommendations, care advice, and customer service while implementing appropriate guardrails for responsible AI responses.\n\nAWS GameDay is an interactive, team-based learning opportunity where participants use and expand their AWS skills in a realistic, gamified, risk-free environment. Participants are given an AWS account to share with pre-provisioned infrastructure that they will evolve in response to realistic business and technical requirements designed to challenge them.\n\nTeams will be given 1.5 hours to play through the GameDay and there will be an awards ceremony at the end of the event.\n\n**A laptop is required to participate.**","isSaved":false,"group":{"__ref":"Group:26952502"},"creatorMember":{"__ref":"Member:5467684"},"eventHosts":[{"__typename":"EventHost","memberId":"5467684"}],"feeSettings":null,"venue":{"__ref":"Venue:28099314"},"dateTime":"2026-03-10T17:30:00+11:00","createdTime":"2026-02-20T00:47:07-05:00","endTime":"2026-03-10T19:30:00+11:00","going":{"__typename":"GoingRsvpConnection","totalCount":92},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:484243789"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":92,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063463514"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063464341"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063464608"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063465180"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063466133"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:297804311":{"__typename":"PhotoInfo","id":"297804311","highResUrl":"https://secure.meetupstatic.com/photos/member/5/e/f/7/highres_297804311.jpeg"},"Rsvp:2062011874":{"__typename":"Rsvp","id":"2062011874","member":{"__ref":"Member:31642322"}},"PhotoInfo:323544536":{"__typename":"PhotoInfo","id":"323544536","highResUrl":"https://secure.meetupstatic.com/photos/member/5/f/d/8/highres_323544536.jpeg"},"Member:379742321":{"__typename":"Member","id":"379742321","name":"Tariq AlMoqbil","memberPhoto":{"__ref":"PhotoInfo:323544536"}},"Rsvp:2062012765":{"__typename":"Rsvp","id":"2062012765","member":{"__ref":"Member:379742321"}},"Member:391208502":{"__typename":"Member","id":"391208502","name":"Avijit Singh Macker","memberPhoto":null},"Rsvp:2062012817":{"__typename":"Rsvp","id":"2062012817","member":{"__ref":"Member:391208502"}},"PhotoInfo:199881862":{"__typename":"PhotoInfo","id":"199881862","highResUrl":"https://secure.meetupstatic.com/photos/member/5/5/6/6/highres_199881862.jpeg"},"Member:148245332":{"__typename":"Member","id":"148245332","name":"sudhir kumar","memberPhoto":{"__ref":"PhotoInfo:199881862"}},"Rsvp:2062012832":{"__typename":"Rsvp","id":"2062012832","member":{"__ref":"Member:148245332"}},"PhotoInfo:321808858":{"__typename":"PhotoInfo","id":"321808858","highResUrl":"https://secure.meetupstatic.com/photos/member/7/0/b/a/highres_321808858.jpeg"},"Member:205679359":{"__typename":"Member","id":"205679359","name":"Hazra Ali","memberPhoto":{"__ref":"PhotoInfo:321808858"}},"Rsvp:2062012962":{"__typename":"Rsvp","id":"2062012962","member":{"__ref":"Member:205679359"}},"Event:313199845":{"__typename":"Event","id":"313199845","title":"Kiro Night: Build a Working Agentic App with Kiro","eventUrl":"https://www.meetup.com/melbourne-aws-programming-and-tools-meetup/events/313199845/","description":"AWS Programming and Tools is hosting a special Kiro Night, a practical, fun, and fully hands on learning event focused on the Kiro Agentic IDE.\nThis session is designed to be interactive and engaging, with two learning paths to choose from. A guided path will walk through the fundamentals, while an active path will have you building an application end to end.\n\nWhichever you choose, you will be coding along throughout the session.\nExpect a relaxed, builder friendly atmosphere with food and drinks provided. Perfect for anyone curious about agentic development or looking to learn Kiro in a practical way with the community.\n\nBring your laptop and be ready to get hands on.","isSaved":false,"group":{"__ref":"Group:26952502"},"creatorMember":{"__ref":"Member:31642322"},"eventHosts":[{"__typename":"EventHost","memberId":"31642322"}],"feeSettings":null,"venue":{"__ref":"Venue:25647432"},"dateTime":"2026-02-11T17:30:00+11:00","createdTime":"2026-02-03T22:42:21-05:00","endTime":"2026-02-11T19:30:00+11:00","going":{"__typename":"GoingRsvpConnection","totalCount":42},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:484243789"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":42,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062011874"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062012765"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062012817"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062012832"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062012962"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:120095":{"__typename":"Topic","id":"120095","name":"Software Development","urlkey":"software-development"},"Topic:1516881":{"__typename":"Topic","id":"1516881","name":"NoSQL","urlkey":"nosql"},"Topic:15166":{"__typename":"Topic","id":"15166","name":"EC2","urlkey":"ec2"},"Topic:9696":{"__typename":"Topic","id":"9696","name":"New Technology","urlkey":"new-technology"},"Topic:788002":{"__typename":"Topic","id":"788002","name":"Web Technology","urlkey":"web-technology"},"Topic:15167":{"__typename":"Topic","id":"15167","name":"Cloud Computing","urlkey":"cloud-computing"},"Topic:661712":{"__typename":"Topic","id":"661712","name":"Amazon Web Services","urlkey":"amazon-web-services"},"Topic:24410":{"__typename":"Topic","id":"24410","name":"High Scal