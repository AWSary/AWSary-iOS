er:209116194"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:255325472"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:209388685"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:237415275"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:261116421"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:226044928"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:184991402"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:258609093"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:172053822"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:250771444"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:252607618"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:190857685"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:26906060":{"__typename":"Venue","id":"26906060","name":"Online event","address":"","city":"","state":"","country":""},"PhotoInfo:534305396":{"__typename":"PhotoInfo","id":"534305396","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/1/5/1/4/highres_534305396.jpeg"},"PhotoInfo:321630836":{"__typename":"PhotoInfo","id":"321630836","highResUrl":"https://secure.meetupstatic.com/photos/member/7/8/7/4/highres_321630836.jpeg"},"Rsvp:2070887980":{"__typename":"Rsvp","id":"2070887980","member":{"__ref":"Member:397338204"}},"Rsvp:2070887981":{"__typename":"Rsvp","id":"2070887981","member":{"__ref":"Member:93499232"}},"PhotoInfo:318802606":{"__typename":"PhotoInfo","id":"318802606","highResUrl":"https://secure.meetupstatic.com/photos/member/5/8/4/e/highres_318802606.jpeg"},"Rsvp:2070887982":{"__typename":"Rsvp","id":"2070887982","member":{"__ref":"Member:86571402"}},"PhotoInfo:324031776":{"__typename":"PhotoInfo","id":"324031776","highResUrl":"https://secure.meetupstatic.com/photos/member/7/c/2/0/highres_324031776.jpeg"},"Rsvp:2070887983":{"__typename":"Rsvp","id":"2070887983","member":{"__ref":"Member:448483503"}},"PhotoInfo:321620726":{"__typename":"PhotoInfo","id":"321620726","highResUrl":"https://secure.meetupstatic.com/photos/member/5/0/f/6/highres_321620726.jpeg"},"Member:424494910":{"__typename":"Member","id":"424494910","name":"Raul Galicia","memberPhoto":{"__ref":"PhotoInfo:321620726"}},"Rsvp:2070912393":{"__typename":"Rsvp","id":"2070912393","member":{"__ref":"Member:424494910"}},"Event:314692884":{"__typename":"Event","id":"314692884","title":"🔐 Security \u0026 Compliance in the AI Era","eventUrl":"https://www.meetup.com/amazon-web-services-jalisco/events/314692884/","description":"La Inteligencia Artificial está transformando la manera en que construimos aplicaciones y procesamos datos… pero también está cambiando la forma en que pensamos sobre seguridad, privacidad y compliance. 🤖⚠️\n\nEn esta edición de **AWS User Group Jalisco**, exploraremos algunos de los retos más importantes en torno a la seguridad de sistemas impulsados por IA, el uso responsable de datos y las nuevas superficies de ataque en arquitecturas modernas.\n\n💡 Hablaremos sobre:\n\n* Riesgos y vectores de ataque en sistemas RAG y aplicaciones de IA\n* Privacidad y compliance en entornos HealthTech\n* Uso de embeddings y protección de datos sensibles\n* Buenas prácticas para construir soluciones seguras en AWS\n\n🎤 **Speakers**\n✨ **Carlos Andrés Robles** – *Senior AI Engineer*\n**“RAG Is the New SQL Injection: Data as an Attack Vector and Influence in AI Systems on AWS”**\n✨ **Efra Flores** – *SR Data Engineer \u0026 Profesor Universitario de ML+DL*\n**“HealthTech Compliance: IA, Embeddings y Privacidad de Datos”**\n✨ **Adolfo Cabrera** – *GCP DevOps Engineer*\n**\"From Users to Non-Human Identities: Designing Auth for Agentic Systems\"**\n\n📅 **Fecha:** 28 de mayo\n🕖 **Hora:** 7:00 PM\n💻 **Modalidad:** Online\n\nÚnete a nosotros para conversar sobre cómo construir soluciones de IA más seguras, responsables y preparadas para el futuro 🚀","isSaved":false,"group":{"__ref":"Group:29885341"},"creatorMember":{"__ref":"Member:397338204"},"eventHosts":[{"__typename":"EventHost","memberId":"397338204"},{"__typename":"EventHost","memberId":"93499232"},{"__typename":"EventHost","memberId":"86571402"},{"__typename":"EventHost","memberId":"448483503"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-05-28T19:00:00-06:00","createdTime":"2026-05-08T13:36:17-04:00","endTime":"2026-05-28T22:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":68},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534305396"},"displayPhoto":{"__ref":"PhotoInfo:534305396"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":68,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2070887980"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2070887981"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2070887982"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2070887983"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2070912393"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27901943":{"__typename":"Venue","id":"27901943","name":"Softserve","address":"Av Adolfo López Mateos Nte 2405 - Piso 21 int","city":"GUADALAJARA","state":"","country":"mx"},"PhotoInfo:533023301":{"__typename":"PhotoInfo","id":"533023301","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/a/9/2/5/highres_533023301.jpeg"},"Rsvp:2063893167":{"__typename":"Rsvp","id":"2063893167","member":{"__ref":"Member:397338204"}},"Rsvp:2063893169":{"__typename":"Rsvp","id":"2063893169","member":{"__ref":"Member:93499232"}},"Rsvp:2063893170":{"__typename":"Rsvp","id":"2063893170","member":{"__ref":"Member:86571402"}},"Rsvp:2063893171":{"__typename":"Rsvp","id":"2063893171","member":{"__ref":"Member:448483503"}},"PhotoInfo:312361773":{"__typename":"PhotoInfo","id":"312361773","highResUrl":"https://secure.meetupstatic.com/photos/member/6/e/d/highres_312361773.jpeg"},"Member:257495896":{"__typename":"Member","id":"257495896","name":"Juan","memberPhoto":{"__ref":"PhotoInfo:312361773"}},"Rsvp:2063894294":{"__typename":"Rsvp","id":"2063894294","member":{"__ref":"Member:257495896"}},"Event:313513905":{"__typename":"Event","id":"313513905","title":"Agentes de IA en el Ciclo de Vida de Desarrollo de Software 🤖","eventUrl":"https://www.meetup.com/amazon-web-services-jalisco/events/313513905/","description":"Porque marzo es el mes de **MAR10**, decidimos subir de nivel nuestro próximo meetup 🎮✨\n\nTendremos una edición especial inspirada en Mario Bros, donde exploraremos cómo los **Agentes de IA están transformando el ciclo de vida del desarrollo de software** — desde el código hasta producción.\n\n💡 En esta sesión hablaremos sobre:\n\n* Cómo integrar agentes de IA en el SDLC\n* Automatización inteligente en testing y CI/CD\n* Casos reales en entornos cloud\n* Buenas prácticas para adoptar IA de forma estratégica\n*\n\n🎓 Además, tendremos como invitados especiales al **Club UNIVA**, sumando nuevas mentes builder a nuestra comunidad.\n\n🎤 Speakers: Próximamente por confirmar\n\n🍄 Prepárate para una noche donde combinaremos tecnología, comunidad y un toque gamer — porque siempre es buen momento para hacer *level up* 🚀\n\n📍 SoftServe\n🗓️ 19 de marzo\n🕖 7:00 PM\n\nComo siempre, gracias por ser parte de la comunidad y por seguir construyendo juntos 🚀","isSaved":false,"group":{"__ref":"Group:29885341"},"creatorMember":{"__ref":"Member:397338204"},"eventHosts":[{"__typename":"EventHost","memberId":"397338204"},{"__typename":"EventHost","memberId":"93499232"},{"__typename":"EventHost","memberId":"86571402"},{"__typename":"EventHost","memberId":"448483503"}],"feeSettings":null,"venue":{"__ref":"Venue:27901943"},"dateTime":"2026-03-19T19:00:00-06:00","createdTime":"2026-02-24T18:31:41-05:00","endTime":"2026-03-19T22:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":117},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:533023301"},"displayPhoto":{"__ref":"PhotoInfo:533023301"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":117,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063893167"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063893169"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063893170"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063893171"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2063894294"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":true},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:26675174":{"__typename":"Venue","id":"26675174","name":"Wizeline","address":"Amado Nervo 2200, edificio Esfera Piso 6, Jardines del Sol","city":"Zapopan","state":"","country":"MX"},"PhotoInfo:531114403":{"__typename":"PhotoInfo","id":"531114403","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/d/4/8/3/highres_531114403.jpeg"},"Rsvp:2054044503":{"__typename":"Rsvp","id":"2054044503","member":{"__ref":"Member:397338204"}},"Rsvp:2054044504":{"__typename":"Rsvp","id":"2054044504","member":{"__ref":"Member:93499232"}},"Rsvp:2054044505":{"__typename":"Rsvp","id":"2054044505","member":{"__ref":"Member:86571402"}},"Member:416367901":{"__typename":"Member","id":"416367901","name":"Eduardo Salazar","memberPhoto":null},"Rsvp:2054044507":{"__typename":"Rsvp","id":"2054044507","member":{"__ref":"Member:416367901"}},"PhotoInfo:277072914":{"__typename":"PhotoInfo","id":"277072914","highResUrl":"https://secure.meetupstatic.com/photos/member/c/e/b/2/highres_277072914.jpeg"},"Member:14602410":{"__typename":"Member","id":"14602410","name":"Mario Damian","memberPhoto":{"__ref":"PhotoInfo:277072914"}},"Rsvp:2054078710":{"__typename":"Rsvp","id":"2054078710","member":{"__ref":"Member:14602410"}},"Event:311846675":{"__typename":"Event","id":"311846675","title":"🌩️ Disaster Recovery \u0026 Business Continuity ☁️","eventUrl":"https://www.meetup.com/amazon-web-services-jalisco/events/311846675/","description":"¡Hola, comunidad tech! 🚀\n\nEste **27 de noviembre** te esperamos en **Wizeline** para cerrar el año con un **meetup enfocado en resiliencia, continuidad y recuperación ante desastres en la nube**.\n\nPrepárate para descubrir cómo diseñar infraestructuras sólidas que mantengan tus operaciones seguras, sin importar lo que pase. ⚙️💪\n\n💡 **¿Qué puedes esperar?**\n\n* Estrategias multi-nube para planes de recuperación ante desastres.\n* Casos prácticos sobre continuidad de servicios críticos en AWS.\n* Consejos de arquitectos expertos para mejorar la resiliencia de tus sistemas.\n* Networking con otros profesionales apasionados por la arquitectura cloud. ☁️\n\n🎤 **Speakers**\n\n* **Armando Herra** – *Systems Architect*\n*“The Art of Disaster Recovery: Multi-Cloud DR Strategies”*\n* **Víctor Jiménez** – *Sr. Solutions Architect*\n*“Disaster Recovery para Directory Services en AWS”*\n* **Fabricio Zacarías** – *Senior Software Engineer*\n*“Architecting for Failure: Serverless Resilience in AWS”*\n\n📅 **Fecha:** Jueves, 27 de noviembre de 2025\n📍 **Lugar:** Wizeline\n⏰ **Hora:** 6:30 PM\n\n🔥 Ven a aprender, compartir y conectar con la comunidad sobre cómo asegurar la continuidad del negocio incluso en los escenarios más desafiantes.","isSaved":false,"group":{"__ref":"Group:29885341"},"creatorMember":{"__ref":"Member:397338204"},"eventHosts":[{"__typename":"EventHost","memberId":"397338204"},{"__typename":"EventHost","memberId":"93499232"},{"__typename":"EventHost","memberId":"86571402"}],"feeSettings":null,"venue":{"__ref":"Venue:26675174"},"dateTime":"2025-11-27T18:30:00-06:00","createdTime":"2025-11-03T16:40:45-05:00","endTime":"2025-11-27T21:30:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":57},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:531114403"},"displayPhoto":{"__ref":"PhotoInfo:531114403"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":57,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054044503"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054044504"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054044505"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054044507"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054078710"}}]},"maxTickets":75,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:28166777":{"__typename":"Venue","id":"28166777","name":"The House Café","address":"C. Montreal 1386, Italia Providencia, 44648 Guadalajara, Jal., Mexico","city":"Guadalajara","state":"","country":"mx"},"PhotoInfo:531145968":{"__typename":"PhotoInfo","id":"531145968","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/6/5/7/0/highres_531145968.jpeg"},"Rsvp:2054229976":{"__typename":"Rsvp","id":"2054229976","member":{"__ref":"Member:397338204"}},"Rsvp:2054229978":{"__typename":"Rsvp","id":"2054229978","member":{"__ref":"Member:93499232"}},"Rsvp:2054229981":{"__typename":"Rsvp","id":"2054229981","member":{"__ref":"Member:86571402"}},"Rsvp:2054229982":{"__typename":"Rsvp","id":"2054229982","member":{"__ref":"Member:416367901"}},"Rsvp:2054231190":{"__typename":"Rsvp","id":"2054231190","member":{"__ref":"Member:257495896"}},"Event:311874716":{"__typename":"Event","id":"311874716","title":"🍺Brew the Future | AWS Builders Mixer by Caylent🚀 - REGISTRO EN LUMA REQUERIDO","eventUrl":"https://www.meetup.com/amazon-web-services-jalisco/events/311874716/","description":"​Join us for an evening crafted for **developers, engineers, and cloud architects** shaping the future of AI and automation on AWS.\n​This special edition of our Builders Mixer blends **a technical session** with **a guided craft beer tasting**, creating the perfect mix of learning, inspiration, and authentic connections.\n\n**⚠️⚠️REGISTRO EN [LUMA](https://luma.com/8tjiwtql) NECESARIO⚠️⚠️**\n\n​🧠 **Technical Session: Build and Deploy Agents in Minutes with Strands Agents SDK**\n​Building intelligent agents has traditionally required weeks of work and complex integrations. In this session, discover how **Strands Agents SDK** makes it possible to build and deploy AI agents in just minutes — from your local environment to production on **Amazon Bedrock AgentCore**.\n\n​🍺 **The Experience**\n​After the session, enjoy a **guided craft beer tasting** curated to spark conversations and connections among builders.\nWhether you come to learn, to network, or to share what you’re building, this evening celebrates the builder mindset — Caylent style.\n​**Attendance is limited and curated for active cloud builders.**\n**👉 Apply to join and come brew the future with us.**\n\n## 🗓️ **Agenda**\n\n​**6:30 PM — Welcome \u0026 Check-In**\nKick off the evening with your first beer and casual networking among AWS builders.\n​**7:00 PM — Session: “Build and Deploy Agents in Minutes with Strands Agents SDK”**\nSpeaker: *David Victoria, AWS Community Hero \u0026 Senior Cloud Architect at Caylent*\n​**8:15 PM — Craft Beer Tasting Experience**\nEnjoy a guided tasting session designed to connect innovators and creators in a relaxed atmosphere.\n​**9:00 PM — Networking time!**\nBecause the best ideas often start after a sip. 🍻","isSaved":false,"group":{"__ref":"Group:29885341"},"creatorMember":{"__ref":"Member:397338204"},"eventHosts":[{"__typename":"EventHost","memberId":"397338204"},{"__typename":"EventHost","memberId":"93499232"},{"__typename":"EventHost","memberId":"86571402"}],"feeSettings":null,"venue":{"__ref":"Venue:28166777"},"dateTime":"2025-11-20T18:30:00-06:00","createdTime":"2025-11-05T15:24:00-05:00","endTime":"2025-11-20T22:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":14},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:531145968"},"displayPhoto":{"__ref":"PhotoInfo:531145968"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":14,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054229976"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054229978"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054229981"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054229982"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2054231190"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:9696":{"__typename":"Topic","id":"9696","name":"New Technology","urlkey":"new-technology"},"Topic:788002":{"__typename":"Topic","id":"788002","name":"Web Technology","urlkey":"web-technology"},"Topic:15166":{"__typename":"Topic","id":"15166","name":"EC2","urlkey":"ec2"},"Topic:15167":{"__typename":"Topic","id":"15167","name":"Cloud Computing","urlkey":"cloud-computing"},"Topic:101553":{"__typename":"Topic","id":"101553","name":"Mobile Technology","urlkey":"mobile-technology"},"Topic:1056672":{"__typename":"Topic","id":"1056672","name":"Big Data","urlkey":"big-data"},"Topic:661712":{"__typename":"Topic","id":"661712","name":"Amazon Web Services","urlkey":"amazon-web-services"},"Topic:20479":{"__typename":"Topic","id":"20479","name":"Virtualization","urlkey":"virtualization"},"Topic:24410":{"__typename":"Topic","id":"24410","name":"High Scalability Computing","urlkey":"high-scalability-computing"},"Topic:31197":{"__typename":"Topic","id":"31197","name":"PaaS (Platform as a Service)","urlkey":"paas-platfor