de":{"__ref":"Member:374380476"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:275818683"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:375884735"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:311861175"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:356750815"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:240788970"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:264402499"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:390478412"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:311780555"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:365499446"}}]},"description":"AWS한국사용자모임(AWSKRUG)의 정기 모임 및 소모임 운영 사이트로서 최신 활동 소식 및 행사를 올려드릴 예정입니다. 더 자세한 것은 [https://www.awskr.org](https://www.awskr.org) 를 참고하세요.","video":{"__typename":"GroupVideo","provider":"YOUTUBE","url":"https://www.youtube.com/watch?v=zy8x-5M6LAU"},"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":7,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:315009322"}},{"__typename":"EventEdge","node":{"__ref":"Event:315039832"}},{"__typename":"EventEdge","node":{"__ref":"Event:315050299"}},{"__typename":"EventEdge","node":{"__ref":"Event:314931400"}}]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":815,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:315082322"}},{"__typename":"EventEdge","node":{"__ref":"Event:315068090"}},{"__typename":"EventEdge","node":{"__ref":"Event:312616848"}},{"__typename":"EventEdge","node":{"__ref":"Event:315099275"}}]},"activeTopics":[{"__ref":"Topic:15167"},{"__ref":"Topic:661712"},{"__ref":"Topic:87614"},{"__ref":"Topic:120095"},{"__ref":"Topic:1513353"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[{"__typename":"SponsorEdge","node"