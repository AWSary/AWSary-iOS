s","all":11262,"leadership":63,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.7,"total":3953}},"lat":37.56,"lon":126.99,"joinMode":"OPEN","status":"PAID","city":"Seoul","state":"","country":"kr","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":1},"needsQuestions":false,"needsPhoto":false,"questions":[{"__ref":"GroupQuestion:8309591"},{"__ref":"GroupQuestion:8309590"},{"__ref":"GroupQuestion:8486129"}],"memberDuesSettingsUrl":"https://www.meetup.com/dues/awskrug/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"AWS 한국 사용자 모임(AWSKRUG)에 오신 것을 환영합니다!\u003cbr /\u003e\u003cbr /\u003e본 사이트는 AWS한국사용자모임(AWSKRUG)의 정기 모임 및 소모임 운영 사이트로서 최신 활동 소식 및 행사를 올려드릴 예정입니다. AWSKRUG에서는 분야별 혹은 지역별로 다양한 소모임을 만들어 운영하고 있습니다. 각 소모임을 활성화 하기 위해 아래와 같은 지원 패키지를 준비하였습니다. \u003cbr /\u003e\u003cbr /\u003eAWSKRUG 소모임은 Slack 채널에서 소통하고 있으며, 관심 있는 분들의 많은 참여 바랍니다.\u003cbr /\u003e- 슬랙 채널 가입하기: https://slack.awskr.org/","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:14240645"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:129739692"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:214295322"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:170904932"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:194461433"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:217184134"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:216996214"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:222799421"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:224099023"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:224615907"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:226746503"}},{"__typename":"GroupMemberEdge","nod