t id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"isMobile":false,"showMobileBanner":true,"memberLocale":"en-US","localeMessages":{"organizerUpgradeModal2.upgradeToTier":"Upgrade to {tier}","sendEmailModal.subject":"Subject","sendEmailModal.message":"Message","sendEmailModal.send":"Send","sendEmailModal.cancel":"Cancel","comparisonLikePaywall.continue":"Continue","a11y.skipToContent":"Skip to content","groupHome.title":"{GROUP}","desktopHeader.homepage":"Homepage","desktopSearch.searchEvents":"Search events...","searchLocationTypeahead.placeholder":"Neighborhood, city or zip","searchLocationTypeahead.searchLocationByCityOrZip":"Search for location by city or zip code","groupHomeHeader.coverPhotoAltText":"{NAME} cover photo","groupHomeHeader.proHelp_v3":"This group is in a Meetup Pro network. Network administrators can see member details such as attendance.","groupHomeHeader.proHelpLink":"Learn more","groupHomeHeader.proTitle_v2":"Part of {LINK} - {COUNT, plural, one {# group} other {# groups}}","groupHome.numberOfRatingsPlural":"{COUNT} ratings","groupHomeHeader.membersCount":"{COUNT} members","groupHomeHeader.shareLabel":"Share","shareModal.email":"Email","groupHomeHeader.aboutLink":"About","groupHomeHeader.eventsLink":"Events","groupHomeHeader.membersLink":"Members","groupHomeHeader.photosLink":"Photos","groupHomeHeader.discussionsLink":"Discussions","groupHome.descriptionTitle":"About us","aside.sponsorsTitle":"Sponsors","groupHome.seeAllEventLink":"See all","groupHome.upcomingEventsSectionTitle":"Upcoming events","eventCard.attendeeCount.plural":"{count} attendees","shareButton.eventShareTitle":"Share this event","shareButton.label":"Share event","shareButton.eventShareTitle_v2":"Share","redesign.components.avatar.ariaLabel":"Photo of the user {memberName}","groupHome.pastEventsSectionTitle":"Past events","groupHome.linksTitle":"Group links","aside.messageButton":"Message","aside.organizersTitle":"Organizers","redesign.components.avatar.badgeAriaLabel":"Badge for {memberName}","aside.andOthers":"and {count, plural, one {# other} other {# others}}","shared.organizerIsSuperOrganizer":"{ORGANIZER_NAME} is a \u003cb\u003eSuper Organizer\u003c/b\u003e","aside.seeAll":"See all","aside.membersTitle":"Members","groupHome.networkLinksTitle":"Find us also at","groupHome.topicsTitle":"Related topics","footer.meetupOnFacebook":"Meetup on Facebook","footer.meetupOnTwitter":"Meetup on Twitter","footer.meetupOnYoutube":"Meetup on YouTube","footer.meetupOnInstagram":"Instagram","footer.meetupOnTiktok":"TikTok","footer.thePeoplePlatform":"The \u003cred\u003epeople\u003c/red\u003e platform","footer.createYourOwnMeetupGroup":"Create your own Meetup group","footer.startNewGroup":"Start a new group","footer.yourAccount":"Your account","footer.signUp":"Sign up","footer.logIn":"Log in","footer.help":"Help","footer.discover":"Discover","footer.groups":"Groups","footer.events":"Events","footer.topics":"Topics","footer.cities":"Cities","footer.onlineEvents":"Online events","footer.localGuides":"Local guides","footer.makeFriendsLp":"Make friends","footer.sitemap":"Sitemap","footer.meetupText":"Meetup","footer.about":"About","footer.blog":"Blog","footer.meetupPro":"Meetup Pro","footer.careers":"Careers","footer.apps":"Apps","footer.podcast":"Podcast","footer.followUs":"Follow us","footer.getTheApp":"Get the app","mobileDownloadButtons.downloadFromGooglePlay":"Download app from Google Play","mobileDownloadButtons.downloadFromAppStore":"Download app from App Store","mobileDownloadButtons.downloadOnStore":"Download on","footer.meetupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Terms of service","footer.privacyPolicy":"Privacy policy","footer.cookiePolicy":"Cookie policy","footer.licenseAttribution":"License attribution","footer.madeWithLoveBy":"Made with {love} by"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:302244352":{"__typename":"PhotoInfo","id":"302244352","highResUrl":"https://secure.meetupstatic.com/photos/member/5/f/2/0/highres_302244352.jpeg"},"Member:25258092":{"__typename":"Member","id":"25258092","name":"Geethika Guruge","email":"","memberPhoto":{"__ref":"PhotoInfo:302244352"},"isSuperOrganizer":true},"PhotoInfo:526698161":{"__typename":"PhotoInfo","id":"526698161","highResUrl":"https://secure.meetupstatic.com/photos/event/4/6/f/1/highres_526698161.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Member:257962629":{"__typename":"Member","id":"257962629","name":"Barbora Klusackova","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:319734284"}},"Group:36763991":{"__typename":"Group","id":"36763991","name":"Auckland AWS Tools and Programming","timezone":"Pacific/Auckland","keyGroupPhoto":{"__ref":"PhotoInfo:526698161"},"urlname":"auckland-aws-tools-meetup","isPrivate":false,"organizer":{"__ref":"Member:25258092"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":2017,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.67,"total":261}},"lat":-36.85,"lon":174.76,"joinMode":"OPEN","status":"PAID","city":"Auckland","state":"","country":"nz","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":null,"needsPhoto":null,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/auckland-aws-tools-meetup/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"Thank you for joining my group Auckland AWS tools and Programming. I’m excited to meet you at the next event.","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:25258092"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:257962629"}}]},"description":"Welcome to Auckland AWS Tools and Programming meetup group!\n\nWe're a group of developers, programmers, and other tech professionals passionate about AWS technology. We want to enable the opportunity for our community to come together to learn, discuss and share knowledge about AWS tools and best practices.\n\nThis meetup would include presentations and demos of tools, frameworks and services within the AWS ecosystem, and its focus would be on practical, hands-on learning and knowledge-sharing. The sessions will be interactive, where attendees can participate, share their experiences and collaborate on solutions if they like.\n\nOur thoughts are to cover a wide range of topics, including, but not limited to, infrastructure within AWS, security, migrations, data, serverless, and more.\n\nWe are always looking for new speakers and topics, so if you are interested in presenting or have a suggestion, please let us know!\n\nPlease follow our YouTube channel:\nhttps://www.youtube.com/@auckland-aws-tools-meetup\n\n\\-\\-\\-\n\n**Code of Conduct**\n\n**Purpose**\nAuckland AWS Tools and Programing is dedicated to providing a harassment-free experience for everyone, regardless of gender, gender identity and expression, sexual orientation, disability, physical appearance, body size, race, age, or religion. We do not tolerate harassment of meetup participants in any form.\n\n**Expected Behaviour**\n\n* Be respectful and considerate: Respect the opinions, skills, and abilities of others. Be open to different perspectives and experiences.\n* Be inclusive: Make an effort to include everyone and ensure that everyone has the opportunity to participate.\n* Be collaborative: Work together to build a positive and supportive community.\n* Be mindful of your language: Be kind and positive in your communication. Avoid offensive or inappropriate language.\n* Be aware of your surroundings: Be attentive to how your actions and words may impact others in the meetup environment.\n\n**Unacceptable Behaviour**\n\n* Harassment includes, but is not limited to:\n* Offensive comments related to gender, gender identity and expression, sexual orientation, disability, mental illness, physical appearance, body size, race, age, religion, nationality, regional background or any other protected status.\n* Unwelcome comments regarding a person's lifestyle choices and practices, including those related to food, health, parenting, drugs, and employment.\n* Deliberate misgendering or use of “dead” or rejected names.\n* Gratuitous or off-topic sexual images or behaviour.\n* Physical contact and simulated physical contact (e.g., textual descriptions like \"hug\" or \"backrub\") without consent or after a request to stop.\n* Threats of violence or incitement of violence towards any individual or group, including encouraging a person to commit suicide or to engage in self-harm.\n* Deliberate intimidation.\n* Stalking or following.\n* Harassing photography or recording, including logging online activity for harassment purposes.\n* Sustained disruption of talks or other events.\n* Advocating for or encouraging any of the above behaviour.\n\n**Consequences of Unacceptable Behaviour**\nParticipants who are asked to stop inappropriate behaviour are expected to comply immediately. Meetup organisers may take any appropriate action, up to and including expulsion from the meetup, without warning.\n\n**Reporting Guidelines**\nIf you are subject to or witness unacceptable behaviour or have any other concerns, please notify a meetup organiser as soon as possible. You can do this by:\n\n* Contacting the organisers in person at the event.\n* Sending an email to aucklandawstools@gmail.com.\n\n\n**Acknowledgement**\nBy participating in Auckland AWS Tools and Programing, you agree to abide by this Code of Conduct and accept the consequences of any unacceptable behaviour.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":1,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:315277156"}}]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":34,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:314867587"}},{"__typename":"EventEdge","node":{"__ref":"Event:314253148"}},{"__typename":"EventEdge","node":{"__ref":"Event:313920393"}},{"__typename":"EventEdge","node":{"__ref":"Event:313306685"}}]},"activeTopics":[{"__ref":"Topic:8192"},{"__ref":"Topic:9696"},{"__ref":"Topic:15582"},{"__ref":"Topic:17628"},{"__ref":"Topic:18865"},{"__ref":"Topic:26468"},{"__ref":"Topic:32528"},{"__ref":"Topic:788002"},{"__ref":"Topic:120095"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040498"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7041237"}}]},"foundedDate":"2022-12-06T23:22:08+13:00","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"https://www.youtube.com/@auckland-aws-tools-meetup","url":"https://www.youtube.com/@auckland-aws-tools-meetup","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:25258092"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:199327220"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:229545729"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:58828502"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:358070397"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:112965352"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:373006380"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:148406792"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:370546988"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:278051680"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:215724673"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:378373066"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:242453785"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:377609471"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:11610758"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:251275248"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:55914652"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:27876182":{"__typename":"Venue","id":"27876182","name":"Pushpay Office","address":"Level 19, Vero Centre, 48 Shortland Street, Auckland CBD","city":"Auckland","state":"","country":"nz"},"PhotoInfo:534769192":{"__typename":"PhotoInfo","id":"534769192","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/c/0/2/8/highres_534769192.jpeg"},"PhotoInfo:319734284":{"__typename":"PhotoInfo","id":"319734284","highResUrl":"https://secure.meetupstatic.com/photos/member/d/4/0/c/highres_319734284.jpeg"},"Rsvp:2074380231":{"__typename":"Rsvp","id":"2074380231","member":{"__ref":"Member:257962629"}},"Rsvp:2074380232":{"__typename":"Rsvp","id":"2074380232","member":{"__ref":"Member:25258092"}},"PhotoInfo:323744813":{"__typename":"PhotoInfo","id":"323744813","highResUrl":"https://secure.meetupstatic.com/photos/member/a/f/0/d/highres_323744813.jpeg"},"Member:467505167":{"__typename":"Member","id":"467505167","name":"Carl","memberPhoto":{"__ref":"PhotoInfo:323744813"}},"Rsvp:2074381196":{"__typename":"Rsvp","id":"2074381196","member":{"__ref":"Member:467505167"}},"Member:391097384":{"__typename":"Member","id":"391097384","name":"Sehaj Chawla","memberPhoto":null},"Rsvp:2074381226":{"__typename":"Rsvp","id":"2074381226","member":{"__ref":"Member:391097384"}},"PhotoInfo:325657238":{"__typename":"PhotoInfo","id":"325657238","highResUrl":"https://secure.meetupstatic.com/photos/member/9/1/7/6/highres_325657238.jpeg"},"Member:479856511":{"__typename":"Member","id":"479856511","name":"Dod Ilagan","memberPhoto":{"__ref":"PhotoInfo:325657238"}},"Rsvp:2074381250":{"__typename":"Rsvp","id":"2074381250","member":{"__ref":"Member:479856511"}},"Event:315277156":{"__typename":"Event","id":"315277156","title":"Agentic AI Evaluation on Bedrock: Lessons from Pushpay's Journey","eventUrl":"https://www.meetup.com/auckland-aws-tools-meetup/events/315277156/","description":"Hello everyone,\n\nWe're excited to invite you to the **Auckland AWS Tools and Programming meetup**!\n\nThis month, we are diving deep into the realities of moving AI from a cool demo to a production-ready system. We are thrilled to host two fantastic co-speakers: **[Roger Wang](https://www.linkedin.com/in/roger-nz/)** (Senior Solutions Architect @ AWS) and **[Saurabh Gupta](https://www.linkedin.com/in/nzsaurabh/)** (Pushpay).\n\nWe are gathering once again at the *Pushpay office in the CBD*—looking forward to seeing you all there!\n\n🚨 **Action Required:** To help us streamline building security and sort out the catering (including dietary requirements), please make sure to pre-register before arriving: 👉 **[Pre-register for Venue Check-In Here](https://eventspaces.app/e/build-reliable-agentic-ai-solution-learn-from-pushpay-s-journey-on-agentic-ai-evaluation-f9b80e/register)**\n\n⚠️ *Important Day Change: Please note that we are meeting on a Tuesday this month instead of our usual Thursday slot!*\n\n**🎤 The Lineup**\n**Roger Wang (AWS) \u0026 Saurabh Gupta (Pushpay)**\n\n* **Title:** Breaking Through the 65% Ceiling: How Pushpay Engineered a 95% Accurate Production AI Agent\n* **Description:** Agentic AI plateaus fast once you move beyond demos. Pushpay's natural language search agent hit a \\~65% accuracy ceiling before the team built a structured evaluation framework to break through it.\nRoger and Saurabh will walk through Pushpay's real-world journey: building the agent on **Amazon Bedrock**, why accuracy stalled, and the engineering techniques that pushed it to 95%. They will share practical takeaways including constructing a 300+ query golden dataset, automating measurement with LLM-as-a-Judge, and applying domain-specific prompt engineering on Bedrock. No hype—just real numbers, a real production system, and actionable insights for anyone building or operating agents.\n\n**📍 Venue \u0026 Day Reminder**\n\n* Venue: We are back at the Pushpay office in the Auckland CBD again this month! You can find the address details below.\n* Day Change: Don't forget, we are meeting on Tuesday this time around.\n\n**📅 Event Details**\n\n* When: 5:00 pm on Tuesday, 23rd June 2026 (Note the day change!)\n* Where: Pushpay Office, Level 19, 48 Shortland Street, Auckland\n\n**⏰ Agenda**\n\n* 5:00 pm - Welcome \u0026 Networking\n* 5:30 pm - Presentation \u0026 Deep Dive\n* 6:30 pm - Q\u0026A, Announcements, \u0026 Networking\n\nThis event is proudly supported by **Pushpay**, **Mantel Group**, and **AWS**.\nWe look forward to seeing you there!\n**– The Auckland AWS Tools and Programming Team**\n\n***Code of Conduct***\n*Auckland AWS Tools and Programming is committed to providing a friendly and welcoming space for everyone who attends our meetup events, regardless of gender, gender identity and expression, age, sexual orientation, disability, physical appearance, body size, race, ethnicity, religion (or lack thereof), or technology choices. Any form of harassment, racism, misogyny, or xenophobia is unacceptable. Participants violating these rules will be invited to leave the meetup.*","isSaved":false,"group":{"__ref":"Group:36763991"},"creatorMember":{"__ref":"Member:25258092"},"eventHosts":[{"__typename":"EventHost","memberId":"25258092"},{"__typename":"EventHost","memberId":"257962629"}],"feeSettings":null,"venue":{"__ref":"Venue:27876182"},"dateTime":"2026-06-23T17:00:00+12:00","createdTime":"2026-06-15T18:52:44-04:00","endTime":"2026-06-23T19:00:00+12:00","going":{"__typename":"GoingRsvpConnection","totalCount":100},"isOnline":false,"eventType":"PHYSICAL","status":"ACTIVE","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534769192"},"displayPhoto":{"__ref":"PhotoInfo:534769192"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":100,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074380231"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074380232"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074381196"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074381226"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074381250"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:534319331":{"__typename":"PhotoInfo","id":"534319331","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/4/b/8/3/highres_534319331.jpeg"},"Rsvp:2071904727":{"__typename":"Rsvp","id":"2071904727","member":{"__ref":"Member:25258092"}},"PhotoInfo:299642436":{"__typename":"PhotoInfo","id":"299642436","highResUrl":"https://secure.meetupstatic.com/photos/member/9/8/4/highres_299642436.jpeg"},"Member:311448219":{"__typename":"Member","id":"311448219","name":"Vaibhav Gupta","memberPhoto":{"__ref":"PhotoInfo:299642436"}},"Rsvp:2071906374":{"__typename":"Rsvp","id":"2071906374","member":{"__ref":"Member:311448219"}},"Member:478338035":{"__typename":"Member","id":"478338035","name":"Matt Johnston","memberPhoto":null},"Rsvp:2071907939":{"__typename":"Rsvp","id":"2071907939","member":{"__ref":"Member:478338035"}},"PhotoInfo:223106012":{"__typename":"PhotoInfo","id":"223106012","highResUrl":"https://secure.meetupstatic.com/photos/member/6/5/9/c/highres_223106012.jpeg"},"Member:165228402":{"__typename":"Member","id":"165228402","name":"Wang Laurence","memberPhoto":{"__ref":"PhotoInfo:223106012"}},"Rsvp:2071907969":{"__typename":"Rsvp","id":"2071907969","member":{"__ref":"Member:165228402"}},"Member:475397444":{"__typename":"Member","id":"475397444","name":"levani.ramazashvili90","memberPhoto":null},"Rsvp:2071908035":{"__typename":"Rsvp","id":"2071908035","member":{"__ref":"Member:475397444"}},"Event:314867587":{"__typename":"Event","id":"314867587","title":"From Vibe Coding to Production with the AI Driven Software Life Cycle","eventUrl":"https://www.meetup.com/auckland-aws-tools-meetup/events/314867587/","description":"Hello everyone,\n\nWe're excited to invite you to the May Auckland AWS Tools and Programming meetup!\n\nThis month, we are focusing heavily on the intersection of AI and software engineering. We are thrilled to host two fantastic speakers: [Iain Phillips](https://www.linkedin.com/in/phillipsiain/) (VP of Engineering @ Pushpay) and [Cecilia Yin ](https://www.linkedin.com/in/cecilia-yin)(Solutions Architect @ AWS).\n\nWe are gathering once again at the Pushpay office in the CBD looking forward to seeing you all back there!\n\n**🎤 The Lineup**\n\n**Part 1: Iain Phillips \\| VP of Engineering @ Pushpay**\n\n* **Title:** Look mom, no guardrails! So you \"vibe coded\" a thing? Great. Now, how do we get it to production?\n* **Description:** Everyone's suddenly \"vibe coding\" prototypes in an afternoon, but how do you actually get them to production safely? Join Iain for a frank talk on what it takes to transform an AI-generated demo into a reliable, scalable, and secure enterprise product. Learn how to embrace product contributions from non-engineering roles without compromising on quality, compliance, or security. Get ahead of the curve and discover whose job it really is to harden AI code before your guardrails completely disappear.\n\n**Part 2: Cecilia Yin \\| Solutions Architect @ AWS**\n\n* **Title:** AI Driven Development Life Cycle Reimagining Software Engineering\n* **Description:** The traditional way we build software is changing fast. Join Cecilia for a deep dive into how AI tools are completely reshaping the development lifecycle from the ground up. Whether you are an engineer, an architect, or just curious about the future of tech, come find out how AWS is helping teams navigate this massive shift. Get ahead of the curve and learn how to reinvent your engineering workflow before the old methods leave you behind.\n\n**Important Information**\n\\- 📍 **Venue Reminder:** We are back at the **Pushpay** office in the Auckland CBD again this month! You can find the address details below.\n\n**Event Details:**\n**When**: 5 pm on 28th May 2026\n**Where**: Pushpay Office, Level 19, 48 Shortland Street, Auckland\n\n**Important Check-in Information:** \\\u003e To help us streamline the building check\\-in process on the day and ensure we accommodate everyone's **dietary requirements**, please make sure to pre-register here:\n[Pre-register for Venue Check-In](https://eventspaces.app/e/from-vibe-coding-to-production-with-the-ai-driven-software-life-cycle-bf1479/register)\n\n**Agenda**\n5:00 pm - Welcome \u0026 Networking\n5:30 pm - Food \u0026 beverages\n6:00 pm - Talks\n7:00 pm - Q\u0026A, Announcements, Networking\n\nThis event is proudly supported by Pushpay, Mantel Group, and AWS.\n***We look forward to seeing you there!***\n***Auckland AWS Tools and Programming team***\n\n***Code of Conduct***\n*Auckland AWS Tools and Programming is committed to providing a friendly and welcoming space for everyone who attends our meetup events, regardless of gender, gender identity and expression, age, sexual orientation, disability, physical appearance, body size, race, ethnicity, religion (or lack thereof), or technology choices. Any form of harassment, racism, misogyny, or xenophobia is unacceptable. Participants violating these rules will be invited to leave the meetup.*","isSaved":false,"group":{"__ref":"Group:36763991"},"creatorMember":{"__ref":"Member:25258092"},"eventHosts":[{"__typename":"EventHost","memberId":"25258092"},{"__typename":"EventHost","memberId":"257962629"}],"feeSettings":null,"venue":{"__ref":"Venue:27876182"},"dateTime":"2026-05-28T17:00:00+12:00","createdTime":"2026-05-19T18:57:22-04:00","endTime":"2026-05-28T19:00:00+12:00","going":{"__typename":"GoingRsvpConnection","totalCount":90},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534319331"},"displayPhoto":{"__ref":"PhotoInfo:534319331"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":90,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071904727"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071906374"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071907939"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071907969"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2071908035"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:533695667":{"__typename":"PhotoInfo","id":"533695667","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/d/9/7/3/highres_533695667.jpeg"},"Rsvp:2068344787":{"__typename":"Rsvp","id":"2068344787","member":{"__ref":"Member:25258092"}},"PhotoInfo:324494442":{"__typename":"PhotoInfo","id":"324494442","highResUrl":"https://secure.meetupstatic.com/photos/member/3/8/6/a/highres_324494442.jpeg"},"Member:449478038":{"__typename":"Member","id":"449478038","name":"vishnurgnath94","memberPhoto":{"__ref":"PhotoInfo:324494442"}},"Rsvp:2068345943":{"__typename":"Rsvp","id":"2068345943","member":{"__ref":"Member:449478038"}},"PhotoInfo:305078451":{"__typename":"PhotoInfo","id":"305078451","highResUrl":"https://secure.meetupstatic.com/photos/member/9/6/3/3/highres_305078451.jpeg"},"Member:332741752":{"__typename":"Member","id":"332741752","name":"Wenzhong Hu","memberPhoto":{"__ref":"PhotoInfo:305078451"}},"Rsvp:2068346235":{"__typename":"Rsvp","id":"2068346235","member":{"__ref":"Member:332741752"}},"PhotoInfo:318492203":{"__typename":"PhotoInfo","id":"318492203","highResUrl":"https://secure.meetupstatic.com/photos/member/2/f/a/b/highres_318492203.jpeg"},"Member:192602374":{"__typename":"Member","id":"192602374","name":"Fredy Diaz","memberPhoto":{"__ref":"PhotoInfo:318492203"}},"Rsvp:2068346271":{"__typename":"Rsvp","id":"2068346271","member":{"__ref":"Member:192602374"}},"PhotoInfo:9727458":{"__typename":"PhotoInfo","id":"9727458","highResUrl":"https://secure.meetupstatic.com/photos/member/1/d/2/2/highres_9727458.jpeg"},"Member:4185401":{"__typename":"Member","id":"4185401","name":"taryn","memberPhoto":{"__ref":"PhotoInfo:9727458"}},"Rsvp:2068346606":{"__typename":"Rsvp","id":"2068346606","member":{"__ref":"Member:4185401"}},"Event:314253148":{"__typename":"Event","id":"314253148","title":"The Knowledge Graph Edition: With a Side of Container Security","eventUrl":"https://www.meetup.com/auckland-aws-tools-meetup/events/314253148/","description":"Hello everyone,\n\nWe're excited to invite you to the April Auckland AWS Tools and Programming meetup!\nThis month, we're thrilled to host\n[Stuart Wilson](https://www.linkedin.com/in/stuart-wilson-448588144/) (Principal Engineer @ Pushpay) and [Dinesh Sharma](https://www.linkedin.com/in/dineshsharma2511) (Regional Practice Lead @ Datacom).\n\nThe first part of the night will feature [Stuart](https://www.linkedin.com/in/stuart-wilson-448588144/) speaking on:\n\n**Knowledge is still power: Building your company knowledge graph**\nEveryone's suddenly talking about knowledge graphs, but what are they and how do you get one? Pushpay has been building theirs since before it was cool. Join Stuart for a talk on what they are, why you need one, and a practical live demonstration of how to build one for your company, project, or family. Get ahead of the curve and give your AI-enabled engineers superpowers before the crowd catches up.\n\nThe second part will feature [Dinesh](https://www.linkedin.com/in/dineshsharma2511) speaking on:\n\n**Trust No Image: ECS Supply Chain Security**\nYour container pipeline is only as secure as the images running in it. See how AWS Signer, Lambda, and DevopsAgent work together to bring verified, tamper-proof deployments to ECS.\n\n**Important Information**\n\\- 📍 We're at a **brand new venue** this month — we're guests of Pushpay at their Auckland office! Please note the new address below.\n\n**Event Details:**\n**When**: 5 pm on 23rd April 2026\n**Where**: Pushpay Office, Level 19, 48 Shortland Street, Auckland\n\n**Agenda**\n5:00 pm - Welcome \u0026 Networking\n5:30 pm - Food \u0026 beverages\n6:00 pm - Talks\n7:00 pm - Q\u0026A, Announcements, Networking\n\nThis event is proudly supported by Pushpay, Mantel Group, and AWS.\n***We look forward to seeing you there!***\n***Auckland AWS Tools and Programming team***\n\n***Code of Conduct***\n*Auckland AWS Tools and Programming is committed to providing a friendly and welcoming space for everyone who attends our meetup events, regardless of gender, gender identity and expression, age, sexual orientation, disability, physical appearance, body size, race, ethnicity, religion (or lack thereof), or technology choices. Any form of harassment, racism, misogyny, or xenophobia is unacceptable. Participants violating these rules will be invited to leave the meetup.*","isSaved":false,"group":{"__ref":"Group:36763991"},"creatorMember":{"__ref":"Member:25258092"},"eventHosts":[{"__typename":"EventHost","memberId":"25258092"},{"__typename":"EventHost","memberId":"257962629"}],"feeSettings":null,"venue":{"__ref":"Venue:27876182"},"dateTime":"2026-04-23T17:00:00+12:00","createdTime":"2026-04-12T19:25:10-04:00","endTime":"2026-04-23T19:00:00+12:00","going":{"__typename":"GoingRsvpConnection","totalCount":71},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:533695667"},"displayPhoto":{"__ref":"PhotoInfo:533695667"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":71,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2068344787"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2068345943"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2068346235"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2068346271"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2068346606"}}]},"maxTickets":100,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:25717057":{"__typename":"Venue","id":"25717057","name":"AUT - Room WG126","address":"74 Gov Fitzroy Place","city":"Auckland","state":"","country":"nz"},"PhotoInfo:533356674":{"__typename":"PhotoInfo","id":"533356674","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/4/1/2/2/highres_533356674.jpeg"},"Rsvp:2066416470":{"__typename":"Rsvp","id":"2066416470","member":{"__ref":"Member:257962629"}},"Rsvp:2066416471":{"__typename":"Rsvp","id":"2066416471","member":{"__ref":"Member:25258092"}},"PhotoInfo:324074880":{"__typename":"PhotoInfo","id":"324074880","highResUrl":"https://secure.meetupstatic.com/photos/member/3/a/2/0/highres_324074880.jpeg"},"Member:9806012":{"__typename":"Member","id":"9806012","name":"mark heseltine","memberPhoto":{"__ref":"PhotoInfo:324074880"}},"Rsvp:2066416530":{"__typename":"Rsvp","id":"2066416530","member":{"__ref":"Member:9806012"}},"Member:474761024":{"__typename":"Member","id":"474761024","name":"WayneLiu","memberPhoto":null},"Rsvp:2066418338":{"__typename":"Rsvp","id":"2066418338","member":{"__ref":"Member:474761024"}},"PhotoInfo:324450999":{"__typename":"PhotoInfo","id":"324450999","highResUrl":"https://secure.meetupstatic.com/photos/member/7/9/1/7/highres_324450999.jpeg"},"Member:419498985":{"__typename":"Member","id":"419498985","name":"Gaurav Yadav","memberPhoto":{"__ref":"PhotoInfo:324450999"}},"Rsvp:2066418575":{"__typename":"Rsvp","id":"2066418575","member":{"__ref":"Member:419498985"}},"Event:313920393":{"__typename":"Event","id":"313920393","title":"Beyond Call Centres: Building AI-Powered call centre with Amazon Connect","eventUrl":"https://www.meetup.com/auckland-aws-tools-meetup/events/313920393/","description":"Hello everyone,\n\nThank you for bearing with us! We’ve found a venue for our postponed meetup — great news!\n\nAuckland AWS Tools and Programming is happening on **Thursday, March 26th!**\n\nA special thanks goes to **AUT**, who have kindly provided us with their space!\n\nOur guest speaker is [Kobe Xu,](https://www.linkedin.com/in/kobe-xu/) AWS Community Builder and Specialist Lead at [Deloitte Engineering](https://www.deloitte.com/nz/en.html), who will present a hands-on talk:\n**“Beyond Call Centres: Building an AI‑Powered Call Centre with Amazon Connect.”**\n\n**Important:** This session includes an interactive workshop — please bring your own laptop if you’d like to follow along. Note that deploying the solution may incur some AWS costs depending on your usage. You can review the [Amazon Connect pricing details here](https://aws.amazon.com/connect/pricing/?trk=758059ab-77e5-44fc-8a4a-1be845ee42b9\u0026sc_channel=ps\u0026ef_id=Cj0KCQiA2bTNBhDjARIsAK89wlHZsJbq_jog8CgpPCiwGPc6MH-8fCluclaNaqcEKMELkWKGflurL8kaAkz1EALw_wcB:G:s\u0026s_kwcid=AL!4422!3!798628396283!e!!g!!amazon%20connect%20pricing!23610840676!193043272465\u0026gad_campaignid=23610840676\u0026gbraid=0AAAAADjHtp_klBRzTxcdy3_PNYxO7-bqP\u0026gclid=Cj0KCQiA2bTNBhDjARIsAK89wlHZsJbq_jog8CgpPCiwGPc6MH-8fCluclaNaqcEKMELkWKGflurL8kaAkz1EALw_wcB).\n\n\\*\\*\\*\n**Event details**\n**When:** 5:00 PM – 7:00 PM, Thursday 26 March 2026\n**Where:** WG126 in AUT WG building\n\n**Agenda**\n5:00 PM – Welcome and networking\n5:30 PM – Food and beverages\n6:00 PM – Workshop: ***“Beyond Call Centres: Building an AI‑Powered Call Centre with Amazon Connect”*** – [Kobe Xu](https://www.linkedin.com/in/ACoAACX_96sBtQRzZHDBjApNjP51wgs5VJ_IYEU/) (AWS Community Builder, Specialist Lead at Deloitte Engineering)\n6:45 PM – Q\u0026A, announcements, and networking\n\\*\\*\\*\n\n**About the talk:**\nJoin us for an interactive meetup focused on helping builders, architects, and operations teams get started with Amazon Connect—the cloud contact centre service from AWS.\nIn this session, we’ll explore the fundamentals of launching a modern cloud call centre, from provisioning your first instance to designing intelligent call flows and showcasing AI‑powered voice and chat experiences.\nWhether you’re exploring contact centre modernisation or looking to unlock advanced capabilities like real‑time insights and AI‑assisted agents, this meetup will provide practical guidance, live demos, and real‑world examples to help you get started quickly and confidently.\n\n***We look forward to seeing you there!***\n***Auckland AWS Tools and Programming team***\n\n**How to find us:**\nRoom WG126 is located on Level 1 of the [WG Building](https://www.aut.ac.nz/__data/assets/pdf_file/0011/118919/AUT-campus-map-city.pdf) at the AUT City Campus, situated at 24 St Paul Street, Auckland. It is on the ground-entry floor of the main WG building, which is positioned on the corner of Wakefield and St Paul Streets.\n\n***Code of Conduct***\n*Auckland AWS Tools and Programming is committed to providing a friendly and welcoming space for everyone who attends our meetup events, regardless of gender, gender identity and expression, age, sexual orientation, disability, physical appearance, body size, race, ethnicity, religion (or lack thereof), or technology choices. Any form of harassment, racism, misogyny, or xenophobia is unacceptable. Participants violating these rules will be invited to leave the meetup.*","isSaved":false,"group":{"__ref":"Group:36763991"},"creatorMember":{"__ref":"Member:257962629"},"eventHosts":[{"__typename":"EventHost","memberId":"257962629"},{"__typename":"EventHost","memberId":"25258092"}],"feeSettings":null,"venue":{"__ref":"Venue:25717057"},"dateTime":"2026-03-26T17:00:00+13:00","createdTime":"2026-03-23T21:09:28-04:00","endTime":"2026-03-26T19:00:00+13:00","going":{"__typename":"GoingRsvpConnection","totalCount":22},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:533356674"},"displayPhoto":{"__ref":"PhotoInfo:533356674"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":22,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066416470"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066416471"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066416530"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066418338"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066418575"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27861526":{"__typename":"Venue","id":"27861526","name":"PwC Tower","address":"15 Customs Street West, Auckland CBD, Auckland 1010","city":"Auckland","state":"","country":"nz"},"PhotoInfo:532689615":{"__typename":"PhotoInfo","id":"532689615","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/2/5/8/f/highres_532689615.jpeg"},"Rsvp:2062694040":{"__typename":"Rsvp","id":"2062694040","member":{"__ref":"Member:257962629"}},"Rsvp:2062694042":{"__typename":"Rsvp","id":"2062694042","member":{"__ref":"Member:25258092"}},"Rsvp:2062695142":{"__typename":"Rsvp","id":"2062695142","member":{"__ref":"Member:467505167"}},"Rsvp:2062695261":{"__typename":"Rsvp","id":"2062695261","member":{"__ref":"Member:332741752"}},"PhotoInfo:324942960":{"__typename":"PhotoInfo","id":"324942960","highResUrl":"https://secure.meetupstatic.com/photos/member/a/7/d/0/highres_324942960.jpeg"},"Member:399577877":{"__typename":"Member","id":"399577877","name":"Kingsley Leung","memberPhoto":{"__ref":"PhotoInfo:324942960"}},"Rsvp:2062695484":{"__typename":"Rsvp","id":"2062695484","member":{"__ref":"Member:399577877"}},"Event:313306685":{"__typename":"Event","id":"313306685","title":"Migration Tales — How Atlassian Migrated Jira and Confluence to AWS Graviton","eventUrl":"https://www.meetup.com/auckland-aws-tools-meetup/events/313306685/","description":"**Hello everyone,**\n\nThe Auckland AWS Tools and Programming team is back for an exciting 2026, and we’d love to invite you to our February meetup!\n\nOur first speaker for the new year is [Paulo Almeida](https://www.linkedin.com/in/paulo-almeida-011a058b/), Principal Site Reliability Engineer at [Atlassian](https://www.atlassian.com/), who will present an exciting talk: **“Migration Tales — How Atlassian Migrated Jira and Confluence to AWS Graviton.”**\n\nImportant: Since this meetup will take place at the AWS offices, please remember to bring a valid ID for entry.\n\nThis event is made possible by [Mantel](https://mantelgroup.com.au/) and [AWS](https://aws.amazon.com/?nc2=h_lg).\n\n**Event details**\n**When**: 5:00 PM – 7:00 PM, Thursday 19 February 2026\n**Where**: AWS Office – Training Room, Level 13, PwC Tower, 15 Customs Street West, Auckland CBD\n\n**Agenda**\n**5:00 PM** – Welcome and networking\n**5:30 PM** – Food and beverages\n**6:00 PM** – Talk: **“Migration Tales — How Atlassian Migrated Jira and Confluence to AWS Graviton”** – [Paulo Almeida](https://www.linkedin.com/in/paulo-almeida-011a058b/) (Principal Site Reliability Engineer, Atlassian)\n**6:40 PM** – Q\u0026A, announcements, and networking\n\n**About the talk:**\nWhat happens when you migrate a massive Java-based infrastructure to Graviton and hit unexpected roadblocks? At the scale of Jira and Confluence—spanning over 3,000 instances—the transition reveals unique technical bottlenecks and bugs that only surface under heavy load.\nIn this session, Paulo will share how this migration was made possible, including:\n\n* Scaling pains: The specific hurdles of moving a large, legacy-heavy Java codebase to Graviton.\n* Failures: Why previous attempts failed and what the team did differently to change the outcome.\n* Geeking out: The tools used and the hardware architecture quirks uncovered between Intel and Graviton.\n\nDon’t miss this opportunity to learn the “how” and “why” behind one of the largest Graviton migrations in APAC!\n\n***We look forward to seeing you there!***\n***Auckland AWS Tools and Programming team***\n\n**How to find us:**\nEntry to the PWC building is by the main entrance on Customs Street.\nGo up by the escalators until the end. You will land at the Spectra cafe and PWC reception on the right. Take the lift to level 13.\n\n***Code of Conduct***\n*Auckland AWS Tools and Programming is committed to providing a friendly and welcoming space for everyone who attends our meetup events, regardless of gender, gender identity and expression, age, sexual orientation, disability, physical appearance, body size, race, ethnicity, religion (or lack thereof), or technology choices. Any form of harassment, racism, misogyny, or xenophobia is unacceptable. Participants violating these rules will be invited to leave the meetup.*","isSaved":false,"group":{"__ref":"Group:36763991"},"creatorMember":{"__ref":"Member:257962629"},"eventHosts":[{"__typename":"EventHost","memberId":"257962629"},{"__typename":"EventHost","memberId":"25258092"}],"feeSettings":null,"venue":{"__ref":"Venue:27861526"},"dateTime":"2026-02-19T17:00:00+13:00","createdTime":"2026-02-11T04:28:39-05:00","endTime":"2026-02-19T19:00:00+13:00","going":{"__typename":"GoingRsvpConnection","totalCount":43},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532689615"},"displayPhoto":{"__ref":"PhotoInfo:532689615"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":43,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062694040"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062694042"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062695142"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062695261"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2062695484"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:8192":{"__typename":"Topic","id":"8192","name":"Open Source","urlkey":"open-source"},"Topic:9696":{"__typename":"Topic","id":"9696","name":"New Technology","urlkey":"new-technology"},"Topic:15582":{"__typename":"Topic","id":"15582","name":"Web Development","urlkey":"web-development"},"Topic:17628":{"__typename":"Topic","id":"17628","name":"Programming Languages","urlkey":"programming-languages"},"Topic:18865":{"__typename":"Topic","id":"18865","name":"Technology","urlkey":"technology"},"Topic:26468":{"__typename":"Topic","id":"26468","name":"Software Architecture","urlkey":"software-architecture"},"Topic:32528":{"__typename":"Topic","id":"32528","name":"Computer Programming","urlkey":"computer-programming"},"Topic:788002":{"__typename":"Topic","id":"788002","name":"Web Technology","urlkey":"web-technology"},"Topic:120095":{"__typename":"Topic","id":"120095","name":"Software Development","urlkey":"software-development"},"TopicCategory:546":{"__typename":"TopicCategory","id":"546","name":"Technology","urlkey":"technology"},"PhotoInfo:2749369":{"__typename":"PhotoInfo","id":"2749369","standardUrl":"https://secure.meetupstatic.com/photos/sponsor/c/0/d/9/iab120x90_2749369.jpeg"},"Sponsor:ch7040498":{"__typename":"Sponsor","id":"ch7040498","name":"Amazon Web Services","description":"AWS Tools and Programming sponsor.","url":"https://aws.amazon.com/","logoPhoto":{"__ref":"PhotoInfo:2749369"}},"PhotoInfo:2750602":{"__typename":"PhotoInfo","id":"2750602","standardUrl":"https://secure.meetupstatic.com/photos/sponsor/c/5/a/a/iab120x90_2750602.jpeg"},"Sponsor:ch7041237":{"__typename":"Sponsor","id":"ch7041237","name":"Mantel","description":"AWS Tools and Programming sponsor.","url":"https://mantelgroup.com.au","logoPhoto":{"__ref":"PhotoInfo:2750602"}},"PhotoInfo:298155122":{"__typename":"PhotoInfo","id":"298155122","highResUrl":"https://secure.meetupstatic.com/photos/member/3/b/1/2/highres_298155122.jpeg"},"Member:199327220":{"__typename":"Member","id":"199327220","name":"Ali","memberPhoto":{"__ref":"PhotoInfo:298155122"}},"PhotoInfo:321746544":{"__typename":"PhotoInfo","id":"321746544","highResUrl":"https://secure.meetupstatic.com/photos/member/6/7/b/0/highres_321746544.jpeg"},"Member:229545729":{"__typename":"Member","id":"229545729","name":"Suzana Melo","memberPhoto":{"__ref":"PhotoInfo:321746544"}},"PhotoInfo:297838984":{"__typename":"PhotoInfo","id":"297838984","highResUrl":"https://secure.meetupstatic.com/photos/member/e/6/6/8/highres_297838984.jpeg"},"Member:58828502"