ypename":"PhotoInfo","id":"177211622","highResUrl":"https://secure.meetupstatic.com/photos/member/7/b/8/6/highres_177211622.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:132991972":{"__typename":"Member","id":"132991972","name":"Jesus Guevara Pinedo","memberPhoto":{"__ref":"PhotoInfo:177211622"}},"Rsvp:2067486238":{"__typename":"Rsvp","id":"2067486238","member":{"__ref":"Member:132991972"}},"PhotoInfo:318423576":{"__typename":"PhotoInfo","id":"318423576","highResUrl":"https://secure.meetupstatic.com/photos/member/d/f/8/highres_318423576.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:256419402":{"__typename":"Member","id":"256419402","name":"David Sol","memberPhoto":{"__ref":"PhotoInfo:318423576"}},"Rsvp:2067502288":{"__typename":"Rsvp","id":"2067502288","member":{"__ref":"Member:256419402"}},"PhotoInfo:245526142":{"__typename":"PhotoInfo","id":"245526142","highResUrl":"https://secure.meetupstatic.com/photos/member/1/7/f/e/highres_245526142.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:185531423":{"__typename":"Member","id":"185531423","name":"Jose Ramos","memberPhoto":{"__ref":"PhotoInfo:245526142"}},"Rsvp:2067534791":{"__typename":"Rsvp","id":"2067534791","member":{"__ref":"Member:185531423"}},"PhotoInfo:300387955":{"__typename":"PhotoInfo","id":"300387955","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/6/d/3/3/highres_300387955.jpeg"},"PhotoInfo:243255207":{"__typename":"PhotoInfo","id":"243255207","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/3/b/6/7/highres_243255207.jpeg"},"PhotoInfo:325253104":{"__typename":"PhotoInfo","id":"325253104","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/c/f/7/0/highres_325253104.jpeg"},"Event:314107575":{"__typename":"Event","id":"314107575","title":"Meetup #7 Serverless en la playa: Lambda Durable Functions","eventUrl":"https://www.meetup.com/es-ES/aws-user-group-cancun/events/314107575/","description":"¡Estás invitado a nuestro próximo AWS Meetup! Descubre cómo Lambda, Lambda Durable Functions y Step Functions ofrecen una solución para cada tipo de problema.\n\nLambda Durable Functions es una nueva innovación de AWS para ayudarnos en nuestros desarrollos. Con ella podemos resolver nuestras necesidades con el poder de serverless, aprovechando sus ventajas en términos de costo, simplicidad, velocidad y escalamiento.\nLambda, Lambda Durable Function y Step Functions: ¿En qué son similares? ¿En qué son diferentes? ¿Cuándo se debe utilizar cada una de ellas?\n¡No te pierdas la oportunidad de aprender y conectar con entusiastas de AWS! Ven, comparte tus ideas y llevemos juntos tus habilidades en serverless al siguiente nivel.","isSaved":false,"group":{"__ref":"Group:37793270"},"creatorMember":{"__ref":"Member:174526172"},"eventHosts":[{"__typename":"EventHost","memberId":"174526172"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-04-16T20:00:00-06:00","createdTime":"2026-04-03T12:13:44-04:00","endTime":"2026-04-16T21:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":9},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:527241414"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":9,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067480373"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067480610"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067486238"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067502288"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067534791"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":{"__typename":"SocialProofInsights","isTrendingEvent":false,"totalInterestedUsers":33,"interestedUsersSample":[{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:324987798"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:177211622"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:318423576"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:245526142"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:300387955"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:243255207"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:325253104"}}]}},"PhotoInfo:532371728":{"__typename":"PhotoInfo","id":"532371728","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/c/a/1/0/highres_532371728.jpeg"},"Rsvp:2060823042":{"__typename":"Rsvp","id":"2060823042","member":{"__ref":"Member:156769882"}},"Rsvp:2060823043":{"__typename":"Rsvp","id":"2060823043","member":{"__ref":"Member:469259855"}},"Rsvp:2060823044":{"__typename":"Rsvp","id":"2060823044","member":{"__ref":"Member:174526172"}},"PhotoInfo:274474951":{"__typename":"PhotoInfo","id":"274474951","highResUrl":"https://secure.meetupstatic.com/photos/member/8/8/8/7/highres_274474951.jpeg"},"Rsvp:2060823045":{"__typename":"Rsvp","id":"2060823045","member":{"__ref":"Member:247601262"}},"PhotoInfo:324891478":{"__typename":"PhotoInfo","id":"324891478","highResUrl":"https://secure.meetupstatic.com/photos/member/c/9/1/6/highres_324891478.jpeg"},"Member:250797109":{"__typename":"Member","id":"250797109","name":"Ernesto Lázaro","memberPhoto":{"__ref":"PhotoInfo:324891478"}},"Rsvp:2060838415":{"__typename":"Rsvp","id":"2060838415","member":{"__ref":"Member:250797109"}},"Event:313001045":{"__typename":"Event","id":"313001045","title":"📣 Meetup #6: Cloud Foundations","eventUrl":"https://www.meetup.com/es-ES/aws-user-group-cancun/events/313001045/","description":"En esta charla exploraremos los fundamentos de la computación en la nube, entendiendo los conceptos clave que sirven como base para trabajar con servicios modernos en AWS y otros proveedores cloud.\nHablaremos sobre:\nQué es realmente cloud y qué no lo es\nPrincipios básicos como infraestructura, escalabilidad, alta disponibilidad y costos\nCómo pensar en cloud más allá de servidores y máquinas virtuales\nErrores comunes al dar los primeros pasos en la nube\nEsta charla está pensada para personas que están iniciando en cloud, estudiantes, desarrolladores que quieren entender mejor el ecosistema, y profesionales que buscan construir una base sólida antes de profundizar en servicios específicos.\nUn buen punto de partida para cualquiera que quiera comprender cómo funciona la nube y por qué se diseñan las arquitecturas modernas de la forma en que las vemos hoy.","isSaved":false,"group":{"__ref":"Group:37793270"},"creatorMember":{"__ref":"Member:156769882"},"eventHosts":[{"__typename":"EventHost","memberId":"156769882"},{"__typename":"EventHost","memberId":"469259855"},{"__typename":"EventHost","memberId":"174526172"},{"__typename":"EventHost","memberId":"247601262"}],"feeSettings":null,"venue":{"__ref":"Venue:26906060"},"dateTime":"2026-02-19T20:00:00-06:00","createdTime":"2026-01-22T01:31:12-05:00","endTime":"2026-02-19T21:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":12},"isOnline":true,"eventType":"ONLINE","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:532371728"},"displayPhoto":{"__ref":"PhotoInfo:532371728"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":12,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2060823042"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2060823043"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2060823044"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2060823045"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2060838415"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"PhotoInfo:531625361":{"__typename":"PhotoInfo","id":"531625361","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/6/3/1/1/highres_531625361.jpeg"},"Rsvp:2056737844":{"__typename":"Rsvp","id":"2056737844","member":{"__ref":"Member:156769882"}},"PhotoInfo:321367142":{"__typename":"PhotoInfo","id":"321367142","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/1/b/e/6/highres_321367142.jpeg"},"PhotoInfo:267067590":{"__typename":"PhotoInfo","id":"267067590","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/1/d/a/6/highres_267067590.jpeg"},"PhotoInfo:321518064":{"__typename":"PhotoInfo","id":"321518064","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/9/4/b/0/highres_321518064.jpeg"},"PhotoInfo:321343554":{"__typename":"PhotoInfo","id":"321343554","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/a/a/2/2/highres_321343554.jpeg"},"PhotoInfo:299178854":{"__typename":"PhotoInfo","id":"299178854","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/4/9/a/6/highres_299178854.jpeg"},"PhotoInfo:280134395":{"__typename":"PhotoInfo","id":"280134395","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/d/4/7/b/highres_280134395.jpeg"},"PhotoInfo:321410703":{"__typename":"PhotoInfo","id":"321410703","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/c/6/0/f/highres_321410703.jpeg"},"Event:312309105":{"__typename":"Event","id":"312309105","title":"📣 Meetup #5: “AWS para Desarrolladores Mobile – Parte 1: Amplify y Cognito”","eventUrl":"https://www.meetup.com/es-ES/aws-user-group-cancun/events/312309105/","description":"En esta primera sesión de una serie dedicada a AWS para desarrollo móvil, vamos a enfocarnos en dos de las herramientas más importantes para crear apps modernas, seguras y escalables: AWS Amplify y Amazon Cognito. El objetivo es entender qué resuelven, cómo integrarlos correctamente en apps Android, iOS y Flutter y cuándo conviene usarlos según la arquitectura de tu proyecto.\n\nhttps://www.youtube.com/watch?v=kwRTcN-RmSM","isSaved":false,"group":{"__ref":"Group:37793270"},"creatorMember":{"__ref":"Member:156769882"},"eventHosts":[{"__typename":"EventHost","memberId":"156769882"}],"feeSettings":null,"venue":null,"dateTime":"2025-12-17T22:00:00-06:00","createdTime":"2025-12-04T20:53:35-05:00","endTime":"2025-12-17T23:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":1},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:531625361"},"displayPhoto":{"__ref":"PhotoInfo:531625361"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":1,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2056737844"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":{"__typename":"SocialProofInsights","isTrendingEvent":false,"totalInterestedUsers":28,"interestedUsersSample":[{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:321367142"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:267067590"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:321518064"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:321343554"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:299178854"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:280134395"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:321410703"}}]}},"PhotoInfo:531397421":{"__typename":"PhotoInfo","id":"531397421","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/9/2/2/d/highres_531397421.jpeg"},"Rsvp:2055444720":{"__typename":"Rsvp","id":"2055444720","member":{"__ref":"Member:156769882"}},"Rsvp:2055444721":{"__typename":"Rsvp","id":"2055444721","member":{"__ref":"Member:469259855"}},"Rsvp:2055444722":{"__typename":"Rsvp","id":"2055444722","member":{"__ref":"Member:174526172"}},"Rsvp:2055444723":{"__typename":"Rsvp","id":"2055444723","member":{"__ref":"Member:247601262"}},"Member:471994675":{"__typename":"Member","id":"471994675","name":"daniel.maldonado","memberPhoto":null},"Rsvp:2055470656":{"__typename":"Rsvp","id":"2055470656","member":{"__ref":"Member:471994675"}},"Event:312075387":{"__typename":"Event","id":"312075387","title":"Meetup #4 Kit de supervivencia zombie SQL","eventUrl":"https://www.meetup.com/es-ES/aws-user-group-cancun/events/312075387/","description":"**“Kit de supervivencia zombie SQL”**\nUna sesión donde hablaremos de todo lo que un desarrollador necesita para sobrevivir cuando la base de datos empieza a comportarse como un apocalipsis zombie:\nconsultas lentas, índices rotos, locks interminables, anomalías en transacciones, y esos momentos donde el CPU se va al 100% y parece que la infraestructura pide auxilio en morse.\n💡 **¿Qué veremos?**\n\n* Cómo identificar señales tempranas del “outbreak” en tu base de datos\n* Consultas que te salvan la vida (literal… de tu servicio)\n* Trucos para optimizar sin romper nada\n* Qué hacer cuando *ya todo se rompió*\n* Buenas prácticas para que tu sistema no muera… o para revivirlo\n\nIdeal para developers, data engineers, DBAs, estudiantes y cualquiera que quiera agregar armas a su arsenal técnico para sobrevivir en el día a día del software.\n\n📍 **Lugar:** Online https://www.youtube.com/watch?v=GAkSx4Du5z4\n📅 **Fecha:** 18 Diciembre\n⏰ **Hora:** 20:00 hrs Cancun y 19:00 hrs CDMX\nVen a aprender, reír, compartir y seguir haciendo grande la comunidad tech de Cancún. 🚀\n¡Te esperamos!","isSaved":false,"group":{"__ref":"Group:37793270"},"creatorMember":{"__ref":"Member:156769882"},"eventHosts":[{"__typename":"EventHost","memberId":"156769882"},{"__typename":"EventHost","memberId":"469259855"},{"__typename":"EventHost","memberId":"174526172"},{"__typename":"EventHost","memberId":"247601262"}],"feeSettings":null,"venue":null,"dateTime":"2025-12-10T19:00:00-06:00","createdTime":"2025-11-18T22:42:59-05:00","endTime":"2025-12-10T20:00:00-06:00","going":{"__typename":"GoingRsvpConnection","totalCount":15},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:531397421"},"displayPhoto":{"__ref":"PhotoInfo:531397421"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":15,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2055444720"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2055444721"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2055444722"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2055444723"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2055470656"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:18865":{"__typename":"Topic","id":"18865","name":"Tecnología","urlkey":"technology"},"Topic:21355":{"__typename":"Topic","id":"21355","name":"Desarrollo móvil","urlkey":"mobile-development"},"Topic:37381":{"__typename":"Topic","id":"37381","name":"Visualización de datos","urlkey":"data-visualization"},"Topic:43601":{"__typename":"Topic","id":"43601","nam