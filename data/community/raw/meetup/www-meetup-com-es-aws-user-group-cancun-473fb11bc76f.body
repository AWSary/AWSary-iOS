etupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Condiciones del servicio","footer.privacyPolicy":"Política de privacidad","footer.cookiePolicy":"Política de cookies","footer.licenseAttribution":"Atribución de licencia","footer.madeWithLoveBy":"Hecho con {love} por"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:211762742":{"__typename":"PhotoInfo","id":"211762742","highResUrl":"https://secure.meetupstatic.com/photos/member/5/8/d/6/highres_211762742.jpeg"},"Member:156769882":{"__typename":"Member","id":"156769882","name":"José D. Luján","email":"","memberPhoto":{"__ref":"PhotoInfo:211762742"},"isSuperOrganizer":false},"PhotoInfo:527241414":{"__typename":"PhotoInfo","id":"527241414","highResUrl":"https://secure.meetupstatic.com/photos/event/5/3/a/6/highres_527241414.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Member:174526172":{"__typename":"Member","id":"174526172","name":"Josué Hernández","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:324454972"}},"Member:247601262":{"__typename":"Member","id":"247601262","name":"Noemi Leon","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:274474951"}},"Member:469259855":{"__typename":"Member","id":"469259855","name":"Nancy Aguas","isSuperOrganizer":false,"memberPhoto":null},"Group:37793270":{"__typename":"Group","id":"37793270","name":"AWS User Group Cancun","timezone":"America/Mexico_City","keyGroupPhoto":{"__ref":"PhotoInfo:527241414"},"urlname":"aws-user-group-cancun","isPrivate":false,"organizer":{"__ref":"Member:156769882"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":160,"leadership":4,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.83,"total":6}},"lat":16.92,"lon":-92.48,"joinMode":"OPEN","status":"PAID","city":"Cancun","state":"","country":"mx","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":null,"needsPhoto":null,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-cancun/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:156769882"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:174526172"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:247601262"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:469259855"}}]},"description":"¡Bienvenidos al AWS User Group Cancún!🐢 🌴\n\nSomos una comunidad vibrante de profesionales, entusiastas y curiosos apasionados por la nube y Amazon Web Services (AWS). Nos reunimos regularmente en Cancún para aprender juntos, compartir conocimientos y experiencias sobre AWS, y divertirnos mientras exploramos el poder de la tecnología en la nube.\n\nEste grupo está abierto a todos, ya seas desarrollador, administrador de sistemas, líder empresarial o estudiante. No importa si apenas estás comenzando con AWS o si ya eres un experto, ¡hay algo para todos en nuestra comunidad!\n\nEn nuestros eventos encontrarás charlas, talleres, demostraciones y oportunidades para hacer networking con otros entusiastas de AWS. Además, nos mantenemos actualizados con las últimas tendencias y novedades de AWS, y compartimos recursos para que todos puedan mejorar sus habilidades y conocimientos.\n\nÚnete a nosotros para conectar con otros expertos en la nube, ampliar tu red profesional y aprender de una manera divertida. ¡Te esperamos en nuestro próximo evento en el paraíso de Cancún! 🌊🌞","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":7,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:314107575"}},{"__typename":"EventEdge","node":{"__ref":"Event:313001045"}},{"__typename":"EventEdge","node":{"__ref":"Event:312309105"}},{"__typename":"EventEdge","node":{"__ref":"Event:312075387"}}]},"activeTopics":[{"__ref":"Topic:18865"},{"__ref":"Topic:21355"},{"__ref":"Topic:37381"},{"__ref":"Topic:43601"},{"__ref":"Topic:78565"},{"__ref":"Topic:108403"},{"__ref":"Topic:128595"},{"__ref":"Topic:584902"},{"__ref":"Topic:661712"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[]},"foundedDate":"2024-10-17T19:24:49-06:00","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"","url":"","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:156769882"}},{"__typename":"GroupMemberEdge","