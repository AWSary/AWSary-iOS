otos","groupHomeHeader.discussionsLink":"Discussions","groupHome.descriptionTitle":"About us","aside.seeAll":"See all","aside.sponsorsTitle":"Sponsors","groupHome.seeAllEventLink":"See all","groupHome.upcomingEventsSectionTitle":"Upcoming events","eventCard.attendeeCount.plural":"{count} attendees","shareButton.eventShareTitle":"Share this event","shareButton.label":"Share event","shareButton.eventShareTitle_v2":"Share","redesign.components.avatar.ariaLabel":"Photo of the user {memberName}","groupHome.pastEventsSectionTitle":"Past events","groupHome.linksTitle":"Group links","aside.messageButton":"Message","aside.organizersTitle":"Organizers","aside.andOthers":"and {count, plural, one {# other} other {# others}}","aside.membersTitle":"Members","groupHome.networkLinksTitle":"Find us also at","groupHome.socialLinkedinBtn":"LinkedIn","groupHome.topicsTitle":"Related topics","footer.meetupOnFacebook":"Meetup on Facebook","footer.meetupOnTwitter":"Meetup on Twitter","footer.meetupOnYoutube":"Meetup on YouTube","footer.meetupOnInstagram":"Instagram","footer.meetupOnTiktok":"TikTok","footer.thePeoplePlatform":"The \u003cred\u003epeople\u003c/red\u003e platform","footer.createYourOwnMeetupGroup":"Create your own Meetup group","footer.startNewGroup":"Start a new group","footer.yourAccount":"Your account","footer.signUp":"Sign up","footer.logIn":"Log in","footer.help":"Help","footer.discover":"Discover","footer.groups":"Groups","footer.events":"Events","footer.topics":"Topics","footer.cities":"Cities","footer.onlineEvents":"Online events","footer.localGuides":"Local guides","footer.makeFriendsLp":"Make friends","footer.sitemap":"Sitemap","footer.meetupText":"Meetup","footer.about":"About","footer.blog":"Blog","footer.meetupPro":"Meetup Pro","footer.careers":"Careers","footer.apps":"Apps","footer.podcast":"Podcast","footer.followUs":"Follow us","footer.getTheApp":"Get the app","mobileDownloadButtons.downloadFromGooglePlay":"Download app from Google Play","mobileDownloadButtons.downloadFromAppStore":"Download app from App Store","mobileDownloadButtons.downloadOnStore":"Download on","footer.meetupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Terms of service","footer.privacyPolicy":"Privacy policy","footer.cookiePolicy":"Cookie policy","footer.licenseAttribution":"License attribution","footer.madeWithLoveBy":"Made with {love} by"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:325664971":{"__typename":"PhotoInfo","id":"325664971","highResUrl":"https://secure.meetupstatic.com/photos/member/a/f/a/b/highres_325664971.jpeg"},"Member:236906297":{"__typename":"Member","id":"236906297","name":"Damien Jones","email":"","memberPhoto":{"__ref":"PhotoInfo:325664971"},"isSuperOrganizer":false},"PhotoInfo:525286834":{"__typename":"PhotoInfo","id":"525286834","highResUrl":"https://secure.meetupstatic.com/photos/event/b/6/f/2/highres_525286834.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"PhotoInfo:320914479":{"__typename":"PhotoInfo","id":"320914479","highResUrl":"https://secure.meetupstatic.com/photos/member/8/6/a/f/highres_320914479.jpeg"},"ProNetwork:1121475507299876864":{"__typename":"ProNetwork","id":"1121475507299876864","urlname":"global-aws-user-group-community","name":"Global AWS User Group Community","logo":{"__ref":"PhotoInfo:320914479"},"groups":{"__typename":"ProNetworkGroupsConnection","totalCount":392}},"Member:387299743":{"__typename":"Member","id":"387299743","name":"Cat Mawdsley","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:319555437"}},"Group:37846811":{"__typename":"Group","id":"37846811","name":"AWS User Group Lancashire","timezone":"Europe/London","keyGroupPhoto":{"__ref":"PhotoInfo:525286834"},"urlname":"aws-user-group-lancashire","isPrivate":false,"organizer":{"__ref":"Member:236906297"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":174,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.83,"total":6}},"lat":53.8,"lon":-2.26,"joinMode":"OPEN","status":"PAID","city":"Burnley","state":"H2","country":"gb","proNetwork":{"__ref":"ProNetwork:1121475507299876864"},"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":1},"needsQuestions":null,"needsPhoto":null,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/aws-user-group-lancashire/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:236906297"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387299743"}}]},"description":"Welcome to AWS User Group Lancashire! This community welcomes anyone enthusiastic about Amazon Web Services (AWS), cloud computing or technology in general, whether you're an experienced user or just starting out.\n\nOur aim is to bring together developers, architects, SysOps professionals, business leaders, and enthusiasts to learn, share, and connect within the AWS community. We plan to visit various cities across Lancashire throughout the year and look forward to meeting you!\n\nWe host engaging talks, workshops, and networking sessions with guest speakers from AWS and the cloud community. Join us to broaden your knowledge, explore ideas, and connect with others passionate about the cloud!\n\n\n\n\n**Code Of Conduct**\nWe value the participation of each and every member and want all attendees to have an enjoyable and fulfilling experience. Accordingly, all attendees, speakers, organisers, and volunteers are required to conform to [the AWS Code of Conduct.](https://aws.amazon.com/codeofconduct/) Please be respectful and courteous to each other at events and on related social media.\n\n\n\n\n**Want To Speak?**\nDo you have an AWS or cloud-related story, a recent major project to share your experience of, special expertise in the field or even just some tips to share? If so, we'd love to hear from you! Our Call For Speakers can be found [on our Gravatar profile](https://gravatar.com/awsuglancs).\n\n\n\n\n**Get In Touch, Feedback \u0026 Socials**\nThere are many ways to interact with AWS User Group Lancashire, all of which are now [on our Gravatar profile](https://gravatar.com/awsuglancs).\n\n**Diversity**\nOur events are free and open to everyone, regardless of background or experience. Please let us know if you require any accommodations, and we will do our best to assist you.\n\n**Refreshments**\nFood and beverages will be available at all events unless specified otherwise. Have any particular dietary needs? Let us know in advance, and we will do our best to accommodate you.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":1,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:314993875"}}]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":4,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:313977757"}},{"__typename":"EventEdge","node":{"__ref":"Event:311670967"}},{"__typename":"EventEdge","node":{"__ref":"Event:307085649"}},{"__typename":"EventEdge","node":{"__ref":"Event:305152182"}}]},"activeTopics":[{"__ref":"Topic:8192"},{"__ref":"Topic:15167"},{"__ref":"Topic:18865"},{"__ref":"Topic:24120"},{"__ref":"Topic:26468"},{"__ref":"Topic:110474"},{"__ref":"Topic:117019"},{"__ref":"Topic:488822"},{"__ref":"Topic:584902"},{"__ref":"Topic:661712"},{"__ref":"Topic:1509702"},{"__ref":"Topic:1513353"},{"__ref":"Topic:1516091"},{"__ref":"Topic:1056672"},{"__ref":"Topic:9696"}],"topicCategory":{"__ref":"TopicCategory:546"},"sponsors":{"__typename":"ProGroupSponsorsConnection","edges":[{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040510"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040511"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040512"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040514"}},{"__typename":"SponsorEdge","node":{"__ref":"Sponsor:ch7040513"}}]},"foundedDate":"2024-12-18T14:33:54Z","socialNetworks":[{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FACEBOOK"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TWITTER"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"FLICKR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TUMBLR"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"INSTAGRAM"},{"__typename":"SocialNetwork","identifier":"https://www.linkedin.com/company/aws-user-group-lancashire","url":"https://www.linkedin.com/company/aws-user-group-lancashire","service":"LINKEDIN"},{"__typename":"SocialNetwork","identifier":"","url":"http://","service":"TIKTOK"},{"__typename":"SocialNetwork","identifier":"https://gravatar.com/awsuglancs","url":"https://gravatar.com/awsuglancs","service":"OTHER"}],"memberships:{\"filter\":{\"status\":[\"ACTIVE\",\"LEADER\"]}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:236906297"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:387246058"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:295515867"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:14063784"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:379750081"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:254949594"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:297104480"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:202478196"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:420697700"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:120950612"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:185313276"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:418501113"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:436648782"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:452390267"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:448586220"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:409493596"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:74900052"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:28256933":{"__typename":"Venue","id":"28256933","name":"Old Milk Depot","address":"The Old Milk Depot, Bacup Road, Rawtenstall, Lancashire, BB4 7FE","city":"Rawtenstall","state":"","country":"gb"},"PhotoInfo:534448634":{"__typename":"PhotoInfo","id":"534448634","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/6/f/d/a/highres_534448634.jpeg"},"PhotoInfo:319555437":{"__typename":"PhotoInfo","id":"319555437","highResUrl":"https://secure.meetupstatic.com/photos/member/d/8/8/d/highres_319555437.jpeg"},"Rsvp:2072682401":{"__typename":"Rsvp","id":"2072682401","member":{"__ref":"Member:387299743"}},"Rsvp:2072682405":{"__typename":"Rsvp","id":"2072682405","member":{"__ref":"Member:236906297"}},"Member:481908232":{"__typename":"Member","id":"481908232","name":"Ian Clarke","memberPhoto":null},"Rsvp:2074086354":{"__typename":"Rsvp","id":"2074086354","member":{"__ref":"Member:481908232"}},"PhotoInfo:325605615":{"__typename":"PhotoInfo","id":"325605615","highResUrl":"https://secure.meetupstatic.com/photos/member/b/2/2/f/highres_325605615.jpeg"},"Member:419041451":{"__typename":"Member","id":"419041451","name":"Haider Shah","memberPhoto":{"__ref":"PhotoInfo:325605615"}},"Rsvp:2074170136":{"__typename":"Rsvp","id":"2074170136","member":{"__ref":"Member:419041451"}},"Event:314993875":{"__typename":"Event","id":"314993875","title":"AWS UG Lancashire x Rossendale Digital June 2026: Rossendale","eventUrl":"https://www.meetup.com/aws-user-group-lancashire/events/314993875/","description":"**AWS User Group Lancashire** comes to Rossendale! We are joining **Rossendale Digital** to support a digital hub so that residents can benefit from a programme of skills and events whilst businesses can share their knowledge and experience with each other.\n\n**\\|\\|\\| FEATURED TALKS \\|\\|\\|**\n\n🎙️**[Damien Jones](https://www.linkedin.com/in/mrdamienjones/) \\- AWS Consultant @ [Steamhaus](https://www.steamhaus.co.uk/)**\n\n***\"Best in Show: Building a Crufts-Ready AWS Business Platform in 5 Weeks\"***\n\nA new dog training business is launched. You have 5 weeks to develop a new production-ready platform before Crufts: the world's biggest dog show. Could you deliver?\n\nIn this talk, I'll share the real-world journey of building WolfieAndFriends on AWS. We'll review my architectural choices, \"build vs buy\" decisions and the trade-offs made during those hectic early days. You'll learn how to use AWS serverless, IaC and AI services to enable rapid delivery, shorten development times and transform a greenfield project into a professional, scalable platform that pays the bills.\n\nWhether you're a startup founder or an enterprise dev, you'll walk away with a blueprint for rapid delivery without sacrificing long-term stability. Expect Amplify, CDK, Q Developer, Kiro and more!\n\nThere will be a chance to network🗣️ and of course the obligatory 🍕on offer.\nGrab your space!\n\n**\\|\\|\\| SCHEDULE \\|\\|\\|**\n17:00 - Doors\n17:30 - Speaker\n18:00 - Refreshments \u0026 networking\n18:20 - Live exploration of Kiro\n19:00 - Close\n\n**\\|\\|\\| LOCATION \u0026 HOW TO FIND US \\|\\|\\|**\nThe Old Milk Depot, Bacup Road, Rawtenstall, Lancashire, BB4 7FE\n\nThe Old Milk Depot is a 10 minute walk from Rawtenstall town centre, with free on-site parking for easy access.\n\nWhat3words - [https://w3w.co/artist.leader.best](https://w3w.co/artist.leader.best)\nGoogle Pin - [https://maps.app.goo.gl/vHaDVoRvmj3bvL1d9](https://maps.app.goo.gl/vHaDVoRvmj3bvL1d9)\n\n**\\|\\|\\| SPONSORS \\|\\|\\|**\nAWS User Group Lancashire thanks our generous sponsors:\n\n* [Innovate Lancashire](https://innovatelancashire.co.uk/)\n* [Lancashire Digital Hub](https://lancashiredigitalhub.co.uk/)\n* [Rossendale Borough Council](https://www.rossendale.gov.uk/)\n* [Northern Reach](https://northernreach.co.uk/)","isSaved":false,"group":{"__ref":"Group:37846811"},"creatorMember":{"__ref":"Member:236906297"},"eventHosts":[{"__typename":"EventHost","memberId":"236906297"},{"__typename":"EventHost","memberId":"387299743"}],"feeSettings":null,"venue":{"__ref":"Venue:28256933"},"dateTime":"2026-06-24T17:00:00+01:00","createdTime":"2026-05-28T09:03:59-04:00","endTime":"2026-06-24T19:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":4},"isOnline":false,"eventType":"PHYSICAL","status":"ACTIVE","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:534448634"},"displayPhoto":{"__ref":"PhotoInfo:534448634"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":4,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072682401"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2072682405"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074086354"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2074170136"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27850361":{"__typename":"Venue","id":"27850361","name":"Blackburn Industry Collaboration Zone","address":"Blackburn College, Harrison Centre, Feilden Street  Blackburn  BB2 1LH","city":"Blackburn","state":"","country":"gb"},"PhotoInfo:533404084":{"__typename":"PhotoInfo","id":"533404084","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/f/f/4/highres_533404084.jpeg"},"Rsvp:2066791614":{"__typename":"Rsvp","id":"2066791614","member":{"__ref":"Member:387299743"}},"Rsvp:2066791615":{"__typename":"Rsvp","id":"2066791615","member":{"__ref":"Member:236906297"}},"PhotoInfo:322242666":{"__typename":"PhotoInfo","id":"322242666","highResUrl":"https://secure.meetupstatic.com/photos/member/a/6/a/a/highres_322242666.jpeg"},"Member:418501113":{"__typename":"Member","id":"418501113","name":"Michael Tattersall","memberPhoto":{"__ref":"PhotoInfo:322242666"}},"Rsvp:2066793268":{"__typename":"Rsvp","id":"2066793268","member":{"__ref":"Member:418501113"}},"PhotoInfo:324795443":{"__typename":"PhotoInfo","id":"324795443","highResUrl":"https://secure.meetupstatic.com/photos/member/3/c/5/3/highres_324795443.jpeg"},"Member:478321712":{"__typename":"Member","id":"478321712","name":"manish121292","memberPhoto":{"__ref":"PhotoInfo:324795443"}},"Rsvp:2066855134":{"__typename":"Rsvp","id":"2066855134","member":{"__ref":"Member:478321712"}},"PhotoInfo:272946663":{"__typename":"PhotoInfo","id":"272946663","highResUrl":"https://secure.meetupstatic.com/photos/member/1/a/0/7/highres_272946663.jpeg"},"Member:243342870":{"__typename":"Member","id":"243342870","name":"Mark Francis","memberPhoto":{"__ref":"PhotoInfo:272946663"}},"Rsvp:2067447254":{"__typename":"Rsvp","id":"2067447254","member":{"__ref":"Member:243342870"}},"Event:313977757":{"__typename":"Event","id":"313977757","title":"AWS UG Lancashire x Tech Voices April 2026: Blackburn","eventUrl":"https://www.meetup.com/aws-user-group-lancashire/events/313977757/","description":"**AWS User Group Lancashire** and **Tech Voices** are joining forces to bring together people on the front line, sharing what actually works (and what really doesn't).\nWhether you're at the coalface, shaping solutions, studying or simply exploring the world of tech, join us.\n\n**\\|\\|\\| FEATURED TALKS \\|\\|\\|**\n\n🎙️ **[Mark Francis](https://www.linkedin.com/in/mark-s-francis/) \\- CTO @ [Moonstar](https://moonstar.ai/)**\n***'How to Build a Realtime Collaborative AI Chat'***\n\n**What to expect:**\nAI chat is easy, that is until you try to make it work for teams. Mark breaks down how he built a realtime, multi-user AI chat where people can collaborate in the same conversation. From syncing data and streaming responses to handling scale, he’ll share what actually works and what broke along the way.\n\n🎙️ **[Benjamin Clark](https://www.linkedin.com/in/benni/) – Founder @ [Sudoblark](https://sudoblark.com/)**\n***'How to Build AI Data Pipelines on AWS'***\n\n**What to expect:**\nMost teams think AI agents require a total architectural overhaul. Ben is here to show you that they're actually just a natural extension of the existing infrastructure patterns you already use. Using a live bookshelf-cataloguing system as a guide, you'll see how to extract metadata from images and build genuine AI integration without the specialist ML overhead. No new stack required—just smart patterns that work on any cloud.\n\nThere will be a chance to network🗣️ and of course the obligatory 🍕on offer.\nGrab your space!\n\n**\\|\\|\\| SCHEDULE \\|\\|\\|**\n18:00 - Doors, food, drinks\n18:30 - Welcome\n18:40 - Speaker 1\n19:10 - Break for refreshments \u0026 networking\n19:20 - Speaker 2\n19:50 - Open Mic \u0026 Community News\n20:00 - Close\n\n**\\|\\|\\| LOCATION \u0026 HOW TO FIND US \\|\\|\\|**\n[Industry Collaboration Zone at Blackburn College](https://www.blackburnicz.co.uk/)\n\n**HERE is the part to take note of as some people do get lost.**\n\n🚗 **CARS:** Park in the Car Park in front of the University Centre Building. The car park location for the Industry Collaboration Zone can be tricky to find; please see the Google Pin and the What3words location below to help you find it better.\n\nYou will see that you can access the car park at the front of the building via either St Paul's Street or Alma Street. Take care when coming to the car park entrances and **note the Bus Lane.**\n\nWhat3words - [https://w3w.co/stand.proud.tasty](https://w3w.co/stand.proud.tasty)\nGoogle Pin - [https://maps.app.goo.gl/8r6PoD6RzV3uqpPT8](https://maps.app.goo.gl/8r6PoD6RzV3uqpPT8)\n\nAs you stand facing the University Building, you will see a brown brick building to the right of the car park – this is the Harrison Centre, ICZ - [https://w3w.co/names.mixer.badge](https://w3w.co/names.mixer.badge)\n\nCar Park charges apply after 16:30, costing £1 all evening. Machines are card only. **UNFORTUNATELY WE CAN NO LONGER OFFER FREE PARKING**\n\n**🚌 PUBLIC TRANSPORT**: Industry Collaboration Zone is just over half a mile from Blackburn Train Station. The nearest bus stop is Alma Street.\n\n**\\|\\|\\| SPONSORS \\|\\|\\|**\nAWS User Group Lancashire thanks our generous sponsors:\n\n*[Innovate Lancashire](https://innovatelancashire.co.uk/)\n- [Lancashire Digital Hub](https://lancashiredigitalhub.co.uk/)\n*[Northern Reach](https://northernreach.co.uk/)","isSaved":false,"group":{"__ref":"Group:37846811"},"creatorMember":{"__ref":"Member:236906297"},"eventHosts":[{"__typename":"EventHost","memberId":"236906297"},{"__typename":"EventHost","memberId":"387299743"}],"feeSettings":null,"venue":{"__ref":"Venue:27850361"},"dateTime":"2026-04-23T18:00:00+01:00","createdTime":"2026-03-27T05:56:45-04:00","endTime":"2026-04-23T20:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":8},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:533404084"},"displayPhoto":{"__ref":"PhotoInfo:533404084"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":8,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066791614"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066791615"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066793268"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2066855134"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2067447254"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:28160697":{"__typename":"Venue","id":"28160697","name":"Kings Court Business Centre","address":"Kings Court Business Centre, King Street, Leyland, Lancashire PR25 2LE","city":"Leyland","state":"","country":"gb"},"PhotoInfo:530955435":{"__typename":"PhotoInfo","id":"530955435","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/3/c/4/b/highres_530955435.jpeg"},"Rsvp:2053335994":{"__typename":"Rsvp","id":"2053335994","member":{"__ref":"Member:236906297"}},"PhotoInfo:315240560":{"__typename":"PhotoInfo","id":"315240560","highResUrl":"https://secure.meetupstatic.com/photos/member/2/3/0/highres_315240560.jpeg"},"Member:6008319":{"__typename":"Member","id":"6008319","name":"David Batty","memberPhoto":{"__ref":"PhotoInfo:315240560"}},"Rsvp:2053339904":{"__typename":"Rsvp","id":"2053339904","member":{"__ref":"Member:6008319"}},"Rsvp:2053345208":{"__typename":"Rsvp","id":"2053345208","member":{"__ref":"Member:418501113"}},"PhotoInfo:250314868":{"__typename":"PhotoInfo","id":"250314868","highResUrl":"https://secure.meetupstatic.com/photos/member/d/6/5/4/highres_250314868.jpeg"},"Member:119737782":{"__typename":"Member","id":"119737782","name":"Stephen Kershaw","memberPhoto":{"__ref":"PhotoInfo:250314868"}},"Rsvp:2053361148":{"__typename":"Rsvp","id":"2053361148","member":{"__ref":"Member:119737782"}},"PhotoInfo:314545356":{"__typename":"PhotoInfo","id":"314545356","highResUrl":"https://secure.meetupstatic.com/photos/member/6/3/0/c/highres_314545356.jpeg"},"Member:28984802":{"__typename":"Member","id":"28984802","name":"James Wright","memberPhoto":{"__ref":"PhotoInfo:314545356"}},"Rsvp:2053625662":{"__typename":"Rsvp","id":"2053625662","member":{"__ref":"Member:28984802"}},"Event:311670967":{"__typename":"Event","id":"311670967","title":"AWS UG Lancashire November 2025: Leyland","eventUrl":"https://www.meetup.com/aws-user-group-lancashire/events/311670967/","description":"AWS User Group Lancashire welcomes you to Kings Court Business Centre at Leyland!\n\n**\\*\\*\\* Speakers \\*\\*\\***\nWe are excited to welcome:\n\n[Kate Gowron](https://www.linkedin.com/in/katehollow/) is a Database Cloud Architect @ DoiT, specialising in cloud and database platforms, with 12+ years building on-prem and cloud-native systems. She has led large-scale RDS migrations, optimised PostgreSQL and Neptune performance at billion-row scale and built automated deployments using AWS CDK and Terraform. Kate is an author, an AWS Ambassador \u0026 Community Builder and blogger at kategawron.co.uk.\n\n[Paul Ross](https://www.linkedin.com/in/paul-mcgregor-ross/) is a Senior Specialist Solution Architect for In-Memory Databases on AWS. Paul helps AWS customers build faster, scalable applications by utilising technologies such as Amazon ElastiCache and MemoryDB. Before joining AWS, Paul worked as a Partner Solution Architect at Redis. Paul is as happy sharing knowledge on key-value databases as he is demonstrating the capabilities of his Brompton C-Line bicycle.\n\nThanks for joining us!\n\n**\\*\\*\\* Sessions \\*\\*\\***\n\nKate's session: **Beyond Relational: Designing Resilient, Scalable Data Platforms on AWS**\n\nIn this talk, we explore how to design resilient and scalable data architectures on AWS by going beyond traditional relational databases. We'll walk through real-world scenarios and dive into the strengths, trade-offs, and ideal use cases for AWS services like DynamoDB, Redshift, OpenSearch, Keyspaces, and more. Whether you're building for high write throughput, low-latency access, or complex analytics, you'll leave with a practical decision-making framework to choose the right datastore for the job.\n\nPaul's session: **Optimise your apps for cost and performance using In-Memory Databases and Valkey on AWS**\n\nOrganisations are rapidly adopting Valkey to dramatically boost performance while slashing operational costs. Join Paul Ross to discover how Valkey on AWS can transform your applications through lightning-fast data access and seamless real-time operations.\n\n**\\*\\*\\* Schedule \\*\\*\\***\n18:00 - Doors, food, drinks\n18:30 - Welcome\n18:40 - Speaker 1\n19:10 - Break for refreshments \u0026 networking\n19:20 - Speaker 2\n19:50 - Open Mic \u0026 Community News\n20:00 - Close\n\n**\\*\\*\\* Travel \\*\\*\\***\n\n* Google Maps: [Kings Court Business Centre, King Street, Leyland, PR25 2LE](https://www.google.com/maps/place/Kings+Court+Business+Centre,+King+St,+Leyland+PR25+2LE/@53.6946141,-2.6936416,18z/data=!3m1!4b1!4m6!3m5!1s0x487b0d456c8946c7:0x7fc9406f72745077!8m2!3d53.6946125!4d-2.6923541!16s%2Fg%2F11bymzb3m5?entry=ttu\u0026g_ep=EgoyMDI1MTAyMi4wIKXMDSoASAFQAw%3D%3D)\n* [What3Words](https://what3words.com/calms.book.tell): ///calms.book.tell\n\n**DRIVING**: Kings Court Business Centre is about a mile away from Junction 28 of the M6 motorway and has ample free on-site parking.\n\n**PUBLIC TRANSPORT**: Kings Court Business Centre is a ten-minute walk from [Leyland Train Station](https://www.northernrailway.co.uk/stations/leyland) on the West Coast main line. Several bus routes also stop at Hough Lane - a five-minute walk from the venue.\n\n**\\*\\*\\* Diversity \\*\\*\\***\nOur events are free and open to everyone, regardless of background or experience. Please let us know if you require any accommodations, and we will do our best to assist you.\n\n**\\*\\*\\* Refreshments \\*\\*\\***\nA selection of food and beverages will be provided. Have dietary requirements? Let us know in advance, and we’ll do our best to accommodate you.\n\n**\\*\\*\\* Photography \u0026 Videography Notice \\*\\*\\***\nBy attending, you consent to being photographed and filmed for promotional and educational purposes. Prefer not to be recorded? Just let us know when you arrive.\n\n**\\*\\*\\* Sponsors \\*\\*\\***\nAWS User Group Lancashire thanks our generous sponsors:\n\n* [Innovate Lancashire](https://innovatelancashire.co.uk/)\n* [Lancashire Digital Hub](https://lancashiredigitalhub.co.uk/)\n* [Northern Reach](https://northernreach.co.uk/)","isSaved":false,"group":{"__ref":"Group:37846811"},"creatorMember":{"__ref":"Member:236906297"},"eventHosts":[{"__typename":"EventHost","memberId":"236906297"}],"feeSettings":null,"venue":{"__ref":"Venue:28160697"},"dateTime":"2025-11-26T18:00:00Z","createdTime":"2025-10-23T08:57:29-04:00","endTime":"2025-11-26T20:00:00Z","going":{"__typename":"GoingRsvpConnection","totalCount":8},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:530955435"},"displayPhoto":{"__ref":"PhotoInfo:530955435"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":8,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2053335994"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2053339904"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2053345208"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2053361148"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2053625662"}}]},"maxTickets":0,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27898761":{"__typename":"Venue","id":"27898761","name":"Strawberry Fields Digital Hub","address":"Euxton Lane, Chorley, PR7 1PS","city":"Chorley","state":"","country":"gb"},"PhotoInfo:527555520":{"__typename":"PhotoInfo","id":"527555520","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/8/a/c/0/highres_527555520.jpeg"},"Rsvp:2032484198":{"__typename":"Rsvp","id":"2032484198","member":{"__ref":"Member:236906297"}},"PhotoInfo:321265955":{"__typename":"PhotoInfo","id":"321265955","highResUrl":"https://secure.meetupstatic.com/photos/member/6/5/6/3/highres_321265955.jpeg"},"Member:448586220":{"__typename":"Member","id":"448586220","name":"Adam Matthews","memberPhoto":{"__ref":"PhotoInfo:321265955"}},"Rsvp:2032485595":{"__typename":"Rsvp","id":"2032485595","member":{"__ref":"Member:448586220"}},"Rsvp:2032489157":{"__typename":"Rsvp","id":"2032489157","member":{"__ref":"Member:28984802"}},"PhotoInfo:317962984":{"__typename":"PhotoInfo","id":"317962984","highResUrl":"https://secure.meetupstatic.com/photos/member/5/9/c/8/highres_317962984.jpeg"},"Member:385398333":{"__typename":"Member","id":"385398333","name":"Al Roberts","memberPhoto":{"__ref":"PhotoInfo:317962984"}},"Rsvp:2032490422":{"__typename":"Rsvp","id":"2032490422","member":{"__ref":"Member:385398333"}},"PhotoInfo:310878432":{"__typename":"PhotoInfo","id":"310878432","highResUrl":"https://secure.meetupstatic.com/photos/member/4/8/0/0/highres_310878432.jpeg"},"Member:196083823":{"__typename":"Member","id":"196083823","name":"Matt Houghton","memberPhoto":{"__ref":"PhotoInfo:310878432"}},"Rsvp:2032496018":{"__typename":"Rsvp","id":"2032496018","member":{"__ref":"Member:196083823"}},"Event:307085649":{"__typename":"Event","id":"307085649","title":"AWS UG Lancashire May 2025: Chorley - EDA \u0026 GenAI","eventUrl":"https://www.meetup.com/aws-user-group-lancashire/events/307085649/","description":"AWS User Group Lancashire welcomes you to **[Strawberry Fields Digital Hub](https://strawberryfieldshub.com/)** at Chorley!\n\nWe want to make sure we have just the right amount of food and drinks for everyone to enjoy, so please sign up only if you're planning to join us! If your plans happen to change after you've signed up, just let us know by updating your RSVP to 'no'- this way, someone else can take advantage of your spot!\n\nThank you for your understanding!\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Travel \\*\\*\\***\n\n* [Google Maps](https://www.google.com/maps/place/Strawberry+Fields+Digital+Hub+-+Office+Space+Lancashire/@53.6680959,-2.6500054,15z/data=!4m6!3m5!1s0x487b0db7d0cdea2f:0x8e3e856528fa4bde!8m2!3d53.6680769!4d-2.6406552!16s%2Fg%2F11h_cnpnz5?entry=ttu\u0026g_ep=EgoyMDI1MDMzMS4wIKXMDSoASAFQAw%3D%3D): Euxton Lane, Chorley, PR7 1PS\n* [What3Words](https://what3words.com/direct.deeper.thinks): ///modern.logo.mountains\n* [Moovit public transport directions](https://moovitapp.com/index/en-gb/public_transportation-The_Strawberry_Fields_Digital_Hub_Chorley-North_West-site_163984093-2105)\n\nWhile free parking is available on site, please car share or use public transport if possible. There is also a cycle hub and shower facilities.\n\nVenue is 200 yards down from Chorley Hospital on Euxton Lane, through the second set of traffic lights with a set of feeder traffic lights to turn into the car park.\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Speakers \\*\\*\\***\nWe are excited to welcome:\n\n**[Chris Dobson](https://www.linkedin.com/in/chrisdobby/)** has been developing software for longer than he cares to remember. Having worked in healthcare and video streaming, he is currently plying his trade at Trustpilot where he spends most of his time designing and building AWS workloads and implementing good coding and DevOps practices.\n\nHe is an AWS Serverless Community Builder, a certified AWS Solutions Architect Professional and Devops Engineer Professional, and an AWS Certification Subject Matter Expert.\n\n**[Matt Houghton](https://www.linkedin.com/in/matt-houghton-06b59010a/)** is a Data Architect at CDL_Software, where he undertakes R\u0026D and works with customers and CDL teams on their most challenging and complex data problems. Matt is an AWS Community Builder and holds all 13 AWS certifications. In 2021, Qlik named Matt one of their 50 Global Luminaries for driving measurable impacts from data and sharing with the community.\n\nThanks for joining us!\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Sessions \\*\\*\\***\nOur sessions are:\n\nChris Dobson: **Streamlining An Event-Driven Architecture: A Real World Transformation**\n\n\"If we are not careful as an event driven architecture matures it can evolve into something resembling the well documented ‘big ball of mud’.\n\nThis talk will look at how my team has been transforming a production EDA. It will show how a sparsely documented set of AWS SNS topics used to publish and consume cross-domain events have been transformed into an architecture exhibiting discoverability, governance and observability while continuing to run in production without any data loss.\"\n\nMatt Houghton: **Ensure The Security And Reliability Of Your GenAI Workloads With Amazon Bedrock**\n\n\"In this session, we will explore emerging risks associated with GenAI-based workloads and discuss strategies for testing, securing and monitoring them using Amazon Bedrock.\n\nWe will highlight and demonstrate some of the latest features announced for Amazon Bedrock, showcasing how they can help you create more effective GenAI workloads.\"\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Schedule \\*\\*\\***\n18:00 - Doors, food, drinks\n18:30 - Welcome\n18:40 - Matt Houghton\n19:10 - Break for refreshments \u0026 networking\n19:20 - Chris Dobson\n19:50 - Open Mic \u0026 Community News\n20:00 - Close\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Diversity \\*\\*\\***\nOur events are free and open to everyone, regardless of background or experience. Please let us know if you require any accommodations, and we will do our best to assist you.\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Refreshments \\*\\*\\***\nA selection of food and beverages will be provided. Have dietary requirements? Let us know in advance, and we’ll do our best to accommodate you.\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Photography \u0026 Videography Notice \\*\\*\\***\nBy attending, you consent to being photographed and filmed for promotional and educational purposes. Prefer not to be recorded? Just let us know when you arrive.\n\n\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\\-\n\n**\\*\\*\\* Sponsors \\*\\*\\***\nAWS User Group Lancashire thanks our generous sponsors:\n\n* [Lancashire Digital Hub](https://lancashiredigitalhub.co.uk/)\n* [Northern Reach](https://northernreach.co.uk/)\n* [Strawberry Fields Digital Hub](https://strawberryfieldshub.com/)","isSaved":false,"group":{"__ref":"Group:37846811"},"creatorMember":{"__ref":"Member:236906297"},"eventHosts":[{"__typename":"EventHost","memberId":"236906297"}],"feeSettings":null,"venue":{"__ref":"Venue:27898761"},"dateTime":"2025-05-22T18:00:00+01:00","createdTime":"2025-04-03T11:13:55-04:00","endTime":"2025-05-22T20:30:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":11},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:527555520"},"displayPhoto":{"__ref":"PhotoInfo:527555520"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":11,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2032484198"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2032485595"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2032489157"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2032490422"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2032496018"}}]},"maxTickets":50,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:25567827":{"__typename":"Venue","id":"25567827","name":"Burnley College","address":"princess way, burnley","city":"Burnley","state":"","country":"GB"},"PhotoInfo:525973987":{"__typename":"PhotoInfo","id":"525973987","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/3/6/a/3/highres_525973987.jpeg"},"Rsvp:2022985911":{"__typename":"Rsvp","id":"2022985911","member":{"__ref":"Member:236906297"}},"PhotoInfo:300926018":{"__typename":"PhotoInfo","id":"300926018","highResUrl":"https://secure.meetupstatic.com/photos/member/6/5/a/2/highres_300926018.jpeg"},"Member:227446613":{"__typename":"Member","id":"227446613","name":"Steve Murray","memberPhoto":{"__ref":"PhotoInfo:300926018"}},"Rsvp:2023043796":{"__typename":"Rsvp","id":"2023043796","member":{"__ref":"Member:227446613"}},"Rsvp:2023310906":{"__typename":"Rsvp","id":"2023310906","member":{"__ref":"Member:418501113"}},"Member:461466229":{"__typename":"Member","id":"461466229","name":"Leane Kelly","memberPhoto":null},"Rsvp:2023525901":{"__typename":"Rsvp","id":"2023525901","member":{"__ref":"Member:461466229"}},"PhotoInfo:321939668":{"__typename":"PhotoInfo","id":"321939668","highResUrl":"https://secure.meetupstatic.com/photos/member/9/a/f/4/highres_321939668.jpeg"},"Member:457412880":{"__typename":"Member","id":"457412880","name":"deji ","memberPhoto":{"__ref":"PhotoInfo:321939668"}},"Rsvp:2024783021":{"__typename":"Rsvp","id":"2024783021","member":{"__ref":"Member:457412880"}},"Event:305152182":{"__typename":"Event","id":"305152182","title":"AWS UG Lancashire February 2025: Burnley - re:Invent re:Cap","eventUrl":"https://www.meetup.com/aws-user-group-lancashire/events/305152182/","description":"AWS User Group Lancashire welcomes you to **Burnley College**!\n\nTo help us arrange the right amount of food and drinks and ensure that everyone who wants to attend can do so, please sign up only if you plan to attend. If your plans change after you sign up, please update your RSVP to 'no' so that someone else can enjoy your spot.\n\nThank you for your understanding!\n\n**Agenda**\nWe are excited to announce that **[Matheus Guimaraes](https://uk.linkedin.com/in/codingmatheus)**, the Senior Developer Advocate for AWS UK \u0026 Ireland, will be our guest speaker! Matheus is bringing the **AWS re:Invent re:Cap Tour** to Lancashire, packed with **insights, quizzes, and fun highlights** from the AWS re:Invent conference in Las Vegas.\n\nDon't miss this opportunity to get quickly updated on the latest AWS cloud developments, connect with fellow tech professionals, and learn practical strategies for optimising your cloud operations and infrastructure.\n\n**Schedule**\n18:00 - Doors, food, drinks\n18:30 - re:Invent re:Cap Part 1\n19:30 - Break for refreshments \u0026 networking\n19:45 - re:Invent re:Cap Part 2\n20:30 - Close. Continue the conversation in [Icaro Lounge](https://thelounges.co.uk/icaro/) at [Pioneer Place](https://charterwalk.com/pioneer-place/).\n\n**Diversity**\nOur events are free and open to everyone, regardless of background or experience. Please let us know if you require any accommodations, and we will do our best to assist you.\n\n**Travel**\n\n* [Burnley College Travel Advice](https://www.burnley.ac.uk/support/travel-and-transport/) (select Student / Adult is needed)\n* [Google Maps](https://www.google.co.uk/maps/place/Burnley+College/@53.7939012,-2.2497429,17z/data=!4m6!3m5!1s0x487b972faf6a13ef:0x9389f742160750da!8m2!3d53.793803!4d-2.2471572!16s%2Fm%2F03y057x?entry=ttu\u0026g_ep=EgoyMDI1MDExNC4wIKXMDSoASAFQAw%3D%3D): Princess Way, Burnley BB12 0AN\n* [What3Words](https://what3words.com/direct.deeper.thinks): ///direct.deeper.thinks\n\nWhile free parking is available behind the college, please car share or use public transport if possible.\n\n**Refreshments**\nA selection of food and beverages will be provided, courtesy of **Lancaster University.** Have dietary requirements? Let us know in advance, and we’ll do our best to accommodate you.\n\n**Photography \u0026 Videography Notice**\nBy attending, you consent to being photographed and filmed for promotional and educational purposes. Prefer not to be recorded? Just let us know when you arrive.\n\n**Sponsors**\nAWS User Group Lancashire thanks our generous sponsors:\n\n* [Burnley College](https://www.burnley.ac.uk/)\n* [Burnley Borough Council](https://burnley.gov.uk/)\n* [Lancashire Digital Hub](https://lancashiredigitalhub.co.uk/)\n* [Lancaster University](https://www.lancaster.ac.uk/)\n* [Northern Reach](https://northernreach.co.uk/)","isSaved":false,"group":{"__ref":"Group:37846811"},"creatorMember":{"__ref":"Member:236906297"},"eventHosts":[{"__typename":"EventHost","memberId":"236906297"}],"feeSettings":null,"venue":{"__ref":"Venue:25567827"},"dateTime":"2025-02-20T18:00:00Z","createdTime":"2024-12-18T16:02:38-05:00","endTime":"2025-02-20T20:30:00Z","going":{"__typename":"GoingRsvpConnection","totalCount":6},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:525973987"},"displayPhoto":{"__ref":"PhotoInfo:525973987"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":6,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2022985911"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2023043796"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2023310906"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2023525901"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2024783021"}}]},"maxTickets":50,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:8192":{"__typename":"Topic","id":"8192","name":"Open Source","urlkey":"open-source"},"Topic:15167":{"__typename":"Topic","id":"15167","name":"Cloud Computing","urlkey":"cloud-computing"},"Topic:18865":{"__typename":"Topic","id":"18865","name":"Technology","urlkey":"technology"},"Topic:24120":{"__typename":"Topic","id":"24120","name":"Data Storage","urlkey":"data-storage"},"Topic:26468":{"__typename":"Topic","id":"26468","name":"Software Architecture","urlkey":"software-architecture"},"Topic:110474":{"__typename":"Topic","id":"110474","name":"Cloud Security","urlkey":"cloud-security"},"Topic:117019":{"__typename":"Topic","id":"117019","name":"Cloud Integration","urlkey":"cloud-integration"},"Topic:488822":{"__typename":"Topic","id":"488822","name":"Artificial Intelligence",