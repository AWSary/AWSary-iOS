ber:85703172"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:210114563"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:94085682"}}]},"stepUpInfo":{"__typename":"StepUpInfo","organizerNominees":[]}},"Venue:28082446":{"__typename":"Venue","id":"28082446","name":"Brew Digital","address":"2 Millennium Plain","city":"Norwich","state":"","country":"gb"},"Rsvp:2036226869":{"__typename":"Rsvp","id":"2036226869","member":{"__ref":"Member:214031396"}},"PhotoInfo:319287428":{"__typename":"PhotoInfo","id":"319287428","highResUrl":"https://secure.meetupstatic.com/photos/member/6/b/2/4/highres_319287428.jpeg"},"Rsvp:2036226870":{"__typename":"Rsvp","id":"2036226870","member":{"__ref":"Member:186522115"}},"PhotoInfo:320110797":{"__typename":"PhotoInfo","id":"320110797","highResUrl":"https://secure.meetupstatic.com/photos/member/2/a/2/d/highres_320110797.jpeg"},"Member:276480747":{"__typename":"Member","id":"276480747","name":"Dan Clarke","memberPhoto":{"__ref":"PhotoInfo:320110797"}},"Rsvp:2036230487":{"__typename":"Rsvp","id":"2036230487","member":{"__ref":"Member:276480747"}},"PhotoInfo:320146201":{"__typename":"PhotoInfo","id":"320146201","highResUrl":"https://secure.meetupstatic.com/photos/member/b/4/7/9/highres_320146201.jpeg"},"Member:424292978":{"__typename":"Member","id":"424292978","name":"Coner","memberPhoto":{"__ref":"PhotoInfo:320146201"}},"Rsvp:2036268336":{"__typename":"Rsvp","id":"2036268336","member":{"__ref":"Member:424292978"}},"PhotoInfo:318672320":{"__typename":"PhotoInfo","id":"318672320","highResUrl":"https://secure.meetupstatic.com/photos/member/3/0/2/0/highres_318672320.jpeg"},"Member:407924153":{"__typename":"Member","id":"407924153","name":"ellana evans","memberPhoto":{"__ref":"PhotoInfo:318672320"}},"Rsvp:2036383520":{"__typename":"Rsvp","id":"2036383520","member":{"__ref":"Member:407924153"}},"Event:308060927":{"__typename":"Event","id":"308060927","title":"[Norwich] AWS User Group Meetup","eventUrl":"https://www.meetup.com/east-anglia-aws-user-group/events/308060927/","description":"**Details**\nWe're back with two exciting talks on topic of AWS!\n\n**Agenda**\n**18:00** \\- Doors open \u0026 networking\n**18:35** \\- Introduction to the event\n**18:40** \\- Talk: \"Securing the Cloud with AWS Identity Management\"\\, Mike Mead\n**19:05** \\- Talk: \"SaaS Email Done Right: Building Reliable Email Systems with AWS SES\"\\, Coner Murphy\n**19:30** \\- Networking\n**20:00** \\- Close\n\nWe'll have drinks and pizza to keep you all fed and watered throughout.\n\nLooking forward to seeing you all!\n\n**This event's talks:**\n\n**Securing the Cloud with AWS Identity Management - Mike Mead**\n*An introduction to AWS Identity and Access Management (IAM) that demystifies cloud security concepts and providing some practical tips on implementing secure access controls in AWS.*\n\n**SaaS Email Done Right: Building Reliable Email Systems with AWS SES - Coner Murphy**\n*Talk description TBC*\n\n**Venue**\nFor this event, we're planning to be at [Brew Digital's offices](https://maps.app.goo.gl/E3CmJxCZTdkWpdxaA) in the heart of Norwich (Thanks Brew!).\n\n***Important Note:*** *Brew Digital have moved office since the last event and are now based on the first floor of 2 Millennium Plain, Norwich, NR2 1TF (above the TV \u0026 Movie Store/opposite the Forum). Nearest car park is the Forum*","isSaved":false,"group":{"__ref":"Group:20230241"},"creatorMember":{"__ref":"Member:186522115"},"eventHosts":[{"__typename":"EventHost","memberId":"186522115"},{"__typename":"EventHost","memberId":"214031396"}],"feeSettings":null,"venue":{"__ref":"Venue:28082446"},"dateTime":"2025-07-03T18:00:00+01:00","createdTime":"2025-05-26T07:55:33-04:00","endTime":"2025-07-03T20:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":12},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:519828705"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":12,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2036226869"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2036226870"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2036230487"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2036268336"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2036383520"}}]},"maxTickets":30,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Venue:27710048":{"__typename":"Venue","id":"27710048","name":"University of Suffolk - Atrium Building","address":"","city":"Ipswich","state":"","country":"gb"},"PhotoInfo:525759325":{"__typename":"PhotoInfo","id":"525759325","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/","highResUrl":"https://secure.meetupstatic.com/photos/event/9/9/9/d/highres_525759325.jpeg"},"Rsvp:2021662847":{"__typename":"Rsvp","id":"2021662847","member":{"__ref":"Member:214031396"}},"PhotoInfo:322123549":{"__typename":"PhotoInfo","id":"322123549","highResUrl":"https://secure.meetupstatic.com/photos/member/a/a/1/d/highres_322123549.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:385548222":{"__typename":"Member","id":"385548222","name":"Ben Formesyn","memberPhoto":{"__ref":"PhotoInfo:322123549"}},"Rsvp:2021682353":{"__typename":"Rsvp","id":"2021682353","member":{"__ref":"Member:385548222"}},"Member:341360005":{"__typename":"Member","id":"341360005","name":"Herman","memberPhoto":null},"Rsvp:2021684466":{"__typename":"Rsvp","id":"2021684466","member":{"__ref":"Member:341360005"}},"PhotoInfo:314403861":{"__typename":"PhotoInfo","id":"314403861","highResUrl":"https://secure.meetupstatic.com/photos/member/f/1/5/highres_314403861.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/"},"Member:195364546":{"__typename":"Member","id":"195364546","name":"Edward Ireson","memberPhoto":{"__ref":"PhotoInfo:314403861"}},"Rsvp:2021724963":{"__typename":"Rsvp","id":"2021724963","member":{"__ref":"Member:195364546"}},"Member:204244399":{"__typename":"Member","id":"204244399","name":"Brian Jones","memberPhoto":null},"Rsvp:2021979672":{"__typename":"Rsvp","id":"2021979672","member":{"__ref":"Member:204244399"}},"PhotoInfo:318227377":{"__typename":"PhotoInfo","id":"318227377","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/b/9/1/1/highres_318227377.jpeg"},"PhotoInfo:150338422":{"__typename":"PhotoInfo","id":"150338422","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/9/6/1/6/highres_150338422.jpeg"},"PhotoInfo:265082602":{"__typename":"PhotoInfo","id":"265082602","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/a/2/a/highres_265082602.jpeg"},"PhotoInfo:266620957":{"__typename":"PhotoInfo","id":"266620957","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/9/f/f/d/highres_266620957.jpeg"},"PhotoInfo:242739576":{"__typename":"PhotoInfo","id":"242739576","baseUrl":"https://secure-content.meetupstatic.com/images/classic-member/","highResUrl":"https://secure.meetupstatic.com/photos/member/9/a/9/8/highres_242739576.jpeg"},"Event:305664182":{"__typename":"Event","id":"305664182","title":"[Ipswich] Let's re:Cap re:Invent 2024","eventUrl":"https://www.meetup.com/east-anglia-aws-user-group/events/305664182/","description":"***Session***\nOver the pre:Invent, and re:Invent period at the end of 2024, there were 546 announcements around new features and services!\n\nThe purpose of this first meetup of 2025 is to replay the highlights from around the biggest AWS event in the calendar! We won't get through all the releases, but are aiming to cover a healthy balance across all areas.\n\nWe're super excited to have Matheus Guimaraes presenting this re:Cap!\n\n**We'll be kicking off the re:Cap at around 18:45**, as we have a hard end on the room hire at 21:30 and I want to make sure we've got some time to chat at the end. We'll have soft drinks and pizza as usual to keep you all fed and watered throughout.\n\nLook forward to seeing as many of you as possible!\n\n***Venue***\nFor this event, we're going to be in the Atrium Building at The University of Suffolk. It's in the same building as the previous meetup, close to the Waterfront, just in a different room. I'd recommend parking at [Duke Orwell Quay car park](https://www.google.com/maps/place/Duke+Orwell+Quay+car+park/@52.0517677,1.1623461,17.75z/data=!4m14!1m7!3m6!1s0x47d99fb1c5b5b50b:0x7df3b2d6de6e1ffb!2sThe+Hold+-+Ipswich+home+of+Suffolk+Archives!8m2!3d52.0530624!4d1.1636657!16s%2Fg%2F11qmm4z8h4!3m5!1s0x47d99f871a4b3a97:0x39cb00398149fbd3!8m2!3d52.0509309!4d1.1641632!16s%2Fg%2F11f_p395lt?entry=ttu) on the Waterfront; prices are reasonable and it's just a few minutes walk from the venue. Parking isn't available in the University of Suffolk car park (unless you'd like a ticket!). I'm hoping to pop some signs up inside the venue to direct people to the right room.","isSaved":false,"group":{"__ref":"Group:20230241"},"creatorMember":{"__ref":"Member:214031396"},"eventHosts":[{"__typename":"EventHost","memberId":"214031396"}],"feeSettings":null,"venue":{"__ref":"Venue:27710048"},"dateTime":"2025-02-06T18:30:00Z","createdTime":"2025-01-17T04:21:24-05:00","endTime":"2025-02-06T21:30:00Z","going":{"__typename":"GoingRsvpConnection","totalCount":9},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":{"__ref":"PhotoInfo:525759325"},"displayPhoto":{"__ref":"PhotoInfo:525759325"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":9,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2021662847"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2021682353"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2021684466"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2021724963"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2021979672"}}]},"maxTickets":30,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":{"__typename":"SocialProofInsights","isTrendingEvent":false,"totalInterestedUsers":48,"interestedUsersSample":[{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:322123549"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:314403861"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:318227377"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:150338422"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:265082602"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:266620957"}},{"__typename":"Member","memberPhoto":{"__ref":"PhotoInfo:242739576"}}]}},"Venue:27848340":{"__typename":"Venue","id":"27848340","name":"Brew Digital","address":"Lawrence House, 5 St Andrews Hill, Norwich NR2 1AD","city":"Norwich","state":"","country":"gb"},"Rsvp:2009924394":{"__typename":"Rsvp","id":"2009924394","member":{"__ref":"Member:214031396"}},"Rsvp:2009924395":{"__typename":"Rsvp","id":"2009924395","member":{"__ref":"Member:186522115"}},"Member:428805636":{"__typename":"Member","id":"428805636","name":"Josh Hart","memberPhoto":null},"Rsvp:2009925634":{"__typename":"Rsvp","id":"2009925634","member":{"__ref":"Member:428805636"}},"Rsvp:2009929527":{"__typename":"Rsvp","id":"2009929527","member":{"__ref":"Member:276480747"}},"PhotoInfo:311636628":{"__typename":"PhotoInfo","id":"311636628","highResUrl":"https://secure.meetupstatic.com/photos/member/d/d/3/4/highres_311636628.jpeg"},"Member:144645242":{"__typename":"Member","id":"144645242","name":"Elisa","memberPhoto":{"__ref":"PhotoInfo:311636628"}},"Rsvp:2009934857":{"__typename":"Rsvp","id":"2009934857","member":{"__ref":"Member:144645242"}},"Event:303481454":{"__typename":"Event","id":"303481454","title":"[Norwich] AWS User Group Meetup","eventUrl":"https://www.meetup.com/east-anglia-aws-user-group/events/303481454/","description":"**Details**\nThis time around we have two talks for you! We'll be starting with an introductory talk before moving onto a more advanced topic on databases.\n\n**Agenda**\n**18:00** \\- Doors open \u0026 networking\n**18:35** \\- Introduction to the event\n**18:40** \\- Talk: \"A\\(P\\)I: Building a REST API to generate stories with AWS Bedrock\"\\, Coner Murphy\n**19:05** \\- Talk: \"Are relational databases cool again?\"\\, Josh Hart\n**19:30** \\- Networking\n**20:00** \\- Close\n\nWe'll have drinks and pizza to keep you all fed and watered throughout.\n\nLooking forward to seeing you all!\n\n**This event's talks:**\n\n**A(P)I: Building a REST API to generate stories with AWS Bedrock - Coner Murphy**\nFirst up we have Coner, a Senior Software Engineer at Salable, introducing us to AWS Bedrock. For those new to this service it's used to build GenAI applications on AWS.\n\n**Are relational databases cool again? - Josh Hart**\nNext up we have Josh, a Principal Solutions Architect at AWS, who will take us through the the recent AWS platform innovations (E.g. Data API, Limitless, Serverless V2 etc) in the relational database space.\n\n**Venue**\nFor this event, we're planning to be at [Brew Digital's offices](https://maps.app.goo.gl/XEboqLY2wfhKf4Qj7) in the heart of Norwich (Thanks Brew!).\n\nThere are many nearby parking options, but the closest is probably [St. Andrews Car Park](https://maps.app.goo.gl/E9WPJfiUyJqutRnr7). It's less than [15 minutes walking](https://maps.app.goo.gl/vigoRGYwSPsKUMMH9) from Norwich station if you're travelling by train.","isSaved":false,"group":{"__ref":"Group:20230241"},"creatorMember":{"__ref":"Member:186522115"},"eventHosts":[{"__typename":"EventHost","memberId":"186522115"},{"__typename":"EventHost","memberId":"214031396"}],"feeSettings":null,"venue":{"__ref":"Venue:27848340"},"dateTime":"2024-10-10T18:00:00+01:00","createdTime":"2024-09-17T06:16:13-04:00","endTime":"2024-10-10T20:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":14},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:519828705"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":14,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2009924394"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2009924395"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2009925634"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2009929527"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2009934857"}}]},"maxTickets":30,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Rsvp:2003160210":{"__typename":"Rsvp","id":"2003160210","member":{"__ref":"Member:214031396"}},"Rsvp:2003160211":{"__typename":"Rsvp","id":"2003160211","member":{"__ref":"Member:186522115"}},"Rsvp:2003161537":{"__typename":"Rsvp","id":"2003161537","member":{"__ref":"Member:276480747"}},"PhotoInfo:320247189":{"__typename":"PhotoInfo","id":"320247189","highResUrl":"https://secure.meetupstatic.com/photos/member/6/a/3/5/highres_320247189.jpeg"},"Member:251132620":{"__typename":"Member","id":"251132620","name":"Steve Dodd","memberPhoto":{"__ref":"PhotoInfo:320247189"}},"Rsvp:2003434364":{"__typename":"Rsvp","id":"2003434364","member":{"__ref":"Member:251132620"}},"Rsvp:2003487537":{"__typename":"Rsvp","id":"2003487537","member":{"__ref":"Member:424292978"}},"Event:302196439":{"__typename":"Event","id":"302196439","title":"[Norwich] Welcome to the East Anglia AWS User Group","eventUrl":"https://www.meetup.com/east-anglia-aws-user-group/events/302196439/","description":"**Details**\nWelcome to the inaugural East Anglia AWS User Group in Norwich!\n\n**Agenda**\n**18:00** \\- Doors open \u0026 networking\n**18:45** \\- Talk: \"Monolithernetes: Running Unwieldy Apps in EKS\"\n**19:30** \\- Networking\n**20:00** \\- Close\n\nWe'll have soft drinks and pizza to keep you all fed and watered throughout.\n\nLooking forward to seeing you all!\n\n**This event's talk**\nWe have Matt Saunders, DevOps Lead for the CTO at The Adaptavist Group, speaking at the event.\n\n**Talk title:** ***Monolithernetes: Running Unwieldy Apps in EKS***.\n*Understanding how to best architect applications for running in containers is a relatively well understood task these days - have small fungible microservices with rapid startup times, minimal runtime configuration and stateless operation. But is it still a good idea to use Kubernetes (EKS) when you have none of those things and no ability to change them?*\n\n*We thought so three years ago and gave it a go. Hear us walk through the constraints we were working under, why we thought EKS was a good idea, how we got on on a journey involving Puppet, Docker Swarm, ECS, EKS, EFS and Fargate, and find out what we learnt.*\n\n**Venue**\nFor this event, we're planning to be at [Brew Digital's offices](https://maps.app.goo.gl/XEboqLY2wfhKf4Qj7) in the heart of Norwich.\n\nThere are many nearby parking options, but the closest is probably [St. Andrews Car Park](https://maps.app.goo.gl/E9WPJfiUyJqutRnr7). It's less than [15 minutes walking](https://maps.app.goo.gl/vigoRGYwSPsKUMMH9) from Norwich station if you're travelling by train.","isSaved":false,"group":{"__ref":"Group:20230241"},"creatorMember":{"__ref":"Member:186522115"},"eventHosts":[{"__typename":"EventHost","memberId":"186522115"},{"__typename":"EventHost","memberId":"214031396"}],"feeSettings":null,"venue":{"__ref":"Venue:27848340"},"dateTime":"2024-07-25T18:00:00+01:00","createdTime":"2024-07-12T10:06:36-04:00","endTime":"2024-07-25T20:00:00+01:00","going":{"__typename":"GoingRsvpConnection","totalCount":14},"isOnline":false,"eventType":"PHYSICAL","status":"PAST","series":null,"featuredEventPhoto":null,"displayPhoto":{"__ref":"PhotoInfo:519828705"},"rsvps({\"first\":5})":{"__typename":"RsvpConnection","totalCount":14,"edges":[{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003160210"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003160211"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003161537"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003434364"}},{"__typename":"RsvpEdge","node":{"__ref":"Rsvp:2003487537"}}]},"maxTickets":30,"rsvpSettings":{"__typename":"RsvpOpenSettings","rsvpsClosed":false},"isNetworkEvent":false,"networkEvent":null,"socialLabels":[],"socialProofInsights":null},"Topic:120095":{"__typename":"Topic","id":"120095","name":"Software Development","urlkey":"software-development"},"Topic:9696":{"__typename":"Topic","id":"9696","name":"New Technology","urlkey":"new-technology"},"Topic:15167":{"__typename":"Topic","id":"15167","name":"Cloud Computing","urlkey":"cloud-computing"},"Topic:661712":{"__typename":"Topic","id":"661712","name":"Amazon Web Services","urlkey":"amazon-web-services"},"Topic:87614":{"__typename":"Topic","id":"87614","name":"DevOps","urlkey":"devops"},"TopicCategory:546":{"__typename":"TopicCategory","id":"546","name":"Technology","urlkey":"technology"},"Member:209079899":{"__typename":"Member","id":"209079899","name":"Dorothy Constantino","memberPhoto":{"__ref":"PhotoInfo:266620957"}},"Member:206837157":{"__typename":"Member","id":"206837157","name":"Mark Stancombe-Duhm","memberPhoto":null},"Member:46672992":{"__typename":"Member","id":"46672992","name":"Steve Williams","memberPhoto":{"__ref":"PhotoInfo:242739576"}},"PhotoInfo:93824052":{"__typename":"PhotoInfo","id":"93824052","highResUrl":"https://secure.meetupstatic.com/photos/member/a/c/1/4/highres_93824052.jpeg"},"Member:71611362":{"__typename":"Member","id":"71611362","name":"Graham Hadgraft","memberPhoto":{"__ref":"PhotoInfo:93824052"}},"PhotoInfo:153973582":{"__typename":"Ph