ooter.about":"About","footer.blog":"Blog","footer.meetupPro":"Meetup Pro","footer.careers":"Careers","footer.apps":"Apps","footer.podcast":"Podcast","footer.followUs":"Follow us","footer.getTheApp":"Get the app","mobileDownloadButtons.downloadFromGooglePlay":"Download app from Google Play","mobileDownloadButtons.downloadFromAppStore":"Download app from App Store","mobileDownloadButtons.downloadOnStore":"Download on","footer.meetupYear2":"{YEAR} Bending Spoons US Inc.","footer.termsOfService":"Terms of service","footer.privacyPolicy":"Privacy policy","footer.cookiePolicy":"Cookie policy","footer.licenseAttribution":"License attribution","footer.madeWithLoveBy":"Made with {love} by"},"country":"PT","__APOLLO_STATE__":{"PhotoInfo:318718184":{"__typename":"PhotoInfo","id":"318718184","highResUrl":"https://secure.meetupstatic.com/photos/member/e/3/4/8/highres_318718184.jpeg"},"Member:214031396":{"__typename":"Member","id":"214031396","name":"Alex Kearns","email":"","memberPhoto":{"__ref":"PhotoInfo:318718184"},"isSuperOrganizer":false},"PhotoInfo:519828705":{"__typename":"PhotoInfo","id":"519828705","highResUrl":"https://secure.meetupstatic.com/photos/event/b/e/4/1/highres_519828705.jpeg","baseUrl":"https://secure-content.meetupstatic.com/images/classic-events/"},"Member:186522115":{"__typename":"Member","id":"186522115","name":"Mike Mead","isSuperOrganizer":false,"memberPhoto":{"__ref":"PhotoInfo:319287428"}},"Group:20230241":{"__typename":"Group","id":"20230241","name":"East Anglia AWS User Group","timezone":"Europe/London","keyGroupPhoto":{"__ref":"PhotoInfo:519828705"},"urlname":"east-anglia-aws-user-group","isPrivate":false,"organizer":{"__ref":"Member:214031396"},"stats":{"__typename":"GroupStats","memberCounts":{"__typename":"GroupMemberCounts","all":347,"leadership":2,"pending":0},"eventRatings":{"__typename":"GroupStatsEventRatings","average":4.74,"total":34}},"lat":52.05,"lon":1.16,"joinMode":"OPEN","status":"PAID","city":"Ipswich","state":"N5","country":"gb","proNetwork":null,"isPrimaryOrganizer":false,"events({\"filter\":{\"status\":[\"DRAFT\"]},\"first\":1})":{"__typename":"GroupEventConnection","totalCount":0},"needsQuestions":false,"needsPhoto":false,"questions":[],"memberDuesSettingsUrl":"https://www.meetup.com/dues/east-anglia-aws-user-group/start/","duesSettings":null,"calendarFeeds":null,"welcomeBlurb":"","organizerStartTime":null,"memberships:{\"filter\":{\"status\":\"LEADER\"}}":{"__typename":"GroupMemberConnection","edges":[{"__typename":"GroupMemberEdge","node":{"__ref":"Member:214031396"}},{"__typename":"GroupMemberEdge","node":{"__ref":"Member:186522115"}}]},"description":"Hi everyone!\n\nWelcome to the East Anglia AWS User Group! The group has been setup to help share practical knowledge for anyone interested in the cloud services and technologies provided by Amazon Web Services (AWS). If you are interested in learning about and discussing new AWS services and features (and how to get the most out of them), we’d love for you to join us.\n\nWe’ll also be exploring challenges and looking at examples of innovation in action. We are aiming to meet every month, alternating between Ipswich and Norwich. All levels of knowledge and ability are welcome.\n\nIf you are interested in speaking at one of the sessions then please get in touch at: alex@alexkearns.co.uk.","video":null,"featuredEvent":null,"events({\"filter\":{\"status\":[\"ACTIVE\"]},\"first\":4,\"sort\":\"ASC\"})":{"__typename":"GroupEventConnection","totalCount":0,"edges":[]},"events({\"filter\":{\"status\":[\"PAST\"]},\"first\":4,\"sort\":\"DESC\"})":{"__typename":"GroupEventConnection","totalCount":18,"edges":[{"__typename":"EventEdge","node":{"__ref":"Event:308060927"}},{"__typename":"EventEdge","node":{"__ref":"Event:305664182"}},{"__typename":"EventEdge","node":{"__ref":"Event:303481454"}},{"__typename":"EventEdge","node":{"__ref":"Event:302196439"}}]},"activeTopics":[{"__ref":"Topic:120095"},{"__ref":"Topic:9696"},{"__ref":"Topic:15167"},{"__ref":"