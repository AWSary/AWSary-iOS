{"profile":{"awsPrograms":[{"category":"Community Hero","joinedAt":2017.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"cloudfather","avatar":"https://avatars.builderprofile.aws.dev/2xn20LKAAFnP7AQYWIBgYPzya5C.webp","bio":"Drew Firment is Chief Cloud Strategist at Pluralsight (acquired A Cloud Guru), where he accelerates customer outcomes through skills development. He is an AWS Hero for his dedication to building large-scale learning communities that drive business transformations, and his passion for teaching the world to cloud. \n\nDrew was previously Director of Cloud Engineering at Capital One. He led enterprise cloud operations within their Cloud Center of Excellence focusing on migrating the early adopters of Amazon Web Services (AWS). He founded Capital One's cloud engineering college that drove a large-scale talent transformation, and earned a patent for measuring cloud adoption and maturity. ","builderProfileId":"a8dbd9fc-d100-470b-9c33-12c656f439d6","createdOn":1.712013836288E12,"isStaff":false,"name":"Drew Firment"},"location":{},"profileStatus":"ACTIVE","socials":{"blog":"","devto":"","facebook":"","github":"","linkedIn":"drewfirment","personal":"","repost":"","twitter":"drewfirment","youtube":""}}}