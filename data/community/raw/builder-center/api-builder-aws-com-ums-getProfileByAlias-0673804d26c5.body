{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"joinedAt":2026.0,"programName":"NEW_VOICES"},{"category":"Serverless Hero","joinedAt":2022.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"zachjonesnoel","avatar":"https://avatars.builderprofile.aws.dev/36szxFBRMykn1NT4w7OFIi5Aq3q.webp","bio":"Jones Zachariah Noel aka Zach Jones is an AWS Serverless Hero and AWS UG Bengaluru leader and at his day job an observability focused Developer Advocate at New Relic. \n\nJones has been an advocate for Serverless first and also best monitoring strategies for applications and infrastructures. Coming from a full-stack developer background has always been a curious on building and breaking things! Jones writes his Serverless stories (blog and newsletter) on The Serverless Terminal and runs a podcast called The Zacs Show Talking AWS with another Hero Zack from NZ. \n\nApart from this, Jones loves to explore the mountains and driving around the country side. And burns money on LEGOs and action figures. ","builderProfileId":"cb27a662-8360-4710-aa88-499dffdfbc9d","createdOn":1.70532667392E12,"headline":"DevRel @ New Relic | AWS Serverless Hero | AWS User Group Bengaluru leader","isStaff":false,"name":"Jones Zachariah Noel N"},"location":{"displayLocation":{"countryRegion":"IN","stateProvince":"Karnataka"}},"profileStatus":"ACTIVE","socials":{"blog":"https://blog.theserverlessterminal.com/","github":"https://github.com/zachjonesnoel","linkedIn":"https://www.linkedin.com/in/jones-zachariah-noel-n","personal":"https://www.theserverlessterminal.com","twitter":"https://twitter.com/zachjonesnoel","youtube":"https://www.youtube.com/@thezacsshowtalkingaws"}}}