{"profile":{"awsPrograms":[{"category":"Container Hero","joinedAt":2018.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"sathyabhat","avatar":"https://avatars.builderprofile.aws.dev/2xo5SV4JfrgltfOlEN4Lx3PBitg.webp","bio":"Sathyajith Bhat is an experienced Cloud Architect & SRE with over 17 years of experience in Cloud Architecture, DevOps, Site Reliability Engineering. His expertise includes AWS, Azure, Kubernetes, Docker, Chef, Python, TypeScript, Linux, Bash, Docker, Terraform, Prometheus and more.\n\nHe is not fanatic about specific tools or services and believes in making the most available out of the tools he gets to work with.\n\nHe is the author of [Practical Docker with Python](https://amzn.to/3B9pQaz), a co-author of [The CDK Book](https://www.thecdkbook.com/) and is recognized as an [AWS Container Hero](https://builder.aws.com/community/@sathyabhat)","builderProfileId":"939e59d8-2123-4641-b135-fd0bdf2aadbe","createdOn":1.70165993472E12,"isStaff":false,"name":"Sathyajith Bhat"},"location":{},"profileStatus":"ACTIVE","socials":{"blog":"https://sathyasays.com","devto":"","github":"https://github.com/sathyabhat","linkedIn":"https://linkedin.com/in/sathyabhat","twitter":"https://twitter.com/sathyabhat","youtube":"https://www.youtube.com/@sathyabhat"}}}