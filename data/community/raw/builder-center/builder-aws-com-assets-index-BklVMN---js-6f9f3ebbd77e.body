is only visible to you and moderators.",dropdownArticles:"Articles",dropdownComments:"Comments",dropdownPosts:"Posts",dropdownTitle:"Content type",dropdownWishes:"Wishes",emptyBody:"You have no suspended content.",emptySeriesBody:"You have no suspended series",title:"Suspended"}}},navigation:{authStatusAll:{footer:{legalAWSSiteTerms:"Site Terms",legalAccessibility:"Accessibility",legalCookies:"Cookie preferences",legalCopyrightStatement:({year:e})=>`© ${e}, Amazon Web Services, Inc. or its affiliates. All rights reserved.`,legalPrivacy:"Privacy",nonLegalAbout:"About",nonLegalBuilderSupport:"Support",nonLegalFAQ:"FAQs",nonLegalStudentVerification:"Student verification"},leftNavigation:{buildSectionBuild:"Build",buildSectionOpenSource:"Open Source",buildSectionToolbox:"Toolbox",closeSideNavigation:"Close side navigation",connectSectionBuilderLoft:"Builder Loft",connectSectionCommunityPrograms:"Community",connectSectionConnect:"Connect",connectSectionEvents:"Events",connectSectionStartups:"Startups",exploreAWS:"Explore AWS",learnSectionLearn:"Learn",learnSectionSupportArticles:"Support articles",learnSectionTopic:"Topics",learnSectionWhatsNew:"What's new",openSideNavigation:"Open side navigation"},topNavigation:{closeModal:"Close modal",create:"Create",createContent:"Create content",createDropdownArticle:"Article",createDropdownArticleDescription:"Publish stories and insights",createDropdownPost:"Post",createDropdownPostDescription:"Start a conversation in a Space",createDropdownSpace:"Space",createDropdownSpaceDescription:"Start a community by topic or interest",createDropdownWish:"Wish",createDropdownWishDescription:"Submit an idea to help improve AWS",exploreAWSConsole:"Console",exploreAWSDocs:"Documentation",exploreAWSSupport:"Support",exploreAWSTitle:"Explore AWS",notifications:"Notifications",searchAriaLabel:"Search",searchPlaceholder:"Search",settings:"Settings",signInToCreate:({appName:e})=>`Sign in to create content on ${e}`,welcomeFallback:"Welcome"}},authSta