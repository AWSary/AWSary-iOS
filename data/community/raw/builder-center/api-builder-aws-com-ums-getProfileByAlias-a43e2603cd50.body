{"profile":{"awsPrograms":[{"category":"AI Hero","joinedAt":2016.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"wongcyrus","avatar":"https://avatars.builderprofile.aws.dev/36ddCTPbJWIsu5rYPgFLUjzxIR8.webp","bio":"Cyrus Wong is an accomplished senior lecturer who oversees the Higher Diploma program in Cloud and Data Centre Administration at the Hong Kong Institute of Information Technology (HKIIT) at IVE(Lee Wai Lee) in Hong Kong. He is a passionate advocate for the adoption of cloud technology across various media and events. With his extensive knowledge and expertise, he has earned prestigious recognitions such as AWS AI Hero, Microsoft MVP - Microsoft Foundry, and Google Developer Expert for Google Cloud Platform (AI)\n\nMicrosoft Azure AI MVP\nhttps://mvp.microsoft.com/en-US/MVP/profile/86da86ff-8786-ed11-aad1-000d3a197333\nGoogle Developer Expert in Google Cloud Platform & AI/ML (GenAI) \nhttps://developers.google.com/profile/u/cyruswong\nHigher Diploma in Cloud and Data Centre Administration\nhttps://www.vtc.edu.hk/admission/en/programme/it114115-higher-diploma-in-cloud-and-data-centre-administration/\n\n","builderProfileId":"1505146e-2f86-4626-b4c3-1169c88f87e5","createdOn":1.713600331776E12,"headline":"AWS AI Hero + Microsoft MVP + Google Developer Experts - GCP(AI)","isStaff":false,"name":"Cyrus Wong"},"location":{"displayLocation":{"countryRegion":"HK","stateProvince":"New Territories"}},"profileStatus":"ACTIVE","socials":{"facebook":"https://www.facebook.com/cywong.vtc","github":"https://github.com/wongcyrus","linkedIn":"https://www.linkedin.com/in/cyruswong/","twitter":"https://x.com/wongcyrus","youtube":"https://www.youtube.com/@cyruswong"}}}