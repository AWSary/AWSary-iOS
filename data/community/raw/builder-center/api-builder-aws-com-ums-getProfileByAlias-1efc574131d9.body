{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"NEW_VOICES"},{"category":"Community Hero","joinedAt":2024.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"ssennettau","avatar":"https://avatars.builderprofile.aws.dev/2olzia0plSviKsjKo5ANTpy4vfl.webp","bio":"Stephen is an experienced cloud technologist, working with AWS for over a decade as an architect, consultant, engineer, and educator.\n\nStephen was a member of the AWS Community Builders program between 2021 and 2024, acting as a mentor to others in the AWS community, and serving as a public speaking coach for upcoming thought leaders through the AWS New Voices program. He is an experienced keynote speaker, delivering sessions at AWS Community Days, AWS Summits, and other tech conferences around the world. As a Content Architect with A Cloud Guru and Pluralsight, he has directly supported the teaching of hundreds of thousands of students around the world on their cloud journey.\n\nHe currently works as a Lead at V2 AI in Australia, specialising in cloud strategy and architecture. Outside of his professional role, he is an active volunteer emergency management officer, and non-profit board director.","builderProfileId":"0fae6e5f-1307-40c6-9fbd-c61b75d860ec","createdOn":1.702205718528E12,"headline":"","isStaff":false,"name":"Stephen Sennett"},"location":{"displayLocation":{"countryRegion":"AU","stateProvince":"VIC"}},"profileStatus":"ACTIVE","socials":{"devto":"https://dev.to/ssennettau","github":"https://github.com/ssennettau","linkedIn":"https://linkedin.com/in/ssennettau","personal":"https://ssennett.net/","youtube":"https://www.youtube.com/@ssennettau"}}}