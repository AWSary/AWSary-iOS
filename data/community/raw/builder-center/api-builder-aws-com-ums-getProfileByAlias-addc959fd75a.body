{"profile":{"awsPrograms":[{"category":"Data Hero","joinedAt":2021.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"anahit","avatar":"https://avatars.builderprofile.aws.dev/32xltDsyWX45iotxXhbJfUmwiNE.webp","bio":"Anahit is a Cloud Architecture & Engineering Lead at F-Secure, where she leads the Cloud Center of Excellence: a team focused on AWS governance, security, and cloud best practices. With over 16 years of experience across full-stack and data engineering, her career has evolved from building monolithic on-premises systems to architecting modern, resilient, and scalable cloud solutions. Anahit is also an active voice in the tech community. She speaks at conferences and meetups, appears on podcasts and YouTube channels, and teaches online courses.","builderProfileId":"5fb21be3-de2e-4ae8-9735-408babe1455d","createdOn":1.717653209088E12,"headline":"","isStaff":false,"name":"Anahit Pogosova"},"location":{"displayLocation":{"countryRegion":"FI"}},"profileStatus":"ACTIVE","socials":{"linkedIn":"https://www.linkedin.com/in/anahit-pogosova","twitter":"https://twitter.com/anahit_fi"}}}