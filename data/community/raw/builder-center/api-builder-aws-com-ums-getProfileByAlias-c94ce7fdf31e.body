{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"category":"Community Hero","joinedAt":2020.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"hiromi","avatar":"https://avatars.builderprofile.aws.dev/2olvtwqXeBYylhDEGLtVH4r7Wpi.webp","bio":"I began as an AWS community leader in 2014. Since then, I’ve been actively involved both in Japan and globally. I’m actively leading a women’s group, a DEI-focused group, and a global community, continuing to foster an inclusive space for new participants and speakers.\n\nFeel free to reach out anytime—via DM or on social media, whether you have something in mind or not!\n\nCommunities I founded and lead as a User Group leader: \nGlobal-focused\n・AWS Global Commyunity | https://www.meetup.com/ja-JP/awsglobalcommunitygatherings/\nJapan-focused\n・JAWS-UG DE&I | https://jawsugdei.connpass.com/\n・JAWS-UG Osaka | https://jawsugosaka.connpass.com/\n・Serverless Meetup | https://serverless.connpass.com/","builderProfileId":"b4878f6e-3e9b-4a3a-81fc-819a30fdd216","createdOn":1.712105324544E12,"headline":"Head of COE, COLLABO STYLE INC.","isStaff":false,"name":"Hiromi｜AWS Community Hero"},"location":{},"profileStatus":"ACTIVE","socials":{"blog":"https://hiroramos.uno","facebook":"https://www.facebook.com/hirobailaora","github":"https://github.com/4hiroramos","linkedIn":"https://www.linkedin.com/in/hiromi-ito-8917a6b7/","personal":"https://www.instagram.com/hiroramos/","twitter":"https://x.com/hiro_baila","youtube":"https://www.youtube.com/@AWSGlobalCommunityGatherings"}}}