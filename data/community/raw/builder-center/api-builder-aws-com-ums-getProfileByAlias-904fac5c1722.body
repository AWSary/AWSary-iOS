{"profile":{"awsPrograms":[{"category":"Serverless Hero","joinedAt":2023.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"deeheber","avatar":"https://avatars.builderprofile.aws.dev/2uuNhE6BP2QPyoPg4bZeHAQ0wr1.webp","bio":"Danielle was an early AWS serverless adopter who joined Stackery, a startup building modern cloud development tools. AWS acquired the company, and the work evolved into Infrastructure Composer in the AWS Console.\n\nShe's passionate about making cloud development more accessible. She gives talks, writes about her experiences, mentors engineers, and builds products people can depend on and love to use.\n\nDanielle co-organizes Believe in Serverless, a Discord community for engineers to learn about serverless and cloud architecture: https://believeinserverless.com/community","builderProfileId":"350fbc02-84cb-4a9c-9af7-622e31d76e65","createdOn":1.70509795328E12,"headline":"","isStaff":false,"name":"Danielle Heberling"},"location":{"displayLocation":{"countryRegion":"US","stateProvince":"OR"}},"profileStatus":"ACTIVE","socials":{"devto":"https://dev.to/deeheber","github":"https://github.com/deeheber","linkedIn":"https://www.linkedin.com/in/deeheber/","personal":"https://danielleheberling.xyz"}}}