{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"category":"DevTools Hero","joinedAt":2023.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"monica","avatar":"https://avatars.builderprofile.aws.dev/2vdQJRRGEwZjk9TmqN4tVvS5dPE.webp","bio":"I am a technology leader, cloud expert, and AWS DevTools Hero with a strong technical foundation built over two decades in IT. Now Head of Hyperscaler Operations, I bring experience from a career path that started as a system administrator and progressed through DevOps engineering and cloud architecture.\n\nAs a committed community builder, I lead several technical communities in Italy, organizing the AWS Community Day Italy and managing various AWS User Groups. I also founded The Cloud House, a non-profit organization dedicated to supporting and growing the tech community.\n\nAs a passionate advocate for diversity in tech, I am dedicated to breaking barriers and creating pathways for women in technology. I speak at international conferences, sharing both technical insights and my experiences as a woman in tech leadership. Through mentoring, writing technical articles, and active community engagement, I work to inspire the next generation of women in technology and promote inclusive tech environments.","builderProfileId":"83853189-14bf-4f72-8482-6de4f312b9db","createdOn":1.712642981888E12,"headline":"AWS Hero | Head of Hyperscaler Operations","isStaff":false,"name":"Monica Colangelo"},"location":{"displayLocation":{"countryRegion":"IT"}},"profileStatus":"ACTIVE","socials":{"blog":"https://monicacolangelo.com","github":"https://github.com/theonlymonica","linkedIn":"https://www.linkedin.com/in/monicacolangelo/","personal":"https://sessionize.com/monicacolangelo"}}}