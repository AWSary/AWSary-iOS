{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"category":"Data Hero","joinedAt":2019.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"mattlewis","avatar":"https://avatars.builderprofile.aws.dev/35ylv8w4H2QMnx5LnWGgHdfcKcY.webp","bio":"Matt is both an AWS Data Hero and AWS Ambassador, after having worked with AWS in production since 2016. Matt founded and runs the AWS South Wales User Group and is part of the ServerlessDays Cardiff organising team.\n\nWith a background as a software engineer, he regularly builds out working prototypes of innovative AWS solutions. He has spent significant time growing cloud skills across teams and establishing cloud operating models including Centre of Excellence and FinOps. He is a regular speaker at events including AWS re:Invent and Summits. Most recently this has included talks on agentic AI and how this is impacting on developer experience and application modernisation","builderProfileId":"d1ba1b48-9b35-4200-b5c3-2952a193043a","createdOn":1.707818090496E12,"headline":"AWS Chief Architect @ IBM | AWS Data Hero | AWS Ambassador","isStaff":false,"name":"Matt Lewis"},"location":{},"profileStatus":"ACTIVE","socials":{"devto":"https://dev.to/mlewis7127","github":"https://github.com/mlewis7127","linkedIn":"https://www.linkedin.com/in/mattelewis/","twitter":"https://x.com/m_lewis"}}}