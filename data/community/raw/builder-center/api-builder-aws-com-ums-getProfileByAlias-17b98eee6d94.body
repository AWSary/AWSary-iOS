{"profile":{"awsPrograms":[{"category":"Serverless Hero","joinedAt":2022.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"loige","avatar":"https://avatars.builderprofile.aws.dev/2xos8giy08ZPvxLibiortpbF6uk.webp","bio":"Full-stack developer turned cloud architect, Luciano Mammino is an AWS Serverless Hero, author of Node.js Design Patterns (https://nodejsdesignpatterns.com/), and co-author of the e-book Crafting Lambda Functions in Rust (https://rust-lambda.com/). He is also the original author of Middy (https://middy.js.org/), the Node.js middleware engine for AWS Lambda. At fourTheorem (https://fourtheorem.com/), he helps companies be successful with AWS through pragmatic, scalable serverless architectures. He loves building with JavaScript/TypeScript, Rust, and modern cloud systems.\n","builderProfileId":"67cdc1ed-8a12-4169-b75d-96c27c96ba9a","createdOn":1.717582954496E12,"isStaff":false,"name":"Luciano Mammino"},"location":{},"profileStatus":"ACTIVE","socials":{"blog":"https://loige.co","devto":"loige","github":"lmammino","linkedIn":"lucianomammino","twitter":"loige","youtube":"@Loige"}}}