{"profile":{"awsPrograms":[{"category":"Serverless Hero","joinedAt":2018.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"theburningmonk","avatar":"https://avatars.builderprofile.aws.dev/36cXExJgf07OFfYQvCJLt9QARr6.webp","bio":"Yan is an AWS Serverless Hero and independent consultant.\n\nYan has run production workloads at scale on AWS since 2010 and has a track record of improving businesses with technology. He has been an architect and principal engineer in a variety of industries ranging from banking, e-commerce, streaming to mobile gaming.\n\nYan is the author of Production-Ready Serverless and co-author of Serverless Architectures on AWS, 2nd Edition. He has delivered over 200 talks at user groups and conferences around the world and is often seen rushing through Schiphol airport to feed his cat on time.","builderProfileId":"a8811f74-899e-4dae-b41c-375584deffc7","createdOn":1.712641540096E12,"headline":"","isStaff":false,"name":"Yan Cui"},"location":{"displayLocation":{"countryRegion":"NL"}},"profileStatus":"ACTIVE","socials":{"blog":"https://theburningmonk.com","github":"https://github.com/theburningmonk","linkedIn":"https://linkedin.com/in/theburningmonk","twitter":"https://twitter.com/theburningmonk","youtube":"https://www.youtube.com/@theburningmonk"}}}