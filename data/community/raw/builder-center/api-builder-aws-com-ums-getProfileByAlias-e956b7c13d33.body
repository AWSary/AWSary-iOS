{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"joinedAt":2026.0,"programName":"NEW_VOICES"},{"category":"Community Hero","joinedAt":2023.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"kinimod","avatar":"https://avatars.builderprofile.aws.dev/2dgl9lE3Xda58B3H6xdbp9F3VNA.webp","bio":"Community Hero Dominik Grzywaczewski is a Senior Cloud Site Reliability Engineer at Chaos Gears with more than 15 years of experience in IT. His primary objective is to assist companies in gaining a deeper understanding of Cloud Computing technologies, and effectively leveraging them to drive faster and more secure innovation. Dominik shares his passion by organizing technical meetups and workshops, and consistently collaborates with AWS community members. He also founded the AWS User Group in Lublin (Poland) and co-organizes the AWS Community Day conference in Warsaw (Poland).\n","builderProfileId":"bc1e48ee-a60a-4fd1-b53c-8ccbedcf043f","createdOn":1.7012883456E12,"headline":"","isStaff":false,"name":"Dominik Grzywaczewski"},"location":{"displayLocation":{"countryRegion":"PL"}},"profileStatus":"ACTIVE","socials":{"linkedIn":"https://www.linkedin.com/in/dominik-grzywaczewski/"}}}