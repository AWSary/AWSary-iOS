{"profile":{"awsPrograms":[{"category":"Container Hero","joinedAt":2024.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"juliafmorgado","avatar":"https://avatars.builderprofile.aws.dev/2dVfObFTDQY7wSNnHmb8gncv07e.webp","bio":"Julia is passionate about helping teams build reliable, observable, and scalable systems. At Dash0, she focuses on bridging the gap between technology and people, enabling organizations to understand their systems better and make data-driven decisions with confidence.\nBeyond her work, Julia is a CNCF Ambassador, AWS Container Hero, Docker Captain, Google Women Techmakers Ambassador, and Girl Code Ambassador. She’s an active community leader who helps organize Kubernetes Community Days New York, AWS Community Day New York, and the CNCF Midtown Meetup NYC, creating spaces where technologists can connect, learn, and grow together.","builderProfileId":"cc902698-eb00-4d6b-84de-153a155daecf","createdOn":1.708880297984E12,"isStaff":false,"name":"Julia Morgado"},"location":{},"profileStatus":"ACTIVE","socials":{"blog":"https://www.juliafmorgado.com/","devto":"juliafmorgado","github":"juliafmorgado","linkedIn":"juliafmorgado/","twitter":"juliafmorgado","youtube":"juliafmorgado"}}}