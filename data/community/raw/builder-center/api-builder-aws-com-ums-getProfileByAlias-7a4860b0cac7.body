{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"category":"Community Hero","joinedAt":2025.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"awsuggoiania","avatar":"https://avatars.builderprofile.aws.dev/2aoTCZZSG36jxSJD6afS2eRMfbu.webp","bio":"25+ years of experience in technology and is the CTO at Softprime Soluções, leading product development and research in digital biometrics, facial recognition, and artificial intelligence (AI). With more than a decade working with cloud computing, he specializes in building scalable and innovative solutions using AWS. Passionate about tech communities, Marcelo founded the AWS User Group in Goiânia in 2018, helping grow the local community. Today, he organizes events such as JoinCommunity and Cloud Summit Cerrado, fostering learning and networking in the Cerrado region.","builderProfileId":"3cfc82f6-04c8-440e-b7b6-b3189aa43377","createdOn":1.704983789568E12,"headline":"Entrepreneur, CTO at Softprime, AWS Community Hero, Microsoft MVP AI","isStaff":false,"name":"Marcelo Paiva"},"location":{"displayLocation":{"countryRegion":"BR","stateProvince":"GO"}},"profileStatus":"ACTIVE","socials":{"devto":"https://dev.to/marcelojpaiva","github":"https://github.com/marcelojpaiva","linkedIn":"https://www.linkedin.com/in/marcelopaiva","personal":"https://sessionize.com/marcelojpaiva"}}}