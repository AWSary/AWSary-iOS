{"profile":{"awsPrograms":[{"category":"Community Hero","joinedAt":2023.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"nickt","avatar":"https://avatars.builderprofile.aws.dev/2rK0s8ugcxVWMm5TqyuD2QnkLWv.webp","bio":"Nick is a Cloud Engineer, Educator, User Group founder, and Christmas Light enthusiast.\n\nHaving worked as a Linux System Administrator for over 20 years, he discovered AWS in 2009 and hasn't looked back. He was one of the original course instructors at cloud education startup A Cloud Guru, having taught over 1 million students the fundamentals of AWS, and also produced the world's first AWS Certified DevOps Engineer course.\n\nHe's the founder of his local Wollongong AWS User Group, co-founder of the Sydney Serverless Meetup and has assisted in the planning and operation of both the ServerlessConf and ServerlessDays ANZ conferences.\n\nHe runs @NickExplainsAWS, where he is attempting to make a video about every single AWS service on Tiktok and YouTube.\n\nEach December Nick brings traffic to a stand still by installing over 75,000 LEDs on his house for his serverless, AWS powered light show spectacular: https://twitter.com/AWSCloudANZ/status/1599629849798316035\n\nYou can keep up to date with Nick's latest projects via his blog or LinkedIn\n ","builderProfileId":"538c1f26-581c-4c29-aea0-648aaabc0d4c","createdOn":1.717455552512E12,"headline":"Senior MLOps / Cloud Engineer","isStaff":false,"name":"Nick Triantafillou"},"location":{"displayLocation":{"countryRegion":"AU","stateProvince":"NSW"}},"profileStatus":"ACTIVE","socials":{"devto":"https://dev.to/xelfer","github":"https://github.com/xelfer/","linkedIn":"https://www.linkedin.com/in/nicktriantafillou/","personal":"https://nickt.com.au","twitter":"https://bsky.app/profile/nickt.com.au","youtube":"https://www.youtube.com/@nickexplainsaws/"}}}