{"profile":{"awsPrograms":[{"joinedAt":2026.0,"programName":"USER_GROUP_LEADER"},{"category":"Community Hero","joinedAt":2015.0,"memberStatus":"ACTIVE","programName":"HERO"}],"basicInfo":{"alias":"youngcto","avatar":"https://avatars.builderprofile.aws.dev/2omy8qr6SNCJVpNo5W8K4x0QOVv.webp","bio":"Helps tech and cloud enablement to multitude various brands, enterprises and online startups. Recognized Cloud Enthusiast and leader (AWS Hero) with genuine enthusiasm for effective mentoring. Comes from a family of teachers and educators, serving in the academe as well as being an AWS Authorized Instructor.\n\nAs co-leader of the AWS User Group Philippines since 2013, regularly answers questions, gives advice and organizes events for the AWS community.\n\n","builderProfileId":"14f8d8ea-9b92-436d-948e-b0b63ac3323b","createdOn":1.721647628288E12,"headline":"Cloud Enthusiast, Community Hero, Podcast Founder","isStaff":false,"name":"Raphael Quisumbing"},"location":{"displayLocation":{"countryRegion":"PH"}},"profileStatus":"ACTIVE","socials":{"blog":"https://kakacomputer.com","devto":"https://dev.to/kakacomputer/","linkedIn":"https://ph.linkedin.com/in/rafi-quisumbing","youtube":"https://youtube.com/c/YoungCTO"}}}