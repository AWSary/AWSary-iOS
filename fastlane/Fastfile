require "base64"
require "shellwords"

default_platform(:ios)

platform :ios do
  desc "Build and upload AWSary to TestFlight"
  lane :testflight do
    app_identifier = ENV.fetch("APP_IDENTIFIER", "pt.tig.awsary")
    team_id = ENV.fetch("APPLE_TEAM_ID")
    profile_name = ENV.fetch("APPSTORE_PROVISIONING_PROFILE_SPECIFIER")
    build_number = ENV["BUILD_NUMBER"]
    changelog = ENV["TESTFLIGHT_CHANGELOG"]
    groups = ENV.fetch("TESTFLIGHT_GROUPS", "")
                .split(",")
                .map(&:strip)
                .reject(&:empty?)

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_P8_BASE64"),
      is_key_content_base64: true,
      in_house: false
    )

    increment_build_number(
      build_number: build_number
    ) if build_number && !build_number.empty?

    build_app(
      project: "ios/awsary.xcodeproj",
      scheme: "awsary (iOS)",
      configuration: "Release",
      clean: true,
      output_directory: "fastlane/build",
      output_name: "AWSary.ipa",
      export_method: "app-store",
      xcargs: [
        "DEVELOPMENT_TEAM=#{team_id}",
        "CODE_SIGN_STYLE=Manual",
        "PROVISIONING_PROFILE_SPECIFIER=#{Shellwords.escape(profile_name)}"
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          app_identifier => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      ipa: "fastlane/build/AWSary.ipa",
      changelog: changelog,
      distribute_external: false,
      groups: groups.empty? ? nil : groups,
      skip_waiting_for_build_processing: ENV["SKIP_WAITING_FOR_BUILD_PROCESSING"] == "true"
    )
  end
end
